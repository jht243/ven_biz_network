{# Visa application landing-page cluster.
   One template renders four URLs:
     /apply-for-venezuelan-visa            (PILLAR)
     /apply-for-venezuelan-visa/us-citizens
     /apply-for-venezuelan-visa/business-visa
     /apply-for-venezuelan-visa/china

   Caller passes:
     page         dict from src/data/visa_application_content.py
     is_pillar    bool — true for the pillar route
     seo, jsonld  standard SEO payload (built in server.py)
     current_year int
     planilla_display_line  str — shared CTA / link label for the planilla guide + tool
#}
{% extends "_base.html.j2" %}

{% block head_extra %}
<style>
  .visa-hero { background: var(--sr-gray-bg); border-bottom: 1px solid var(--sr-gray-light); padding: 28px 0 24px; margin: 0 0 24px; }
  .visa-hero .kicker { font-size: 12px; text-transform: uppercase; letter-spacing: 1.4px; color: var(--sr-red); font-weight: 700; }
  .visa-hero h1 { font-family: var(--font-serif); font-size: 36px; line-height: 1.18; color: var(--sr-blue-dark); margin: 8px 0 12px; font-weight: 700; }
  .visa-hero .lede { font-family: var(--font-serif); font-size: 18px; color: var(--sr-dark-text); line-height: 1.55; max-width: 70ch; }
  @media (max-width: 600px) { .visa-hero h1 { font-size: 28px; } .visa-hero .lede { font-size: 16px; } }

  .key-facts { display: grid; grid-template-columns: 1fr; gap: 12px; margin: 22px 0 0; }
  @media (min-width: 600px) { .key-facts { grid-template-columns: 1fr 1fr; } }
  .key-fact { background: var(--white); border: 1px solid var(--sr-gray-light); border-left: 3px solid var(--sr-blue); padding: 12px 14px; border-radius: 3px; }
  .key-fact .lbl { font-size: 11px; text-transform: uppercase; letter-spacing: 0.8px; color: var(--sr-gray-text); font-weight: 700; margin-bottom: 4px; }
  .key-fact .val { font-size: 14.5px; font-weight: 700; color: var(--sr-dark-text); line-height: 1.35; }

  .warnings-strip { margin: 24px 0; display: flex; flex-direction: column; gap: 10px; }
  .warning-card { background: #fdf3f2; border: 1px solid #f1c5c0; border-left: 4px solid var(--sr-red); padding: 12px 16px; border-radius: 3px; font-size: 14.5px; line-height: 1.5; }
  .warning-card .warning-label { font-weight: 700; color: var(--sr-red); margin-right: 6px; }

  .section { margin: 36px 0 0; }
  .section h2 { font-family: var(--font-serif); font-size: 26px; color: var(--sr-blue-dark); margin: 0 0 12px; font-weight: 700; line-height: 1.25; }
  .section .section-intro { font-size: 16px; color: var(--sr-dark-text); margin-bottom: 18px; line-height: 1.6; max-width: 72ch; }

  /* Two columns by default to reduce vertical scroll / whitespace; one column on narrow phones. */
  /* Stretch rows so paired “Complete now” cards share one height; non-CTA cards stay content-sized. */
  .doc-list { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 12px 16px; align-items: stretch; }
  @media (max-width: 599px) { .doc-list { grid-template-columns: 1fr; } }
  .doc-list li { background: var(--white); border: 1px solid var(--sr-gray-light); border-radius: 3px; padding: 14px 16px; }
  .doc-list li:not(:has(.doc-cta)) { align-self: start; }
  .doc-list li:has(.doc-cta) { display: flex; flex-direction: column; min-height: 100%; }
  .doc-list li:has(.doc-cta) .doc-detail { flex: 1 1 auto; min-height: 0; }
  .doc-list .doc-label { font-weight: 700; color: var(--sr-blue-dark); display: block; margin-bottom: 4px; font-size: 14.5px; }
  .doc-list .doc-detail { display: block; font-size: 13.5px; color: var(--sr-dark-text); line-height: 1.55; }
  .doc-list .doc-cta { display: inline-block; align-self: flex-start; margin-top: 12px; font-size: 13px; font-weight: 700; color: #fff; background: var(--sr-red); padding: 7px 14px; border-radius: 3px; text-decoration: none; }
  .doc-list .doc-cta:hover { background: #a01d18; color: #fff; }

  .apply-steps { list-style: none; counter-reset: step; padding: 0; margin: 12px 0 0; }
  .apply-steps > li { display: grid; grid-template-columns: 38px 1fr; gap: 12px; padding: 14px 0; border-top: 1px dotted var(--sr-gray-light); counter-increment: step; }
  .apply-steps > li:first-child { border-top: 0; padding-top: 4px; }
  .apply-steps .step-num { width: 30px; height: 30px; border-radius: 50%; background: var(--sr-red); color: #fff; font-weight: 700; font-size: 14px; display: flex; align-items: center; justify-content: center; line-height: 1; }
  .apply-steps .step-num::before { content: counter(step); }
  .apply-steps h4 { font-family: var(--font-sans); font-size: 15.5px; font-weight: 700; color: var(--sr-dark-text); margin: 4px 0 6px; }
  .apply-steps p { font-size: 14px; color: var(--sr-dark-text); margin: 0 0 8px; line-height: 1.6; }
  .apply-steps .step-service-plug { background: #fff8f7; border-left: 3px solid var(--sr-red); padding: 9px 12px; margin-top: 10px; }
  .apply-steps .step-service-plug a { color: var(--sr-red); font-weight: 700; text-decoration: none; }
  .apply-steps .step-service-plug a:hover { text-decoration: underline; }
  .apply-steps .step-cta-row { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-top: 4px; }
  .apply-steps .step-cta { display: inline-block; font-size: 13px; font-weight: 600; color: #fff; background: var(--sr-blue); padding: 6px 14px; border-radius: 999px; text-decoration: none; }
  .apply-steps .step-cta:hover { background: var(--sr-blue-dark); }
  .fees-table, .timeline-table { width: 100%; border-collapse: collapse; margin: 4px 0 0; font-size: 14.5px; }
  .fees-table th, .fees-table td, .timeline-table th, .timeline-table td { text-align: left; padding: 10px 12px; border-bottom: 1px solid var(--sr-gray-light); vertical-align: top; }
  .fees-table th, .timeline-table th { font-size: 12px; text-transform: uppercase; letter-spacing: 0.6px; color: var(--sr-gray-text); font-weight: 700; }
  .fees-table .val, .timeline-table .val { font-weight: 700; color: var(--sr-blue-dark); white-space: nowrap; }
  .fees-table .note { font-size: 13px; color: var(--sr-gray-text); }

  .faq-item { background: var(--white); border: 1px solid var(--sr-gray-light); border-radius: 3px; padding: 14px 18px; margin: 0 0 10px; }
  .faq-item h3 { font-family: var(--font-serif); font-size: 17px; color: var(--sr-blue-dark); margin: 0 0 8px; font-weight: 700; line-height: 1.4; }
  .faq-item p { font-size: 14.5px; color: var(--sr-dark-text); margin: 0; line-height: 1.6; }

  /* Match tools index: index-grid + index-card; cap at three links; three columns on wide screens. */
  .section .keep-going-grid.index-grid { margin: 8px 0 24px; }
  @media (min-width: 720px) {
    .section .keep-going-grid.index-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 980px) {
    .section .keep-going-grid.index-grid { grid-template-columns: 1fr 1fr 1fr; }
  }

  .mmpre-form-deck { display: grid; grid-template-columns: 1fr; gap: 10px; margin: 4px 0 0; }
  @media (min-width: 700px) { .mmpre-form-deck { grid-template-columns: 1fr 1fr; } }
  .mmpre-form-deck a { display: block; background: var(--white); border: 1px solid var(--sr-gray-light); border-radius: 4px; padding: 16px; text-decoration: none; color: inherit; }
  .mmpre-form-deck a:hover { border-color: var(--sr-blue); }
  .mmpre-form-deck .m-label { font-family: var(--font-serif); font-weight: 700; color: var(--sr-blue-dark); display: block; margin-bottom: 4px; }
  .mmpre-form-deck .m-sub { font-size: 14px; color: var(--sr-gray-text); line-height: 1.5; }

  .needs-visa-box { background: var(--sr-gray-bg); border-left: 3px solid var(--sr-blue); padding: 14px 18px; margin: 4px 0 0; font-size: 15px; line-height: 1.6; }
  .needs-visa-box a { color: var(--sr-blue); font-weight: 600; }

  .visa-service-callout { background: #f7fafc; border: 1px solid var(--sr-gray-light); border-left: 4px solid var(--sr-red); border-radius: 4px; padding: 18px 20px; margin: 22px 0 0; }
  .visa-service-callout h3 { font-family: var(--font-serif); font-size: 20px; color: var(--sr-blue-dark); margin: 0 0 8px; line-height: 1.3; }
  .visa-service-callout p { font-size: 14.5px; color: var(--sr-dark-text); line-height: 1.6; margin: 0 0 12px; max-width: 72ch; }
  .visa-service-callout .service-cta { display: inline-block; font-size: 13.5px; font-weight: 700; color: #fff; background: var(--sr-red); padding: 8px 16px; border-radius: 3px; text-decoration: none; }
  .visa-service-callout .service-cta:hover { background: #a01d18; color: #fff; }

</style>
{% endblock %}

{% block content %}
<section class="container">
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <a href="/travel">Travel to Venezuela</a><span>/</span>
    {% if is_pillar %}
      <span>{{ page.page_label }}</span>
    {% else %}
      <a href="/apply-for-venezuelan-visa">Apply for a Venezuelan visa</a><span>/</span>
      <span>{{ page.page_label }}</span>
    {% endif %}
  </nav>
</section>

<header class="visa-hero">
  <div class="container">
    <div class="kicker">{{ page.kicker }}</div>
    <h1>{{ page.h1 }}</h1>
    <p class="lede">{{ page.lede }}</p>

    <div class="key-facts">
      {% for kf in page.key_facts %}
      <div class="key-fact">
        <div class="lbl">{{ kf.label }}</div>
        <div class="val">{{ kf.value }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</header>

<section class="container">

  {% if page.intro_warnings %}
  <div class="warnings-strip">
    {% for w in page.intro_warnings %}
    <div class="warning-card"><span class="warning-label">{{ w.label }}.</span>{{ w.body }}</div>
    {% endfor %}
  </div>
  {% endif %}

  <div class="section">
    <h2>Do you need a Venezuelan visa?</h2>
    <p class="section-intro">{{ page.needs_visa_summary }}</p>
    <div class="needs-visa-box">
      Not sure about your passport? Use the
      <a href="/tools/venezuela-visa-requirements">Venezuela visa-requirements checker</a>
      to see whether you need a visa.
    </div>
  </div>

  <div class="section">
    <h2>Step-by-step application</h2>
    {% if page.steps_intro %}<p class="section-intro">{{ page.steps_intro }}</p>{% endif %}
    <ol class="apply-steps">
      {% for s in page.steps %}
      <li{% if s.anchor %} id="{{ s.anchor }}"{% endif %}>
        <div class="step-num"></div>
        <div>
          <h4>{{ s.title }}</h4>
          <p>{{ s.detail }}</p>
          {% if s.service_plug and s.service_url %}
          <p class="step-service-plug">
            {{ s.service_plug }}
            <a href="{{ s.service_url }}">{{ s.service_label|default("Get visa help") }} &rarr;</a>
          </p>
          {% endif %}
          {% if s.url %}
          <div class="step-cta-row">
            <a class="step-cta" href="{{ s.url }}" target="_blank" rel="noopener">
              {%- if 'usembassy' in s.url -%}
              Embassy Application Instructions
              {%- else -%}
              {{ s.url_label or 'Open the e-visa portal' }}
              {%- endif -%} &rarr;</a>
          </div>
          {% endif %}
        </div>
      </li>
      {% endfor %}
    </ol>
  </div>

  <div class="visa-service-callout">
    <h3>Want help filing the application?</h3>
    <p>
      Our same-day Venezuela visa application service prepares the document
      package, files through the application channel, and monitors the case after
      submission. Government fees are separate.
    </p>
    <a class="service-cta" href="/get-venezuela-visa">Get Venezuela visa help &rarr;</a>
  </div>

  <div class="section">
    <h2>What you need before you start</h2>
    <p class="section-intro">Gather these documents before you open the application portal. Missing or low-quality scans are the most common cause of approval delays.</p>
    <ul class="doc-list">
      {% for d in page.documents %}
      <li>
        <span class="doc-label">{{ d.label }}</span>
        <span class="doc-detail">{{ d.detail }}</span>
        {% if d.cta is defined and d.cta and d.cta.href %}
        <a class="doc-cta" href="{{ d.cta.href }}" target="_blank" rel="noopener">{{ d.cta.label|default("Complete now") }} &rarr;</a>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>

  <div class="section">
    <h2>Printable MPPRE forms (Planilla + Declaración)</h2>
    <p class="section-intro">
      These are the two documents travelers upload most often with the e-visa file.
      Both tools use <strong>English on screen</strong> (labels and tips) and produce a
      <strong>Spanish-labelled PDF</strong> for the portal. Use your browser’s
      <strong>Print</strong> dialog and choose <strong>Save as PDF</strong>
      — the same flow as the
      <a href="/travel/emergency-card">Caracas Emergency Card</a>.
    </p>
    <div class="mmpre-form-deck">
      <a href="/apply-for-venezuelan-visa/planilla">
        <span class="m-label">{{ planilla_display_line }}</span>
        <span class="m-sub">English labels while you type; print saves Spanish section titles and field labels. Cursive-style signature from your typed name.</span>
      </a>
      <a href="/apply-for-venezuelan-visa/declaracion-jurada">
        <span class="m-label">Declaración jurada</span>
        <span class="m-sub">English how-to box and placeholders; official declaration body stays Spanish on your PDF. Typed signature renders in cursive.</span>
      </a>
    </div>
    <p class="section-intro" style="margin-top: 14px; max-width: 72ch;">
      First time seeing these names? Read our short guides:
      <a href="/planilla-de-solicitud-de-visa">{{ planilla_display_line }}</a>
      ·
      <a href="/declaracion-jurada-visa-venezolana">declaración jurada (visa venezolana)</a>.
    </p>
  </div>

  <div class="section">
    <h2>Fees</h2>
    <table class="fees-table">
      <thead>
        <tr><th>Item</th><th>Amount</th><th>Notes</th></tr>
      </thead>
      <tbody>
        {% for f in page.fees %}
        <tr>
          <td>{{ f.label }}</td>
          <td class="val">{{ f.value }}</td>
          <td class="note">{{ f.note }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <div class="section">
    <h2>Timeline</h2>
    <table class="timeline-table">
      <tbody>
        {% for t in page.timeline %}
        <tr>
          <td>{{ t.label }}</td>
          <td class="val">{{ t.value }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <div class="section">
    <h2>Frequently asked questions</h2>
    {% for f in page.faqs %}
    <div class="faq-item">
      <h3>{{ f.q }}</h3>
      <p>{{ f.a }}</p>
    </div>
    {% endfor %}
  </div>

  {% if page.related_links %}
  <div class="section">
    <h2>Keep going</h2>
    <div class="index-grid keep-going-grid">
      {% for r in page.related_links[0:3] %}
      <article class="index-card">
        <a class="card-link" href="{{ r.href }}" aria-label="{{ r.label }}"></a>
        <a class="title-link" href="{{ r.href }}">{{ r.label }}</a>
        <p class="summary">{{ r.description }}</p>
      </article>
      {% endfor %}
    </div>
  </div>
  {% endif %}

</section>
{% endblock %}
