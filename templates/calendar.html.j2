{% extends "_base.html.j2" %}

{% block head_extra %}
<style>
  .cal-list { list-style: none; margin: 24px 0 32px; padding: 0; }
  .cal-item { display: flex; gap: 16px; padding: 18px 20px; background: var(--white); border: 1px solid var(--sr-gray-light); border-radius: 4px; margin-bottom: 12px; align-items: flex-start; }
  .cal-item .date-block { background: var(--sr-blue); color: var(--white); padding: 10px 14px; border-radius: 3px; text-align: center; min-width: 88px; flex-shrink: 0; }
  .cal-item .date-block .lbl { font-family: var(--font-serif); font-weight: 700; font-size: 16px; line-height: 1.1; }
  .cal-item .date-block .sub { font-size: 11px; opacity: 0.85; margin-top: 4px; }
  .cal-item .body h3 { font-family: var(--font-serif); font-size: 17px; color: var(--sr-blue-dark); margin-bottom: 4px; }
  .cal-item .body p { font-size: 14px; color: var(--sr-gray-text); margin: 0; }
  .cal-item.urgent { border-left: 4px solid var(--sr-red); }
  .cal-item.urgent .date-block { background: var(--sr-red); }
  .cal-item.upcoming { border-left: 4px solid #f5b041; }
  .cal-item.upcoming .date-block { background: #f5b041; }
</style>
{% endblock %}

{% block content %}
<section class="container">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <a href="/invest-in-venezuela">Invest in Venezuela</a><span>/</span>
    <span>Investor Calendar</span>
  </nav>

  <header style="margin: 16px 0 24px;">
    <div style="font-size:12px; text-transform:uppercase; letter-spacing:1.4px; color:#cc0000; font-weight:700;">
      Live calendar · Updated daily from primary sources
    </div>
    <h1 style="font-family:var(--font-serif); font-size:36px; color:var(--sr-blue-dark); margin:8px 0 12px;">
      Venezuela Investor Calendar
    </h1>
    <p style="font-family:var(--font-serif); font-style:italic; color:var(--sr-gray-text); font-size:18px;">
      Upcoming OFAC license expirations, Asamblea Nacional sessions, BCV
      announcements, sovereign debt deadlines, and other dates that move
      Venezuelan asset prices.
    </p>
  </header>

  {% if calendar_events %}
  <div class="cr-search-panel" role="search" aria-label="Search investor calendar">
    <label class="cr-search-label" for="calendar-search">Search calendar</label>
    <div class="cr-search-row">
      <input type="search" id="calendar-search" placeholder="Search OFAC, license, BCV, debt, Asamblea…" autocomplete="off">
    </div>
  </div>

  <div class="cr-empty-filter" id="calendar-empty">No calendar items match that search.</div>

  <ul class="cal-list">
    {% for ev in calendar_events %}
    <li class="cal-item {{ ev.css_class or '' }}" data-search="{{ ((ev.date_label or '') ~ ' ' ~ (ev.subtitle or '') ~ ' ' ~ ev.title ~ ' ' ~ (ev.note or ''))|lower }}">
      <div class="date-block">
        <div class="lbl">{{ ev.date_label or '?' }}</div>
        {% if ev.subtitle %}<div class="sub">{{ ev.subtitle }}</div>{% endif %}
      </div>
      <div class="body">
        <h3>{{ ev.title }}</h3>
        {% if ev.note %}<p>{{ ev.note }}</p>{% endif %}
      </div>
    </li>
    {% endfor %}
  </ul>
  {% else %}
  <p style="padding: 32px 0; color: var(--sr-gray-text);">
    No upcoming dates extracted from this week's briefings yet — check back
    after the next pipeline run, or browse the
    <a href="/briefing">latest analysis</a> directly.
  </p>
  {% endif %}

  <p style="font-size: 12px; color: var(--sr-gray-text); margin: 32px 0;">
    Calendar items are extracted from official Venezuelan and US-government
    sources by our analysis pipeline. Always verify with the primary source
    before acting. See also the
    <a href="/sanctions-tracker">OFAC sanctions tracker</a> and the
    <a href="/invest-in-venezuela">investor guide to Venezuela</a>.
  </p>

  {% from "_recent_briefings.html.j2" import recent_briefings_rail %}
  {{ recent_briefings_rail(
       recent_briefings,
       heading="Latest analysis",
       intro="Recent investor briefings on the events, deadlines, and sessions driving this calendar.",
  ) }}

</section>

<script>
(function () {
  var input = document.getElementById('calendar-search');
  var empty = document.getElementById('calendar-empty');
  if (!input) return;
  var items = Array.prototype.slice.call(document.querySelectorAll('.cal-item[data-search]'));
  input.addEventListener('input', function () {
    var q = input.value.trim().toLowerCase();
    var visible = 0;
    items.forEach(function (item) {
      var show = !q || (item.getAttribute('data-search') || '').indexOf(q) !== -1;
      item.style.display = show ? '' : 'none';
      if (show) visible += 1;
    });
    if (empty) empty.style.display = q && visible === 0 ? 'block' : 'none';
  });
})();
</script>
{% endblock %}
