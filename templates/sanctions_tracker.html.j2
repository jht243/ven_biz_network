{% extends "_base.html.j2" %}

{% block head_extra %}
<style>
  .filter-bar { display:flex; flex-wrap:wrap; gap:8px; margin: 16px 0 24px; }
  .filter-bar input, .filter-bar select { padding: 8px 12px; border: 1px solid var(--sr-gray-light); border-radius: 3px; font-size: 14px; font-family: var(--font-sans); }
  .filter-bar input { flex: 1 1 240px; }
  .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px; margin: 24px 0 32px; }
  .stat-card { background: var(--sr-gray-bg); border-left: 3px solid var(--sr-blue); padding: 14px 16px; }
  .stat-card .num { font-family: var(--font-serif); font-size: 28px; font-weight: 700; color: var(--sr-blue-dark); display:block; }
  .stat-card .lbl { font-size: 12px; text-transform: uppercase; letter-spacing: 0.7px; color: var(--sr-gray-text); }
  .sdn-table { width: 100%; border-collapse: collapse; font-size: 14px; }
  .sdn-table th { background: var(--sr-blue); color: var(--white); padding: 10px 12px; text-align: left; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; position: sticky; top: 0; }
  .sdn-table td { padding: 10px 12px; border-bottom: 1px solid var(--sr-gray-light); vertical-align: top; }
  .sdn-table tr:nth-child(even) td { background: var(--sr-gray-bg); }
  .sdn-table .name { font-weight: 600; color: var(--sr-blue-dark); }
  .sdn-table .type { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.4px; background: var(--sr-gray-light); color: var(--sr-dark-text); }
  .sdn-table .type-individual { background: #e3f2fd; color: #002b5e; }
  .sdn-table .type-vessel { background: #e0f7fa; color: #006064; }
  .sdn-table .type-aircraft { background: #fff3e0; color: #bf360c; }
  .sdn-table .program { font-family: 'Menlo', monospace; font-size: 12px; color: var(--sr-gray-text); white-space: nowrap; }
  .sdn-table .remarks { color: var(--sr-gray-text); font-size: 13px; }
  .sdn-empty { padding: 32px; text-align: center; color: var(--sr-gray-text); }
</style>
{% endblock %}

{% block content %}
<section class="container-wide">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <a href="/invest-in-venezuela">Invest in Venezuela</a><span>/</span>
    <span>OFAC Sanctions Tracker</span>
  </nav>

  <header style="margin: 16px 0 24px;">
    <div style="font-size:12px; text-transform:uppercase; letter-spacing:1.4px; color:#cc0000; font-weight:700;">
      Live tracker · Refreshed twice daily from US Treasury
    </div>
    <h1 style="font-family:var(--font-serif); font-size:36px; color:var(--sr-blue-dark); margin:8px 0 12px;">
      OFAC Venezuela Sanctions Tracker
    </h1>
    <p style="font-family:var(--font-serif); font-style:italic; color:var(--sr-gray-text); font-size:18px; max-width:760px;">
      Every Specially Designated National (SDN), vessel, and aircraft on the
      US Treasury OFAC list under Venezuela-related programs. Pulled directly
      from the OFAC SDN consolidated list and refreshed twice daily at 10:00 AM
      and 5:00 PM Medellín time.
    </p>
    {% if last_refreshed_local %}
    <div style="display:flex; flex-wrap:wrap; gap:18px; align-items:center; margin-top:14px; padding:10px 14px; background: var(--sr-gray-bg); border-left: 3px solid #2e7d32; font-size:13px; color: var(--sr-gray-text);">
      <span>
        <strong style="color: var(--sr-dark-text);">Last refreshed:</strong>
        {{ last_refreshed_local }}
        {% if last_refreshed_relative %}
        <span style="color: #2e7d32; font-weight:600;">· {{ last_refreshed_relative }}</span>
        {% endif %}
      </span>
      {% if next_refresh_local %}
      <span>
        <strong style="color: var(--sr-dark-text);">Next refresh:</strong>
        {{ next_refresh_local }}
      </span>
      {% endif %}
    </div>
    {% endif %}
  </header>

  <div class="stats-row">
    <div class="stat-card"><span class="num">{{ stats.total }}</span><span class="lbl">Total designations</span></div>
    <a class="stat-card" href="/sanctions/individuals" style="text-decoration:none;color:inherit;"><span class="num">{{ stats.individuals }}</span><span class="lbl">Individuals →</span></a>
    <a class="stat-card" href="/sanctions/entities" style="text-decoration:none;color:inherit;"><span class="num">{{ stats.entities }}</span><span class="lbl">Entities →</span></a>
    <a class="stat-card" href="/sanctions/vessels" style="text-decoration:none;color:inherit;"><span class="num">{{ stats.vessels }}</span><span class="lbl">Vessels →</span></a>
    <a class="stat-card" href="/sanctions/aircraft" style="text-decoration:none;color:inherit;"><span class="num">{{ stats.aircraft }}</span><span class="lbl">Aircraft →</span></a>
  </div>

  {# Each stat card above links to a full A-Z directory; the search table
     below stays the fast-filter UX. Per-name profile pages
     (/sanctions/<bucket>/<slug>) are linked from those directories. #}
  <p style="font-size:14px;color:var(--sr-gray-text);margin:-12px 0 24px;">
    Looking for a specific name? Browse the
    <a href="/sanctions/individuals">individuals</a>,
    <a href="/sanctions/entities">entities</a>,
    <a href="/sanctions/vessels">vessels</a>, or
    <a href="/sanctions/aircraft">aircraft</a> directories — each entry has its own profile page.
  </p>

  <div class="filter-bar">
    <input type="text" id="sdn-search" placeholder="Search by name, program, or remarks…" aria-label="Search SDN entries">
    <select id="sdn-type-filter" aria-label="Filter by type">
      <option value="">All types</option>
      <option value="individual">Individuals</option>
      <option value="vessel">Vessels</option>
      <option value="aircraft">Aircraft</option>
      <option value="entity">Entities</option>
    </select>
  </div>

  <div style="overflow-x: auto; max-height: 75vh; border:1px solid var(--sr-gray-light);">
    <table class="sdn-table" id="sdn-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Type</th>
          <th>Program</th>
          <th>Remarks</th>
        </tr>
      </thead>
      <tbody>
        {% for s in sdn_entries %}
        <tr data-name="{{ s.name|lower }}" data-type="{{ s.type }}" data-program="{{ s.program|lower }}" data-remarks="{{ s.remarks|lower }}">
          <td class="name">{{ s.name }}</td>
          <td><span class="type type-{{ s.type }}">{{ s.type }}</span></td>
          <td class="program">{{ s.program or '—' }}</td>
          <td class="remarks">{{ s.remarks or '—' }}</td>
        </tr>
        {% else %}
        <tr><td colspan="4" class="sdn-empty">No OFAC SDN entries found in the database yet.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <p style="font-size: 12px; color: var(--sr-gray-text); margin: 16px 0 32px;">
    Authoritative source: <a href="https://www.treasury.gov/ofac/downloads/sdn.csv" rel="nofollow noopener" target="_blank">US Treasury OFAC SDN consolidated list</a>.
    Always verify with the official source before making compliance decisions.
    See also <a href="/invest-in-venezuela">how OFAC sanctions affect Venezuelan investment</a>
    and the <a href="/tools/ofac-venezuela-general-licenses">general license lookup</a>.
  </p>

  <script>
    (function() {
      var table = document.getElementById('sdn-table');
      var rows = Array.prototype.slice.call(table.querySelectorAll('tbody tr[data-name]'));
      var search = document.getElementById('sdn-search');
      var typeFilter = document.getElementById('sdn-type-filter');
      function apply() {
        var q = (search.value || '').toLowerCase().trim();
        var t = typeFilter.value;
        rows.forEach(function(r) {
          var matchT = !t || r.dataset.type === t;
          var matchQ = !q || r.dataset.name.indexOf(q) !== -1 || r.dataset.program.indexOf(q) !== -1 || r.dataset.remarks.indexOf(q) !== -1;
          r.style.display = (matchT && matchQ) ? '' : 'none';
        });
      }
      search.addEventListener('input', apply);
      typeFilter.addEventListener('change', apply);
    })();
  </script>

</section>
{% endblock %}
