{% extends "_base.html.j2" %}
{% from "_base.html.j2" import share_button %}
{% from "_cluster_nav.html.j2" import cluster_nav %}
{% from "_card_grid.html.j2" import card_grid_section %}
{% from "_recent_briefings.html.j2" import recent_briefings_rail %}

{% block content %}
<article class="container">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <span>{{ page.title }}</span>
  </nav>

  <header>
    {% if page.page_type == 'sector' %}
    <div style="font-size:12px; text-transform:uppercase; letter-spacing:1.4px; color:#cc0000; font-weight:700;">
      Sector landing page
    </div>
    {% else %}
    <div style="font-size:12px; text-transform:uppercase; letter-spacing:1.4px; color:#cc0000; font-weight:700;">
      Investor guide
    </div>
    {% endif %}
    <h1>{{ page.title }}</h1>
    {% if page.subtitle %}<p class="subtitle">{{ page.subtitle }}</p>{% endif %}
    <div class="meta">
      <span><strong>Last updated</strong> {{ page.last_generated_at.strftime('%B %d, %Y') }}</span>
      {% if page.word_count %}<span>{{ page.word_count }}-word guide</span>{% endif %}
      <span><strong>Editor</strong> Caracas Research</span>
      <span style="margin-left:auto;">{{ share_button('https://caracasresearch.com' ~ page.canonical_path, page.title) }}</span>
    </div>
  </header>

  {% if page.sections_json and page.sections_json.table_of_contents %}
  <aside class="takeaways" aria-label="On this page">
    <h3>On this page</h3>
    <ul>
      {% for s in page.sections_json.table_of_contents %}
      <li><a href="#{{ s.anchor }}">{{ s.label }}</a></li>
      {% endfor %}
    </ul>
  </aside>
  {% endif %}

  {% if page.sections_json and page.sections_json.key_takeaways %}
  <aside class="takeaways" aria-label="Key takeaways" style="border-left-color:#cc0000;">
    <h3>Key takeaways</h3>
    <ul>
      {% for t in page.sections_json.key_takeaways %}<li>{{ t }}</li>{% endfor %}
    </ul>
  </aside>
  {% endif %}

  <div class="body">
    {{ page.body_html | safe }}
  </div>

  {% if page.canonical_path == '/sectors/real-estate' %}
  <section class="takeaways" style="border-left-color:#cc0000;">
    <h3>Investor listing vertical</h3>
    <p style="margin:0;">
      For English-language sample listings, city price context, and buyer guidance, see
      <a href="/real-estate/">Venezuela real estate listings and buyer guidance</a>.
    </p>
  </section>
  {% elif page.canonical_path == '/invest-in-venezuela' %}
  <section class="takeaways" style="border-left-color:#cc0000;">
    <h3>Real estate investment</h3>
    <p style="margin:0;">
      Investors comparing hard assets can review
      <a href="/real-estate/">Venezuela real estate investment opportunities</a>
      alongside the broader sector and sanctions analysis on this page.
    </p>
  </section>
  {% endif %}

  {# FAQ block — only emitted when src/page_renderer.py supplies a
     faq_block list via _LANDING_PAGE_SEO_OVERRIDES. Visible HTML
     mirrors the FAQPage JSON-LD so Google honors the rich result. #}
  {% if faq_block %}
  <section class="sdn-faq" aria-label="Frequently asked questions" style="margin-top:32px;">
    <h2 id="faq">Frequently asked questions</h2>
    {% for q, a in faq_block %}
    <details {% if loop.first %}open{% endif %} style="border:1px solid #d8dde6; border-left:3px solid #002b5e; border-radius:3px; padding:12px 16px; margin-bottom:8px; background:#fff;">
      <summary style="font-family:var(--font-serif); color:#002b5e; font-weight:700; font-size:16px; cursor:pointer; list-style:none;">
        <span style="color:#cc0000; font-weight:700;">▸</span> {{ q }}
      </summary>
      <div style="font-size:14px; color:#222; margin-top:10px; line-height:1.55;">
        {{ a }}
      </div>
    </details>
    {% endfor %}
  </section>
  {% endif %}

  {# Cross-cluster bridge: when a sector page maps cleanly to one or
     more OFAC programs (gold sector → EO 13850, gov't block → EO 13884
     etc.), surface the actual sanctioned actors in that sector with
     deep links into the per-name SDN profile pages. This both helps
     readers (sector context → who's actually sanctioned in it) AND
     gives Google a rich, descriptive set of internal links from the
     investment cluster to the sanctions cluster — completing the
     reciprocal link that already runs the other way. #}
  {#
    OFAC-sanctioned actors bridge — when a sector page maps cleanly to
    one or more OFAC programs we surface the current sanctioned actors
    in that sector here. Two wins: readers get the "who's actually
    sanctioned" context, and Google sees a rich, descriptive internal-
    link set from the investment cluster into the sanctions cluster.
    Rendered as the shared 3-card discovery grid.
  #}
  {% if sector_sdn_actors %}
  {% set _sdn_cards = [] %}
  {% for p in sector_sdn_actors %}
    {% set _ = _sdn_cards.append({
        'href': p.url_path,
        'eyebrow': 'ACTIVE SDN',
        'title': p.display_name,
        'tagline': 'On the OFAC Venezuela-related SDN list — full profile with biographical data, linked entities, and source citations.',
        'meta_rows': ['<strong>' ~ p.program ~ '</strong>', p.category_singular|title],
        'cta': 'Open profile'
      }) %}
  {% endfor %}
  {{ card_grid_section(
       heading='OFAC-sanctioned actors in this sector',
       meta=(sector_sdn_actors|length|string) ~ ' currently designated',
       intro='Individuals and entities currently on the US Treasury OFAC SDN list under programs we map to this sector.',
       cards=_sdn_cards,
       aria_label='Sanctioned actors in this sector',
       footer_link={'href': '/sanctions-tracker', 'label': 'Browse all OFAC Venezuela-program designations'},
       footer_mode='always'
  ) }}
  {% endif %}

  {# Latest related briefings — shared rail reuses the 3-card grid. #}
  {{ recent_briefings_rail(recent_briefings, heading='Latest related briefings') }}

  {{ cluster_nav(cluster_ctx) }}

</article>
{% endblock %}
