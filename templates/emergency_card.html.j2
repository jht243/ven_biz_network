<!DOCTYPE html>
<html lang="en">
<head>
  {% include "_google_tag.html.j2" %}

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ seo.title }}</title>
  <meta name="description" content="{{ seo.description }}">
  <link rel="canonical" href="{{ seo.canonical }}">
  <meta name="robots" content="noindex,follow">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=Open+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">

  <style>
    /* =========================================================================
       Caracas Emergency Card — single A4 page, bilingual, print-first.
       Spanish-first content for hand-to-stranger usage; English second
       for the traveller. Designed to fold into a passport.

       On screen:
         - Grey "desk" background.
         - Toolbar that explains editability and lets the user pick which
           embassy to feature on the printed sheet.
         - Editable fields visibly highlighted (yellow + dotted underline).
         - A "Before you land" prep checklist above the card — *screen only*,
           never printed.
         - Dashed page barrier on the white sheet so the user can preview
           the printable boundary.
       On paper:
         - Toolbar, prep checklist, dashed barriers, yellow editable hints
           all suppressed; only the card itself prints.
       ========================================================================= */

    :root {
      --ink: #111;
      --ink-soft: #444;
      --rule: #222;
      --rule-soft: #999;
      --red: #cc0000;
      --red-dark: #8b0000;
      --navy: #001f44;
      --bg-shade: #f4f4f0;
      --edit-bg: #fff7c2;
      --edit-line: #b8a200;
      --serif: 'Libre Baskerville', 'Times New Roman', Times, serif;
      --sans: 'Open Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { background: #d9d9d4; }
    body {
      font-family: var(--sans);
      color: var(--ink);
      line-height: 1.35;
      -webkit-font-smoothing: antialiased;
      padding: 24px 0 60px;
    }

    /* ---- ON-SCREEN TOOLBAR (loud, instructional) ------------------------- */
    .screen-toolbar {
      max-width: 210mm;
      margin: 0 auto 16px;
      background: #fff;
      border: 1px solid #c0c0bc;
      border-top: 5px solid var(--navy);
      border-radius: 4px;
      overflow: hidden;
      font-size: 14px;
      color: var(--ink);
    }
    .toolbar-head {
      padding: 14px 18px 12px;
      border-bottom: 1px solid #e5e5df;
      background: #fffbe6;
    }
    .toolbar-head h1 {
      font-family: var(--serif);
      font-size: 18px;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 4px;
    }
    .toolbar-head p { font-size: 13.5px; color: var(--ink-soft); line-height: 1.5; }
    .toolbar-head p strong {
      color: var(--ink);
      background: var(--edit-bg);
      padding: 1px 6px;
      border-radius: 2px;
      border-bottom: 1.5px dotted var(--edit-line);
    }
    .toolbar-body {
      padding: 14px 18px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 16px;
      align-items: end;
    }
    @media (max-width: 720px) { .toolbar-body { grid-template-columns: 1fr; } }
    .toolbar-body label {
      display: block;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--navy);
      margin-bottom: 6px;
    }
    .toolbar-body select {
      width: 100%;
      max-width: 420px;
      font-family: var(--sans);
      font-size: 14px;
      font-weight: 600;
      padding: 9px 12px;
      border: 1.5px solid var(--navy);
      border-radius: 3px;
      background: #fff;
      color: var(--ink);
      cursor: pointer;
    }
    .toolbar-actions { display: flex; gap: 10px; }
    .toolbar-actions button {
      font-family: var(--sans);
      font-size: 13px;
      font-weight: 700;
      padding: 9px 18px;
      border-radius: 3px;
      border: 1.5px solid var(--navy);
      background: var(--navy);
      color: #fff;
      cursor: pointer;
      white-space: nowrap;
    }
    .toolbar-actions button.secondary { background: #fff; color: var(--navy); }
    .toolbar-actions button:hover { opacity: 0.92; }

    /* ---- "Before you land" — own printable page (throwaway) ------------- */
    .prep {
      max-width: 210mm;
      min-height: 297mm;
      margin: 0 auto 24px;
      background: #fff;
      border: 1px solid #c0c0bc;
      border-radius: 4px;
      padding: 18mm 18mm 20mm;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.18);
      position: relative;
    }
    .prep::before {
      content: "";
      position: absolute;
      inset: 0;
      border: 1px dashed #b0b0aa;
      pointer-events: none;
      border-radius: 4px;
    }
    .prep h2 {
      font-family: var(--serif);
      font-size: 17px;
      color: var(--navy);
      margin-bottom: 4px;
    }
    .prep .lead {
      font-size: 13.5px;
      color: var(--ink-soft);
      margin-bottom: 14px;
      line-height: 1.5;
    }
    .prep ul {
      list-style: none;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px 22px;
    }
    @media (max-width: 720px) { .prep ul { grid-template-columns: 1fr; } }
    .prep li {
      display: grid;
      grid-template-columns: 18px 1fr;
      gap: 8px;
      font-size: 13px;
      line-height: 1.45;
      padding: 4px 0;
    }
    .prep li .box {
      width: 14px; height: 14px; margin-top: 3px;
      border: 1.5px solid var(--navy);
      border-radius: 2px;
    }
    .prep li strong { color: var(--ink); }
    .prep li em { font-style: normal; color: var(--ink-soft); }

    /* ---- THE PAGE itself (single A4) ------------------------------------- */
    .page {
      width: 210mm;
      min-height: 297mm;
      margin: 0 auto;
      padding: 10mm 10mm 12mm;
      background: #fff;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.18);
      position: relative;
    }
    .page::before {
      content: "";
      position: absolute;
      inset: 0;
      border: 1px dashed #b0b0aa;
      pointer-events: none;
    }
    .page-marker {
      position: absolute;
      top: -14px; left: 50%;
      transform: translateX(-50%);
      background: var(--navy);
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      padding: 4px 14px;
      border-radius: 999px;
    }

    /* ---- Editable field treatment (screen only) -------------------------- */
    [contenteditable="true"] {
      background: var(--edit-bg);
      border-bottom: 1.5px dotted var(--edit-line);
      padding: 0 3px;
      cursor: text;
      min-height: 1.1em;
      display: inline-block;
      min-width: 8mm;
    }
    [contenteditable="true"]:focus { outline: 2px solid var(--navy); outline-offset: 1px; background: #fff5b3; }
    [contenteditable="true"]:empty::before {
      content: attr(data-placeholder);
      color: #8a7900;
      font-style: italic;
      font-weight: 400;
    }

    /* ---- Header banner --------------------------------------------------- */
    .sheet-header {
      border: 2.5px solid var(--red);
      padding: 6px 10px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 14px;
      margin-bottom: 4mm;
    }
    .sheet-header .es {
      font-family: var(--serif);
      font-size: 17pt;
      font-weight: 700;
      color: var(--red);
      line-height: 1.05;
    }
    .sheet-header .en {
      font-family: var(--sans);
      font-size: 9pt;
      font-weight: 700;
      color: var(--ink);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      text-align: right;
      line-height: 1.25;
    }
    .sheet-header .en small { display: block; font-weight: 400; font-size: 8pt; color: var(--ink-soft); margin-top: 2px; text-transform: none; letter-spacing: 0; }

    /* ---- Section block titles ------------------------------------------- */
    .block { margin-bottom: 3.5mm; }
    .block-title {
      font-family: var(--sans);
      font-size: 8.5pt;
      text-transform: uppercase;
      letter-spacing: 1.3px;
      font-weight: 800;
      color: #fff;
      background: var(--navy);
      padding: 2px 8px;
      margin-bottom: 4px;
    }
    .block-title .en {
      font-weight: 500;
      letter-spacing: 0.5px;
      text-transform: none;
      opacity: 0.85;
      font-size: 7.5pt;
      margin-left: 6px;
    }

    /* ---- "My details" fillable block ------------------------------------- */
    .me-box {
      border: 1.5px dashed var(--ink);
      padding: 5px 8px;
      background: var(--bg-shade);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0 16px;
    }
    .me-box .row {
      display: flex;
      gap: 8px;
      align-items: baseline;
      padding: 2.5px 0;
    }
    .me-box .row + .row,
    .me-box .row { border-bottom: 1px dotted #aaa; }
    .me-box .row:last-child,
    .me-box .row:nth-last-child(2):nth-child(odd) { border-bottom: 0; }
    .me-box label {
      font-size: 7.5pt;
      font-weight: 800;
      color: var(--navy);
      text-transform: uppercase;
      letter-spacing: 0.6px;
      flex-shrink: 0;
      min-width: 24mm;
      line-height: 1.2;
    }
    .me-box label .en { display: block; font-weight: 500; color: var(--ink-soft); text-transform: none; letter-spacing: 0; font-size: 7pt; }
    .me-box .val { flex: 1; min-height: 12px; font-size: 9.5pt; font-weight: 700; line-height: 1.2; }

    /* ---- Hotel picker (dropdown + auto-fill display + Other inputs) ----- */
    .me-box .row.hotel-row {
      grid-column: 1 / -1;
      align-items: flex-start;
      padding-top: 4px;
      border-top: 1px solid #c8c8c2;
      margin-top: 2px;
      border-bottom: 0;
    }
    .hotel-val { display: block !important; }
    select.hotel-picker {
      font-family: var(--sans);
      font-size: 9pt;
      font-weight: 600;
      padding: 3px 24px 3px 6px;
      background: var(--edit-bg);
      border: 0;
      border-bottom: 1.5px dotted var(--edit-line);
      width: 100%;
      max-width: 100%;
      cursor: pointer;
      appearance: none;
      -webkit-appearance: none;
      background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6'><path fill='%238a7900' d='M0 0l5 6 5-6z'/></svg>");
      background-repeat: no-repeat;
      background-position: right 6px center;
    }
    select.hotel-picker:focus { outline: 2px solid var(--navy); outline-offset: 1px; }
    .hotel-display {
      margin-top: 3px;
      font-size: 9pt;
      line-height: 1.3;
      color: var(--ink);
    }
    .hotel-display .h-name { font-weight: 700; font-size: 9.5pt; }
    .hotel-display .h-addr { font-weight: 500; color: var(--ink-soft); font-size: 8.5pt; margin-top: 1px; }
    .hotel-display .h-phone { font-weight: 700; color: var(--red); margin-top: 1px; }
    .hotel-other { margin-top: 4px; display: grid; gap: 3px; }
    /* The HTML `hidden` attribute would otherwise be overridden by the
       `display: grid/block` rules above. Force it to win. */
    .hotel-other[hidden], .hotel-display[hidden] { display: none !important; }
    .hotel-other-row { display: flex; gap: 6px; align-items: baseline; }
    .hotel-other-label {
      font-size: 7.5pt;
      font-weight: 800;
      color: var(--navy);
      text-transform: uppercase;
      letter-spacing: 0.6px;
      min-width: 14mm;
    }
    .hotel-other-input { flex: 1; font-size: 9.5pt; font-weight: 700; min-height: 12px; }

    /* ---- Big call-this-number panel (911 + embassy) ---------------------- */
    .call-row { display: grid; grid-template-columns: 1fr 1fr; gap: 3mm; }
    .call {
      border: 2px solid var(--red);
      padding: 5px 8px;
      text-align: center;
    }
    .call .label-es { font-family: var(--serif); font-size: 10pt; font-weight: 700; color: var(--red); }
    .call .label-en { font-size: 7.5pt; color: var(--ink-soft); margin-bottom: 2px; }
    .call .num { font-family: var(--sans); font-size: 20pt; font-weight: 800; color: var(--ink); letter-spacing: 0.5px; line-height: 1.05; }
    .call .sub { font-size: 8pt; color: var(--ink-soft); margin-top: 1px; }

    /* ---- Address cards (hospital + selected embassy) --------------------- */
    .addr {
      border: 1.2px solid var(--ink);
      padding: 5px 9px;
    }
    .addr .flag {
      display: inline-block;
      font-size: 8pt;
      font-weight: 800;
      letter-spacing: 0.4px;
      color: #fff;
      background: var(--navy);
      padding: 1px 5px;
      margin-right: 5px;
      vertical-align: middle;
    }
    .addr.hospital .flag { background: var(--red-dark); }
    .addr h3 {
      font-family: var(--serif);
      font-size: 10pt;
      font-weight: 700;
      color: var(--ink);
      display: inline;
      vertical-align: middle;
      line-height: 1.2;
    }
    .addr .address {
      font-size: 9pt;
      font-weight: 600;
      color: var(--ink);
      margin-top: 3px;
      line-height: 1.3;
    }
    .addr .phone {
      font-size: 9.5pt;
      font-weight: 700;
      color: var(--red);
      margin-top: 2px;
    }

    .addr-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3mm; }

    /* ---- Quick-action box ------------------------------------------------ */
    .quick {
      border-left: 3px solid var(--red);
      background: var(--bg-shade);
      padding: 5px 9px;
      font-size: 8.5pt;
      line-height: 1.4;
      margin-bottom: 3mm;
    }
    .quick strong { color: var(--red-dark); }

    /* ---- Spanish phrases (compact, 3-col) -------------------------------- */
    .phrases { columns: 3; column-gap: 5mm; font-size: 8pt; }
    .phrases .ph { break-inside: avoid; padding: 2px 0; border-bottom: 1px dotted #ccc; }
    .phrases .ph .es { font-family: var(--serif); font-weight: 700; color: var(--ink); display: block; line-height: 1.2; }
    .phrases .ph .en { font-size: 7pt; color: var(--ink-soft); display: block; line-height: 1.2; }

    /* ---- Six rules (3-col compact) --------------------------------------- */
    .rules { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2mm 3mm; }
    .rule {
      border-left: 2.5px solid var(--red);
      padding: 2px 7px;
      background: var(--bg-shade);
      font-size: 7.5pt;
      line-height: 1.3;
    }
    .rule strong { display: block; font-size: 8pt; color: var(--red-dark); margin-bottom: 1px; }

    /* ---- Footer ---------------------------------------------------------- */
    .sheet-footer {
      margin-top: 3mm;
      padding-top: 3px;
      border-top: 1px solid var(--ink);
      font-size: 7pt;
      color: var(--ink-soft);
      display: flex;
      justify-content: space-between;
      gap: 16px;
    }

    /* ---- Embassy filtering: show only the selected one ------------------- */
    [data-embassy-card] { display: none; }
    [data-embassy-card].is-selected { display: block; }

    /* ------------------ PRINT RULES --------------------------------------- */
    @page {
      size: A4;
      margin: 8mm 8mm 10mm;
    }
    @media print {
      html, body { background: #fff; }
      body { padding: 0; }
      .screen-toolbar, .page-marker { display: none !important; }

      /* The pre-departure checklist becomes its own throwaway sheet,
         printed BEFORE the keepsake emergency card. */
      .prep {
        max-width: none;
        width: auto;
        margin: 0;
        padding: 0;
        background: #fff;
        border: 0;
        border-radius: 0;
        page-break-before: always;
      }
      .prep::before { display: none; }
      .prep h2 { font-family: var(--serif); font-size: 18pt; color: var(--ink); margin-bottom: 4px; }
      .prep .lead { font-size: 10pt; color: var(--ink-soft); margin-bottom: 10mm; }
      .prep ul { gap: 4mm 8mm; }
      .prep li { font-size: 10.5pt; line-height: 1.5; padding: 3px 0; }
      .prep li .box { width: 16px; height: 16px; border-width: 1.5px; }
      .prep::after {
        content: "Throwaway page — keep only the card from the previous sheet.";
        display: block;
        margin-top: 10mm;
        padding-top: 4mm;
        border-top: 1px solid #999;
        font-size: 8pt;
        font-style: italic;
        color: var(--ink-soft);
        text-align: center;
      }

      .page {
        width: auto;
        min-height: auto;
        margin: 0;
        padding: 0;
        box-shadow: none;
      }
      .page::before { display: none; }
      [contenteditable="true"] {
        background: transparent !important;
        border-bottom: none !important;
        padding: 0 !important;
      }
      [contenteditable="true"]:empty::before { content: ""; }
      /* Hotel picker on print: hide the dropdown UI; only the chosen
         hotel name + address + phone (or the typed Other values) prints. */
      select.hotel-picker { display: none !important; }
      .hotel-other-input { background: transparent !important; border-bottom: 0 !important; }
      a { color: inherit; text-decoration: none; }
    }

    @media (max-width: 860px) {
      .page { width: 100%; padding: 16px; box-shadow: none; }
      .me-box, .call-row, .addr-grid { grid-template-columns: 1fr; }
      .phrases { columns: 2; }
      .rules { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  {# ====================================================================
     SCREEN-ONLY TOOLBAR — clearly explains editability + embassy picker.
     ==================================================================== #}
  <div class="screen-toolbar">
    <div class="toolbar-head">
      <h1>Caracas Emergency Card — personalize, then print one page</h1>
      <p>
        Pick your embassy, click any <strong>highlighted field</strong> to type into it, then print.
      </p>
    </div>
    <div class="toolbar-body">
      <div>
        <label for="embassy-picker">Which embassy should appear on the card?</label>
        <select id="embassy-picker">
          {% for e in embassies_top %}
          <option value="{{ e.short }}"{% if loop.first %} selected{% endif %}>
            {{ e.country_en }} — {{ e.address_short }}
          </option>
          {% endfor %}
        </select>
      </div>
      <div class="toolbar-actions">
        <button type="button" class="secondary" onclick="resetFields()">Clear my info</button>
        <button type="button" onclick="window.print()">Print this card</button>
      </div>
    </div>
  </div>

  {# =====================================================================
     THE PRINTABLE PAGE — single A4 sheet (the keepsake card).
     ===================================================================== #}
  <article class="page">
    <header class="sheet-header">
      <div class="es">EMERGENCIA<br>POR FAVOR AYÚDEME</div>
      <div class="en">
        EMERGENCY · PLEASE HELP ME
        <small>Foreign visitor — please call a number below or take me to one of these addresses.</small>
      </div>
    </header>

    {# ---- WHO I AM (fillable) ---- #}
    <section class="block">
      <div class="block-title">Mis datos <span class="en">My details — type to fill</span></div>
      <div class="me-box">
        <div class="row"><label>Nombre <span class="en">Name</span></label><div class="val" contenteditable="true" data-field="name" data-placeholder="Jane Doe"></div></div>
        <div class="row"><label>Pasaporte <span class="en">Passport #</span></label><div class="val" contenteditable="true" data-field="passport" data-placeholder="123456789"></div></div>
        <div class="row"><label>Nacionalidad <span class="en">Nationality</span></label><div class="val" contenteditable="true" data-field="nationality" data-placeholder="USA"></div></div>
        <div class="row"><label>Sangre <span class="en">Blood type</span></label><div class="val" contenteditable="true" data-field="blood" data-placeholder="O+"></div></div>
        <div class="row"><label>Alergias / med. <span class="en">Allergies / meds</span></label><div class="val" contenteditable="true" data-field="medical" data-placeholder="Penicillin · diabetic"></div></div>
        <div class="row"><label>Contacto <span class="en">Home contact + WhatsApp</span></label><div class="val" contenteditable="true" data-field="home_contact" data-placeholder="John Doe · +1 415 555-0100"></div></div>

        <div class="row hotel-row">
          <label>Mi hotel <span class="en">My hotel — pick from list</span></label>
          <div class="val hotel-val">
            <select id="hotel-picker" class="hotel-picker">
              <option value="">— Pick from the list —</option>
              {% for h in hotels_picker %}
              <option
                value="{{ loop.index0 }}"
                data-name="{{ h.name }}"
                data-neighborhood="{{ h.neighborhood }}"
                data-address="{{ h.address }}"
                data-phone="{{ h.phone }}">{{ h.name }} ({{ h.neighborhood }})</option>
              {% endfor %}
              <option value="other">Other (type your own &darr;)</option>
            </select>
            <div class="hotel-display" id="hotel-display" hidden>
              <div class="h-name" id="hotel-display-name"></div>
              <div class="h-addr" id="hotel-display-addr"></div>
              <div class="h-phone" id="hotel-display-phone"></div>
            </div>
            <div class="hotel-other" id="hotel-other" hidden>
              <div class="hotel-other-row">
                <span class="hotel-other-label">Hotel</span>
                <span class="hotel-other-input" contenteditable="true" data-field="hotel_other_name" data-placeholder="Hotel name"></span>
              </div>
              <div class="hotel-other-row">
                <span class="hotel-other-label">Tel.</span>
                <span class="hotel-other-input" contenteditable="true" data-field="hotel_other_phone" data-placeholder="+58 212 ..."></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {# ---- BIG NUMBERS A STRANGER CAN DIAL ---- #}
    <section class="block">
      <div class="call-row">
        <div class="call">
          <div class="label-es">Emergencias locales</div>
          <div class="label-en">Local emergency services</div>
          <div class="num">911</div>
          <div class="sub">Policía · Ambulancia · Bomberos</div>
        </div>
        <div class="call">
          <div class="label-es">Mi embajada (24 h)</div>
          <div class="label-en">My embassy after-hours line</div>
          <div class="num" id="call-embassy-num">+1 202 501-4444</div>
          <div class="sub" id="call-embassy-sub">Estados Unidos</div>
        </div>
      </div>
    </section>

    {# ---- HOSPITAL + SELECTED EMBASSY ADDRESSES (Spanish, for taxi) ---- #}
    <section class="block">
      <div class="block-title">Lléveme aquí <span class="en">Take me to one of these addresses</span></div>
      <div class="addr-grid">
        {% for m in medical[:2] %}
        <div class="addr hospital">
          <span class="flag">HOSP</span>
          <h3>{{ m.name }}</h3>
          <div class="address">{{ m.neighborhood }}, Caracas</div>
          {% if m.phone %}<div class="phone">{{ m.phone }}</div>{% endif %}
        </div>
        {% endfor %}
      </div>
      <div style="margin-top: 3mm;">
        {% for e in embassies_top %}
        <div class="addr" data-embassy-card data-embassy-key="{{ e.short }}">
          <span class="flag">{{ e.short }}</span>
          <h3>Embajada de {{ e.country_es }}</h3>
          <div class="address">{{ e.address }}</div>
          {% if e.phone %}<div class="phone">{{ e.phone }}{% if e.after_hours and e.after_hours != e.phone %} · 24h: {{ e.after_hours }}{% endif %}</div>{% endif %}
        </div>
        {% endfor %}
      </div>
    </section>

    {# ---- WHAT TO DO (3 short scenarios) ---- #}
    <section class="block">
      <div class="quick">
        <strong>Crime / robbery:</strong> comply, hand over decoy wallet, then call your embassy and Crisis24 +1 877 484-1610. &nbsp;
        <strong>Medical:</strong> call International SOS +1 215 942-8478, then go to a private hospital above. &nbsp;
        <strong>Detained at GNB checkpoint:</strong> polite, no photos, present passport, do not sign anything, insist on embassy notification.
      </div>
    </section>

    {# ---- SIX RULES + ESSENTIAL PHRASES, side by side ---- #}
    <section class="block">
      <div class="block-title">Six rules <span class="en">non-negotiable</span></div>
      <div class="rules">
        <div class="rule"><strong>Never a street taxi</strong>Pre-arrange every car.</div>
        <div class="rule"><strong>Move 07:00–18:00</strong>All transfers in daylight.</div>
        <div class="rule"><strong>Low profile</strong>No watch, no jewellery, no DSLR, no phone in hand.</div>
        <div class="rule"><strong>Decoy wallet</strong>$20–40 to hand over.</div>
        <div class="rule"><strong>Comply at GNB</strong>No photos, no negotiation.</div>
        <div class="rule"><strong>Two-deep comms</strong>Itinerary &amp; check-ins to home twice daily.</div>
      </div>
    </section>

    <section class="block">
      <div class="block-title">Frases esenciales <span class="en">Essential Spanish phrases</span></div>
      <div class="phrases">
        <div class="ph"><span class="es">Necesito ayuda.</span><span class="en">I need help.</span></div>
        <div class="ph"><span class="es">Llame a la policía.</span><span class="en">Call the police.</span></div>
        <div class="ph"><span class="es">Llame a una ambulancia.</span><span class="en">Call an ambulance.</span></div>
        <div class="ph"><span class="es">Lléveme al hospital privado.</span><span class="en">Take me to the private hospital.</span></div>
        <div class="ph"><span class="es">Lléveme a mi embajada.</span><span class="en">Take me to my embassy.</span></div>
        <div class="ph"><span class="es">No hablo español.</span><span class="en">I don't speak Spanish.</span></div>
        <div class="ph"><span class="es">Necesito un médico.</span><span class="en">I need a doctor.</span></div>
        <div class="ph"><span class="es">Me robaron.</span><span class="en">I was robbed.</span></div>
        <div class="ph"><span class="es">Perdí mi pasaporte.</span><span class="en">I lost my passport.</span></div>
        <div class="ph"><span class="es">Llame a este número.</span><span class="en">Call this number.</span></div>
        <div class="ph"><span class="es">¿Cuánto cuesta? En dólares.</span><span class="en">How much? In dollars.</span></div>
        <div class="ph"><span class="es">Pare aquí, por favor.</span><span class="en">Stop here, please.</span></div>
      </div>
    </section>

    <footer class="sheet-footer">
      <span>Caracas Emergency Card · Updated {{ updated_label }} · Fold into passport.</span>
      <span>caracasresearch.com/travel/emergency-card</span>
    </footer>
  </article>

  {# =====================================================================
     PREP CHECKLIST — prints as its own throwaway page AFTER the card.
     ===================================================================== #}
  <div class="prep">
    <h2>Before you land — do these once, then throw this page away</h2>
    <p class="lead">
      The emergency card on the previous sheet only works if you've done the
      offline prep it depends on. Tick these off in the days before your
      flight, then bin this page — keep only the card.
    </p>
    <ul>
      <li><span class="box"></span><div><strong>Photocopy passport &amp; visa</strong> — carry one paper copy on you, leave one in the hotel safe, leave a third with a contact at home.</div></li>
      <li><span class="box"></span><div><strong>Hide emergency cash ($100–200)</strong> — inside a shoe insole, hidden bag pocket, or money belt. Small undamaged USD bills, post-2009 series.</div></li>
      <li><span class="box"></span><div><strong>Decoy wallet</strong> — $20–40 plus an expired card to hand over in a robbery.</div></li>
      <li><span class="box"></span><div><strong>Register with your embassy</strong> — US: STEP. UK: GOV.UK alerts. Canada: ROCA. Germany: Elefand. France: Ariane. Free, 5 minutes.</div></li>
      <li><span class="box"></span><div><strong>Confirm insurance covers Venezuela</strong> — in writing: medical evacuation, kidnap &amp; ransom, civil-unrest cancellation.</div></li>
      <li><span class="box"></span><div><strong>Pre-arrange airport transfer</strong> — book a marked vehicle through the hotel before you board. Never plan to find a taxi at SVMI.</div></li>
      <li><span class="box"></span><div><strong>Activate eSIM + install VPN</strong> — Airalo / Holafly Venezuela eSIM; ExpressVPN / Mullvad / Proton signed-in before takeoff.</div></li>
      <li><span class="box"></span><div><strong>Set up Zelle, bring USD cash</strong> — $200–500/wk in $1, $5, $10, $20. Undamaged, post-2009.</div></li>
      <li><span class="box"></span><div><strong>Download offline maps</strong> — Caracas in Google Maps, plus Maps.me / Organic Maps as a backup.</div></li>
      <li><span class="box"></span><div><strong>Two-deep comms</strong> — share itinerary + daily check-in plan with someone at home.</div></li>
      <li><span class="box"></span><div><strong>Fill out the card</strong> — name, passport, blood type, allergies, hotel and home contact in the previous sheet. It auto-saves.</div></li>
      <li><span class="box"></span><div><strong>Pick your embassy + print</strong> — choose your embassy in the toolbar above and print both sheets.</div></li>
    </ul>
  </div>

<script>
// --------- Editable-field persistence (localStorage) ---------
(function() {
  const KEY = 'caracas-emergency-card.v2';
  const fields = document.querySelectorAll('[contenteditable="true"][data-field]');
  let saved = {};
  try { saved = JSON.parse(localStorage.getItem(KEY) || '{}'); } catch (e) { saved = {}; }
  fields.forEach(function(el) {
    const name = el.getAttribute('data-field');
    if (saved[name]) el.textContent = saved[name];
    el.addEventListener('input', function() {
      saved[name] = el.textContent;
      try { localStorage.setItem(KEY, JSON.stringify(saved)); } catch (e) {}
    });
  });
  window.resetFields = function() {
    if (!confirm('Clear all your saved info on this card?')) return;
    fields.forEach(function(el) { el.textContent = ''; });
    try {
      localStorage.removeItem(KEY);
      localStorage.removeItem('caracas-emergency-card.hotel');
    } catch (e) {}
    const picker = document.getElementById('hotel-picker');
    if (picker) {
      picker.value = '';
      picker.dispatchEvent(new Event('change'));
    }
  };
})();

// --------- Hotel picker: pre-fill name / address / phone, with Other ---------
(function() {
  const KEY = 'caracas-emergency-card.hotel';
  const picker  = document.getElementById('hotel-picker');
  const display = document.getElementById('hotel-display');
  const dName   = document.getElementById('hotel-display-name');
  const dAddr   = document.getElementById('hotel-display-addr');
  const dPhone  = document.getElementById('hotel-display-phone');
  const otherEl = document.getElementById('hotel-other');
  if (!picker) return;

  function applySelection(persist) {
    const v = picker.value;
    if (v === '' || v === undefined) {
      display.hidden = true;
      otherEl.hidden = true;
    } else if (v === 'other') {
      display.hidden = true;
      otherEl.hidden = false;
    } else {
      const opt = picker.options[picker.selectedIndex];
      dName.textContent  = opt.dataset.name || '';
      dAddr.textContent  = [opt.dataset.address, opt.dataset.neighborhood].filter(Boolean).join(' · ');
      dPhone.textContent = opt.dataset.phone || '';
      display.hidden = false;
      otherEl.hidden = true;
    }
    if (persist !== false) { try { localStorage.setItem(KEY, v); } catch (e) {} }
  }

  // Restore prior choice.
  try {
    const saved = localStorage.getItem(KEY);
    if (saved) {
      for (const opt of picker.options) {
        if (opt.value === saved) { picker.value = saved; break; }
      }
    }
  } catch (e) {}
  applySelection(false);
  picker.addEventListener('change', function() { applySelection(true); });
})();

// --------- Embassy picker: show only the selected embassy ---------
(function() {
  const KEY = 'caracas-emergency-card.embassy';
  const picker = document.getElementById('embassy-picker');
  const cards = document.querySelectorAll('[data-embassy-card]');
  const callNum = document.getElementById('call-embassy-num');
  const callSub = document.getElementById('call-embassy-sub');
  if (!picker) return;

  // Load saved choice if present.
  try {
    const saved = localStorage.getItem(KEY);
    if (saved) {
      for (const opt of picker.options) {
        if (opt.value === saved) { picker.value = saved; break; }
      }
    }
  } catch (e) {}

  function applySelection() {
    const key = picker.value;
    cards.forEach(function(c) {
      c.classList.toggle('is-selected', c.getAttribute('data-embassy-key') === key);
    });
    const selectedCard = document.querySelector('[data-embassy-key="' + key + '"]');
    if (selectedCard && callNum && callSub) {
      const phone = selectedCard.querySelector('.phone');
      const heading = selectedCard.querySelector('h3');
      if (phone) callNum.textContent = (phone.textContent || '').split('·')[0].trim();
      if (heading) callSub.textContent = (heading.textContent || '').replace('Embajada de', '').trim();
    }
    try { localStorage.setItem(KEY, key); } catch (e) {}
  }
  picker.addEventListener('change', applySelection);
  applySelection();
})();
</script>
</body>
</html>
