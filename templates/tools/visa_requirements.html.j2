{% extends "_base.html.j2" %}

{% block head_extra %}
<style>
  .visa-form { display: flex; gap: 8px; margin: 20px 0; }
  .visa-form select { flex: 1; padding: 14px 18px; border: 2px solid var(--sr-blue); border-radius: 3px; font-size: 16px; }
  .visa-result { background: var(--white); border: 1px solid var(--sr-gray-light); border-radius: 4px; padding: 24px; margin: 20px 0; display: none; }
  .visa-result.active { display: block; }
  .visa-result h2 { font-family: var(--font-serif); color: var(--sr-blue-dark); font-size: 22px; margin-bottom: 8px; }
  .badge { display:inline-block; padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
  .badge.green { background: #e8f5e9; color: #1b4d1f; }
  .badge.red { background: #fdecea; color: #7a1f1a; }
  .field-row { display: grid; grid-template-columns: 180px 1fr; gap: 8px 16px; padding: 10px 0; border-bottom: 1px dotted var(--sr-gray-light); }
  .field-row .lbl { font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--sr-gray-text); padding-top: 2px; }
  .advisory { padding: 14px 18px; border-radius: 3px; margin: 16px 0; }
  .advisory.l4 { background: #fdecea; border-left: 4px solid var(--sr-red); }
  .advisory.l3 { background: #fff3e0; border-left: 4px solid #f5b041; }
  .advisory.l2 { background: #fff8e1; border-left: 4px solid #fbc02d; }
  .advisory.l1 { background: #e8f5e9; border-left: 4px solid #2e7d32; }
  .advisory .lvl { font-weight:700; }
  .investor-note { background: var(--sr-gray-bg); border-left: 4px solid var(--sr-blue); padding: 14px 18px; margin: 16px 0; font-size: 14px; }
  .timeline-pill { display: inline-flex; align-items: center; gap: 6px; background: #fff8e1; border: 1px solid #f5d27a; border-radius: 999px; padding: 4px 12px; font-size: 13px; font-weight: 700; color: #6b5612; line-height: 1.3; }
  .timeline-pill.green { background: #e8f5e9; border-color: #aed7b1; color: #1b4d1f; }
  .timeline-pill svg { width: 13px; height: 13px; flex-shrink: 0; }
  .timeline-detail { display: block; font-size: 13px; color: var(--sr-gray-text); margin-top: 6px; line-height: 1.55; }
  .apply-callout .apply-timeline { background: #fff; border: 1px solid #f1c5c0; border-left: 3px solid #f5b041; padding: 10px 14px; border-radius: 3px; margin: 10px 0 14px; font-size: 13.5px; color: var(--sr-dark-text); display: flex; align-items: center; gap: 10px; }
  .apply-callout .apply-timeline .apply-timeline-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.7px; font-weight: 700; color: #6b5612; }
  .apply-callout .apply-timeline .apply-timeline-value { font-weight: 700; color: var(--sr-dark-text); }
  .apply-callout { background: #fdf3f2; border: 1px solid #f1c5c0; border-left: 4px solid var(--sr-red); padding: 18px 20px; margin: 18px 0; border-radius: 4px; }
  .apply-callout .apply-head { font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: var(--sr-red); font-weight: 700; margin-bottom: 4px; }
  .apply-callout .apply-title { font-family: var(--font-serif); font-size: 20px; color: var(--sr-blue-dark); margin: 0 0 6px; }
  .apply-callout .apply-warning { background: #fff; border: 1px solid #f1c5c0; border-left: 3px solid var(--sr-red); padding: 10px 14px; border-radius: 3px; margin: 10px 0 14px; font-size: 13.5px; color: var(--sr-dark-text); }
  .apply-steps { list-style: none; counter-reset: step; padding: 0; margin: 12px 0 14px; }
  .apply-steps > li { display: grid; grid-template-columns: 38px 1fr; gap: 12px; padding: 12px 0; border-top: 1px dotted #e5b9b3; counter-increment: step; }
  .apply-steps > li:first-child { border-top: 0; padding-top: 4px; }
  .apply-steps .step-num { width: 30px; height: 30px; border-radius: 50%; background: var(--sr-red); color: #fff; font-family: var(--font-sans); font-weight: 700; font-size: 14px; display: flex; align-items: center; justify-content: center; line-height: 1; }
  .apply-steps .step-num::before { content: counter(step); }
  .apply-steps h4 { font-family: var(--font-sans); font-size: 14.5px; font-weight: 700; color: var(--sr-dark-text); margin: 4px 0 4px; }
  .apply-steps p { font-size: 13.5px; color: var(--sr-gray-text); margin: 0 0 6px; line-height: 1.55; }
  .apply-steps .step-cta-row { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-top: 4px; }
  .apply-steps .step-cta { display: inline-block; font-size: 13px; font-weight: 600; color: #fff; background: var(--sr-blue); padding: 6px 14px; border-radius: 999px; text-decoration: none; }
  .apply-steps .step-cta:hover { background: var(--sr-blue-dark); }
  .apply-steps .step-cta-embassy { background: #fff; color: var(--sr-blue); border: 1px solid var(--sr-blue); }
  .apply-steps .step-cta-embassy:hover { background: var(--sr-blue); color: #fff; }
  .apply-cta-row { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-top: 14px; }
  .apply-primary-cta { display: inline-block; background: var(--sr-red); color: #fff; padding: 11px 22px; border-radius: 3px; text-decoration: none; font-family: var(--font-sans); font-weight: 700; font-size: 14.5px; }
  .apply-primary-cta:hover { background: #a01d18; color: #fff; }
  .apply-secondary-cta { display: inline-block; padding: 11px 22px; border-radius: 3px; font-family: var(--font-sans); font-weight: 600; font-size: 14px; color: var(--sr-blue-dark); border: 1px solid var(--sr-blue); text-decoration: none; }
  .apply-secondary-cta:hover { background: var(--sr-blue); color: #fff; }
  @media (max-width: 480px) { .apply-cta-row { flex-direction: column; align-items: stretch; } .apply-primary-cta, .apply-secondary-cta { display: block; text-align: center; } }
</style>
{% endblock %}

{% block content %}
<section class="container">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <a href="/invest-in-venezuela">Invest in Venezuela</a><span>/</span>
    <span>Visa &amp; Entry Requirements Checker</span>
  </nav>

  <header style="margin: 16px 0 16px;">
    <div style="font-size:12px; text-transform:uppercase; letter-spacing:1.4px; color:#cc0000; font-weight:700;">
      Travel tool · Verified against embassy &amp; state-department sources
    </div>
    <h1 style="font-family:var(--font-serif); font-size:32px; color:var(--sr-blue-dark); margin:8px 0 10px;">
      Venezuela Visa &amp; Travel Requirements Checker
    </h1>
    <p style="font-family:var(--font-serif); font-style:italic; color:var(--sr-gray-text); font-size:17px;">
      Pick your passport country to see whether you need a visa, the maximum
      stay, the current US/UK travel-advisory level, and what investors should
      know before booking a trip to Caracas.
    </p>
  </header>

  <div class="visa-form">
    <select id="visa-country" aria-label="Passport country">
      <option value="">— Select your passport country —</option>
      {% for v in visas %}
      <option value="{{ v.code }}">{{ v.country }}</option>
      {% endfor %}
    </select>
  </div>

  {% for v in visas %}
  <div class="visa-result" id="r-{{ v.code }}" data-code="{{ v.code }}">
    <h2>{{ v.country }} citizens travelling to Venezuela</h2>
    <p>
      {% if v.visa_required %}
      <span class="badge red">Visa required</span>
      {% else %}
      <span class="badge green">Visa-free</span>
      {% endif %}
    </p>

    <div class="field-row"><div class="lbl">Visa type</div><div>{{ v.visa_type }}</div></div>
    <div class="field-row"><div class="lbl">Validity</div><div>{{ v.visa_validity }}</div></div>
    <div class="field-row"><div class="lbl">Maximum stay</div><div>{{ v.tourist_stay }}</div></div>
    {% if v.processing_time_summary %}
    <div class="field-row">
      <div class="lbl">Approval timeline</div>
      <div>
        <span class="timeline-pill {% if not v.visa_required %}green{% endif %}" title="{{ v.processing_time_detail or '' }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="9"/>
            <path d="M12 7v5l3 2"/>
          </svg>
          {{ v.processing_time_summary }}
        </span>
        {% if v.processing_time_detail %}
        <span class="timeline-detail">{{ v.processing_time_detail }}</span>
        {% endif %}
      </div>
    </div>
    {% endif %}
    <div class="field-row"><div class="lbl">Embassy / authority</div><div><a href="{{ v.embassy_url }}" rel="nofollow noopener" target="_blank">Verify with the official source &rarr;</a></div></div>

    {% if v.visa_required and v.visa_application_url %}
    <div class="apply-callout">
      <div class="apply-head">How to actually get the visa</div>
      <h3 class="apply-title">Step-by-step: applying for a Venezuela visa</h3>

      {% if v.visa_application_warning %}
      <div class="apply-warning">{{ v.visa_application_warning }}</div>
      {% endif %}

      {% if v.processing_time_summary %}
      <div class="apply-timeline">
        <svg viewBox="0 0 24 24" fill="none" stroke="#6b5612" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="width:18px;height:18px;flex-shrink:0;">
          <circle cx="12" cy="12" r="9"/>
          <path d="M12 7v5l3 2"/>
        </svg>
        <div>
          <div class="apply-timeline-label">Estimated approval timeline</div>
          <div><span class="apply-timeline-value">{{ v.processing_time_summary }}</span> — {{ v.processing_time_detail }}</div>
        </div>
      </div>
      {% endif %}

      {% if v.visa_application_steps %}
      <ol class="apply-steps">
        {% for step in v.visa_application_steps %}
        <li>
          <span class="step-num" aria-hidden="true"></span>
          <div>
            <h4>{{ step.title }}</h4>
            <p>{{ step.detail }}</p>
            {% if step.url %}
            <div class="step-cta-row">
              <a class="step-cta" href="{{ step.url }}" rel="nofollow noopener" target="_blank">{% if 'usembassy' in step.url %}Embassy Application Instructions{% else %}{{ step.url_label or 'Open the e-visa portal' }}{% endif %} &rarr;</a>
            </div>
            {% endif %}
            {% if 'supporting documents' in step.title|lower %}
            <div class="step-cta-row">
              <a class="step-cta" href="/apply-for-venezuelan-visa/planilla">Generate the Planilla PDF&rarr;</a>
              <a class="step-cta" href="/apply-for-venezuelan-visa/declaracion-jurada">Generate the Declaración Jurada PDF&rarr;</a>
            </div>
            {% endif %}
            {% if 'electronic application form' in step.title|lower or 'complete the' in step.title|lower %}
            <div class="step-cta-row">
              <a class="step-cta" href="/get-venezuela-visa">Same-Day Visa Application Service - Apply Online &rarr;</a>
            </div>
            {% endif %}
          </div>
        </li>
        {% endfor %}
      </ol>
      {% endif %}

      <div class="apply-cta-row">
        <a class="apply-primary-cta" href="{{ v.visa_application_url }}" rel="nofollow noopener" target="_blank">Open the e-visa portal &rarr;</a>
        <a class="apply-secondary-cta" href="{{ us_embassy_eguide_url }}" rel="nofollow noopener" target="_blank">Embassy Application Instructions &rarr;</a>
      </div>

      {# Cross-link to the dedicated /apply-for-venezuelan-visa pillar (or
         the country-specific variant when one exists). Keeps users who
         want a deeper, in-house walkthrough on-site instead of bouncing
         to the Spanish-only portal cold. #}
      {% set _apply_variants = {'US': '/apply-for-venezuelan-visa/us-citizens', 'CN': '/apply-for-venezuelan-visa/china'} %}
      {% set _apply_url = _apply_variants.get(v.code, '/apply-for-venezuelan-visa') %}
      <div style="margin-top: 14px; font-size: 13.5px; color: var(--sr-dark-text);">
        Want the full English walkthrough — documents, fees, timeline, FAQs?
        <a href="{{ _apply_url }}" style="font-weight: 600;">Open our Venezuela visa application guide &rarr;</a>
        Need the upload forms?
        <a href="/planilla-de-solicitud-de-visa" style="font-weight: 600;">Planilla de Solicitud de Visa</a>
        ·
        <a href="/declaracion-jurada-visa-venezolana" style="font-weight: 600;">Declaración Jurada</a>
      </div>
    </div>
    {% endif %}

    {% if v.advisory_level %}
    <div class="advisory l{{ v.advisory_level }}">
      <div><span class="lvl">Travel advisory level {{ v.advisory_level }}</span> — {{ v.advisory_summary }}</div>
      <div style="font-size:13px; margin-top:6px;"><a href="{{ v.advisory_url }}" rel="nofollow noopener" target="_blank" style="color: inherit;">Read the full advisory &rarr;</a></div>
    </div>
    {% endif %}

    <div class="investor-note"><strong>For investors:</strong> {{ v.investor_note }}</div>
  </div>
  {% endfor %}

  <p style="font-size:12px; color:var(--sr-gray-text); margin: 24px 0;">
    All entries verified against the official embassy network and home-country
    foreign-affairs ministry sources. Policy can change quickly — always
    re-verify with the linked official source within 14 days of travel.
    See related: <a href="/apply-for-venezuelan-visa">How To Apply For A Venezuelan Visa (2026)</a> ·
    <a href="/planilla-de-solicitud-de-visa">Planilla de Solicitud de Visa</a> ·
    <a href="/declaracion-jurada-visa-venezolana">Declaración Jurada</a> ·
    <a href="/invest-in-venezuela">how to invest in Venezuela</a> ·
    <a href="/sectors/tourism">Venezuela tourism sector</a>.
  </p>

  <script>
    (function() {
      var sel = document.getElementById('visa-country');
      var cards = document.querySelectorAll('.visa-result');
      sel.addEventListener('change', function() {
        cards.forEach(function(c) { c.classList.remove('active'); });
        if (sel.value) {
          var t = document.getElementById('r-' + sel.value);
          if (t) {
            t.classList.add('active');
            t.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });
      var hash = (location.hash || '').replace('#', '');
      if (hash) { sel.value = hash; sel.dispatchEvent(new Event('change')); }
    })();
  </script>

  {% from "_recent_briefings.html.j2" import recent_briefings_rail %}
  {{ recent_briefings_rail(
       recent_briefings,
       heading="Latest analysis",
       intro="Recent investor briefings on Venezuelan entry vehicles, diplomatic access, and sector conditions.",
  ) }}

</section>
{% endblock %}
