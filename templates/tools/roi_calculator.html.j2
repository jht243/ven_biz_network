{% extends "_base.html.j2" %}

{% block head_extra %}
<style>
  .calc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin: 24px 0; }
  @media (max-width: 800px) { .calc-grid { grid-template-columns: 1fr; } }
  .calc-card { background: var(--white); border: 1px solid var(--sr-gray-light); border-radius: 4px; padding: 22px; }
  .calc-card h2 { font-family: var(--font-serif); color: var(--sr-blue-dark); font-size: 18px; margin-bottom: 14px; }
  .field { margin-bottom: 14px; }
  .field label { display: block; font-size: 12px; text-transform: uppercase; letter-spacing: 0.7px; color: var(--sr-gray-text); margin-bottom: 4px; }
  .field input, .field select { width: 100%; padding: 10px 12px; border: 1px solid var(--sr-gray-light); border-radius: 3px; font-size: 14px; }
  .field .hint { font-size: 11px; color: var(--sr-gray-text); margin-top: 3px; }

  .result-headline { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; margin-bottom: 16px; }
  .res-card { background: var(--sr-gray-bg); padding: 14px; border-radius: 3px; text-align: center; border-left: 3px solid var(--sr-blue); }
  .res-card.bad { border-left-color: var(--sr-red); }
  .res-card.good { border-left-color: #2e7d32; }
  .res-card .lbl { font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--sr-gray-text); }
  .res-card .val { font-family: var(--font-serif); font-weight: 700; font-size: 20px; color: var(--sr-blue-dark); margin-top: 4px; }

  table.cf-table { width: 100%; border-collapse: collapse; font-size: 13px; margin-top: 8px; }
  table.cf-table th { background: var(--sr-blue); color: var(--white); padding: 8px 10px; text-align: right; font-size: 11px; text-transform: uppercase; }
  table.cf-table th:first-child, table.cf-table td:first-child { text-align: left; }
  table.cf-table td { padding: 7px 10px; border-bottom: 1px solid var(--sr-gray-light); text-align: right; font-variant-numeric: tabular-nums; }
  table.cf-table tr:last-child td { font-weight: 700; background: var(--sr-gray-bg); }

  .gate { margin-top: 24px; background: linear-gradient(135deg, var(--sr-blue) 0%, var(--sr-blue-dark) 100%); color: var(--white); padding: 24px; border-radius: 4px; }
  .gate h3 { font-family: var(--font-serif); font-size: 20px; margin-bottom: 6px; }
  .gate form { display: flex; gap: 8px; margin-top: 14px; }
  .gate input { flex: 1; padding: 12px 14px; border: none; border-radius: 3px; font-size: 14px; }
  .gate button { background: var(--white); color: var(--sr-blue-dark); border: none; padding: 12px 20px; font-weight: 700; cursor: pointer; border-radius: 3px; }

  .sector-context { background: var(--sr-gray-bg); border-left: 3px solid var(--sr-blue); padding: 12px 14px; font-size: 13px; color: var(--sr-dark-text); margin: 14px 0; }
</style>
{% endblock %}

{% block content %}
<section class="container-wide">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <a href="/invest-in-venezuela">Invest in Venezuela</a><span>/</span>
    <span>Investment ROI Calculator</span>
  </nav>

  <header style="margin: 16px 0 16px;">
    <div style="font-size:12px; text-transform:uppercase; letter-spacing:1.4px; color:#cc0000; font-weight:700;">
      Free tool · Risk-adjusted scenario modelling
    </div>
    <h1 style="font-family:var(--font-serif); font-size:32px; color:var(--sr-blue-dark); margin:8px 0 10px;">
      Venezuela Investment ROI Calculator
    </h1>
    <p style="font-family:var(--font-serif); font-style:italic; color:var(--sr-gray-text); font-size:17px; max-width: 820px;">
      Estimate the IRR, NPV, and multi-year cash flow of a hypothetical
      Venezuelan investment across oil &amp; gas, mining, real estate, banking,
      agriculture, telecom, and tourism — with sector-specific risk premiums
      built in.
    </p>
  </header>

  <div class="calc-grid">
    <div class="calc-card">
      <h2>Inputs</h2>
      <div class="field">
        <label for="sector">Sector</label>
        <select id="sector">
          <option value="oil_gas" data-rev="0.18" data-margin="0.30" data-rp="0.12">Oil &amp; Gas (high regulatory exposure)</option>
          <option value="mining" data-rev="0.16" data-margin="0.28" data-rp="0.11">Mining (gold, iron, bauxite)</option>
          <option value="real_estate" data-rev="0.10" data-margin="0.40" data-rp="0.08">Real Estate (Caracas commercial)</option>
          <option value="banking" data-rev="0.14" data-margin="0.20" data-rp="0.10">Banking &amp; Financial Services</option>
          <option value="agriculture" data-rev="0.12" data-margin="0.18" data-rp="0.07">Agriculture</option>
          <option value="telecom" data-rev="0.13" data-margin="0.25" data-rp="0.09">Telecom &amp; Digital</option>
          <option value="tourism" data-rev="0.11" data-margin="0.22" data-rp="0.06">Tourism &amp; Hospitality</option>
        </select>
        <div class="hint" id="sector-hint">Each sector ships with a baseline revenue growth rate, operating margin, and Venezuela-specific risk premium added to your discount rate.</div>
      </div>
      <div class="field">
        <label for="capex">Initial capital deployed (USD)</label>
        <input type="number" id="capex" value="2000000" min="10000" step="10000">
      </div>
      <div class="field">
        <label for="rev0">Year-1 revenue (USD)</label>
        <input type="number" id="rev0" value="800000" min="0" step="10000">
      </div>
      <div class="field">
        <label for="years">Holding period (years)</label>
        <input type="number" id="years" value="7" min="1" max="20" step="1">
      </div>
      <div class="field">
        <label for="growth">Annual revenue growth (override)</label>
        <input type="number" id="growth" value="" placeholder="auto from sector" step="0.01">
        <div class="hint">Decimal. e.g. 0.12 = 12%/yr. Leave blank to use sector default.</div>
      </div>
      <div class="field">
        <label for="margin">Operating margin (override)</label>
        <input type="number" id="margin" value="" placeholder="auto from sector" step="0.01">
        <div class="hint">Decimal. e.g. 0.30 = 30%.</div>
      </div>
      <div class="field">
        <label for="discount">Base discount rate (USD WACC)</label>
        <input type="number" id="discount" value="0.10" min="0" step="0.005">
        <div class="hint">Sector-specific Venezuela risk premium added on top.</div>
      </div>
      <div class="field">
        <label for="exit">Exit multiple on year-{n} EBITDA</label>
        <input type="number" id="exit" value="4" min="0" step="0.5">
      </div>
    </div>

    <div class="calc-card">
      <h2>Results</h2>
      <div class="result-headline">
        <div class="res-card" id="card-irr"><div class="lbl">IRR</div><div class="val" id="r-irr">—</div></div>
        <div class="res-card" id="card-npv"><div class="lbl">NPV (today)</div><div class="val" id="r-npv">—</div></div>
        <div class="res-card" id="card-mom"><div class="lbl">Money-on-money</div><div class="val" id="r-mom">—</div></div>
      </div>
      <div class="sector-context" id="risk-context">
        Risk-adjusted discount rate: <strong id="r-rate">—</strong>.
        Sector-specific Venezuela premium reflects sanctions exposure, FX
        convertibility risk, and regulatory volatility. See the
        <a href="/sectors/oil-gas" id="sector-link" style="color: var(--sr-blue);">sector landing page</a>
        for the underlying analysis.
      </div>
      <table class="cf-table" id="cf-table">
        <thead><tr><th>Year</th><th>Revenue</th><th>EBITDA</th><th>FCF</th><th>Disc. CF</th></tr></thead>
        <tbody></tbody>
      </table>
    </div>
  </div>

  <div class="gate">
    <h3>Get the full PDF investor model</h3>
    <p>Subscribe for the daily Caracas Research briefing and we'll email you a polished PDF version of this scenario, plus a Google Sheet you can fork.</p>
    <form id="gate-form">
      <input type="email" id="gate-email" placeholder="you@firm.com" required>
      <button type="submit">Send the model</button>
    </form>
    <div id="gate-msg" style="margin-top:8px; font-size:13px; min-height:18px;"></div>
  </div>

  <h2 style="font-family:var(--font-serif); color:var(--sr-blue-dark); margin: 32px 0 8px;">How this calculator works</h2>
  <p>The model projects a deterministic revenue/EBITDA/FCF schedule using the sector defaults you can override, applies an exit multiple to terminal-year EBITDA, then discounts every cash flow at your USD WACC plus a sector-specific Venezuela risk premium. The result is an order-of-magnitude estimate suitable for first-round filtering — not a substitute for a fully diligenced model with country-of-origin tax, FX repatriation friction, and project-finance structuring.</p>

  <h2 style="font-family:var(--font-serif); color:var(--sr-blue-dark); margin: 24px 0 8px;">Where the sector defaults come from</h2>
  <p>Defaults reflect publicly observed Venezuelan investment outcomes over the last decade plus contemporary EM-comp benchmarks. Risk premiums are anchored to traded Venezuelan sovereign-debt spreads (where available) and adjusted up or down by sector based on sanctions exposure, foreign-investor dispute history, and convertibility friction. See the <a href="/invest-in-venezuela">pillar guide</a> for the full methodology.</p>

  <p style="font-size:12px; color:var(--sr-gray-text); margin: 32px 0;">
    See related: <a href="/invest-in-venezuela">how to invest in Venezuela</a> ·
    <a href="/sectors/mining">sector landing pages</a> ·
    <a href="/tools/bolivar-usd-exchange-rate">bolivar/USD converter</a>.
  </p>

  <script>
    (function() {
      var fmt = function(n) {
        if (!isFinite(n)) return '—';
        return '$' + Math.round(n).toLocaleString('en-US');
      };
      var pct = function(n) {
        if (!isFinite(n)) return '—';
        return (n * 100).toFixed(1) + '%';
      };
      function irr(flows, guess) {
        guess = guess || 0.1;
        for (var i = 0; i < 200; i++) {
          var npv = 0, dnpv = 0;
          for (var t = 0; t < flows.length; t++) {
            var f = flows[t];
            var d = Math.pow(1 + guess, t);
            npv += f / d;
            dnpv += -t * f / Math.pow(1 + guess, t + 1);
          }
          var next = guess - npv / dnpv;
          if (!isFinite(next)) return null;
          if (Math.abs(next - guess) < 1e-7) return next;
          guess = next;
        }
        return guess;
      }
      function compute() {
        var sectorEl = document.getElementById('sector');
        var sectorOpt = sectorEl.options[sectorEl.selectedIndex];
        var defaultGrowth = parseFloat(sectorOpt.dataset.rev);
        var defaultMargin = parseFloat(sectorOpt.dataset.margin);
        var riskPremium = parseFloat(sectorOpt.dataset.rp);
        document.getElementById('sector-link').href = '/sectors/' + sectorEl.value.replace('_', '-');

        var capex = parseFloat(document.getElementById('capex').value || '0');
        var rev0 = parseFloat(document.getElementById('rev0').value || '0');
        var years = Math.max(1, Math.min(20, parseInt(document.getElementById('years').value || '7', 10)));
        var growth = parseFloat(document.getElementById('growth').value);
        if (!isFinite(growth)) growth = defaultGrowth;
        var margin = parseFloat(document.getElementById('margin').value);
        if (!isFinite(margin)) margin = defaultMargin;
        var discount = parseFloat(document.getElementById('discount').value || '0.1');
        var exitMult = parseFloat(document.getElementById('exit').value || '4');

        var rate = discount + riskPremium;
        document.getElementById('r-rate').textContent = pct(rate);

        var flows = [-capex];
        var rows = ['<tr><td>0</td><td></td><td></td><td>' + fmt(-capex) + '</td><td>' + fmt(-capex) + '</td></tr>'];

        var rev = rev0, totalNpv = -capex;
        var lastEbitda = 0;
        for (var y = 1; y <= years; y++) {
          if (y > 1) rev = rev * (1 + growth);
          var ebitda = rev * margin;
          var fcf = ebitda;
          if (y === years) fcf = ebitda + exitMult * ebitda;
          flows.push(fcf);
          var disc = fcf / Math.pow(1 + rate, y);
          totalNpv += disc;
          lastEbitda = ebitda;
          rows.push('<tr><td>' + y + '</td><td>' + fmt(rev) + '</td><td>' + fmt(ebitda) + '</td><td>' + fmt(fcf) + '</td><td>' + fmt(disc) + '</td></tr>');
        }

        var totalReturned = flows.slice(1).reduce(function(a, b) { return a + b; }, 0);
        var mom = capex > 0 ? totalReturned / capex : 0;
        var irrVal = irr(flows);

        document.getElementById('r-irr').textContent = pct(irrVal);
        document.getElementById('r-npv').textContent = fmt(totalNpv);
        document.getElementById('r-mom').textContent = mom.toFixed(2) + 'x';

        document.getElementById('card-irr').className = 'res-card ' + (irrVal > rate + 0.05 ? 'good' : (irrVal < rate ? 'bad' : ''));
        document.getElementById('card-npv').className = 'res-card ' + (totalNpv > 0 ? 'good' : 'bad');
        document.getElementById('card-mom').className = 'res-card ' + (mom > 2 ? 'good' : (mom < 1 ? 'bad' : ''));

        document.querySelector('#cf-table tbody').innerHTML = rows.join('');
      }
      ['sector','capex','rev0','years','growth','margin','discount','exit'].forEach(function(id) {
        document.getElementById(id).addEventListener('input', compute);
        document.getElementById(id).addEventListener('change', compute);
      });
      compute();

      document.getElementById('gate-form').addEventListener('submit', function(e) {
        e.preventDefault();
        var em = document.getElementById('gate-email').value;
        var msg = document.getElementById('gate-msg');
        msg.textContent = 'Sending…';
        fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: em, source: 'roi-calculator' })
        }).then(function(r) { return r.json(); }).then(function(j) {
          if (j.ok) msg.textContent = "You're in. Check your inbox shortly for the model — and the next briefing.";
          else msg.textContent = j.error || 'Something went wrong.';
        }).catch(function() { msg.textContent = 'Network error — try again.'; });
      });
    })();
  </script>

</section>
{% endblock %}
