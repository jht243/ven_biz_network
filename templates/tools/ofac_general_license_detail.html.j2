{% extends "_base.html.j2" %}

{% block head_extra %}
<style>
  .license-hero { margin: 16px 0 24px; }
  .license-kicker { font-size: 12px; text-transform: uppercase; letter-spacing: 1.4px; color: #cc0000; font-weight: 800; }
  .license-title { font-family: var(--font-serif); font-size: 34px; color: var(--sr-blue-dark); margin: 8px 0 10px; }
  .license-lede { font-family: var(--font-serif); font-style: italic; color: var(--sr-gray-text); font-size: 17px; max-width: 860px; }
  .license-layout { display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 28px; align-items: start; }
  .license-section { margin-bottom: 28px; }
  .license-section h2 { font-family: var(--font-serif); color: var(--sr-blue-dark); font-size: 22px; margin: 0 0 10px; }
  .license-section h3 { font-family: var(--font-serif); color: var(--sr-blue-dark); font-size: 17px; margin: 18px 0 8px; }
  .license-section p, .license-section li { font-size: 15px; line-height: 1.65; color: var(--sr-dark-text); }
  .license-section p { margin: 0 0 14px; }
  .license-section p:last-child { margin-bottom: 0; }
  .license-section ul { margin: 0 0 18px 20px; padding: 0; }
  .license-section li { margin-bottom: 7px; }
  .license-section li:last-child { margin-bottom: 0; }
  .detail-table { border: 1px solid var(--sr-gray-light); border-radius: 4px; overflow: hidden; background: #fff; }
  .detail-row { display: grid; grid-template-columns: 110px 1fr; gap: 14px; padding: 11px 14px; border-bottom: 1px solid var(--sr-gray-light); font-size: 14px; }
  .detail-row:last-child { border-bottom: 0; }
  .detail-row strong { color: var(--sr-blue-dark); }
  .source-card { border: 1px solid var(--sr-gray-light); border-top: 4px solid var(--sr-blue); padding: 16px; border-radius: 4px; background: #fff; }
  .source-card h2 { font-family: var(--font-serif); color: var(--sr-blue-dark); font-size: 18px; margin: 0 0 8px; }
  .source-card a { font-weight: 700; }
  .related-list { display: grid; gap: 8px; margin-top: 10px; }
  .related-list a { display: block; padding: 9px 10px; background: var(--sr-gray-bg); border-left: 3px solid var(--sr-blue); font-size: 13px; font-weight: 700; }
  @media (max-width: 860px) { .license-layout { grid-template-columns: 1fr; } }
</style>
{% endblock %}

{% block content %}
<section class="container">
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <a href="/tools">Tools</a><span>/</span>
    <a href="/tools/ofac-venezuela-general-licenses">OFAC Venezuela General Licenses</a><span>/</span>
    <span>{{ license.number }}</span>
  </nav>

  <header class="license-hero">
    <div class="license-kicker">OFAC Venezuela general license analysis</div>
    <h1 class="license-title">{{ license.number }}: {{ license.title }}</h1>
    <p class="license-lede">{{ license.seo_description }}</p>
  </header>

  <div class="license-layout">
    <main>
      <section class="license-section">
        <h2>License Details</h2>
        <div class="detail-table">
          {% for label, value in license.detail_rows %}
          <div class="detail-row"><strong>{{ label }}</strong><span>{{ value }}</span></div>
          {% endfor %}
        </div>
      </section>

      <section class="license-section">
        <h2>Plain-English Summary</h2>
        <p>{{ license.analysis.plain_english }}</p>
      </section>

      <section class="license-section">
        <h2>Our Analysis</h2>
        <p>{{ license.analysis.why_it_matters }}</p>
        {% if license.analysis.source_basis %}<p><strong>Source basis:</strong> {{ license.analysis.source_basis }}</p>{% endif %}

        {% if license.analysis.authorized_activity %}
        <h3>What the License Authorizes</h3>
        <ul>
          {% for item in license.analysis.authorized_activity %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>
        {% endif %}

        {% if license.analysis.limits %}
        <h3>What It Does Not Authorize</h3>
        <ul>
          {% for item in license.analysis.limits %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>
        {% endif %}

        {% if license.analysis.practical_analysis %}
        <h3>Practical Reading</h3>
        {% for paragraph in license.analysis.practical_analysis %}
        <p>{{ paragraph }}</p>
        {% endfor %}
        {% endif %}

        <h3>What to Check in the OFAC Text</h3>
        <ul>
          {% for item in license.analysis.review_items %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>

        <h3>Current Monitoring Signals</h3>
        <ul>
          {% for item in license.analysis.monitoring_items %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>

        {% for paragraph in license.analysis.current_context %}
        <p>{{ paragraph }}</p>
        {% endfor %}
      </section>

      <section class="license-section">
        <h2>Related OFAC Tools</h2>
        <p>
          Track related updates in the <a href="/sanctions-tracker">Venezuela sanctions tracker</a>,
          compare active licenses in the <a href="/tools/ofac-venezuela-general-licenses">general-license directory</a>,
          and screen counterparties with the <a href="/tools/ofac-venezuela-sanctions-checker">OFAC Venezuela sanctions checker</a>.
        </p>
      </section>
    </main>

    <aside>
      <div class="source-card">
        <h2>Primary Source</h2>
        <p>OFAC's text is the controlling source for scope, exclusions, and expiration.</p>
        <p><a href="{{ license.ofac_url }}" rel="nofollow noopener" target="_blank">Open official OFAC text &rarr;</a></p>
      </div>

      <div class="source-card" style="margin-top:18px;">
        <h2>Related Licenses</h2>
        <div class="related-list">
          {% for rel in related_licenses %}
          <a href="{{ rel.detail_url }}">{{ rel.number }}: {{ rel.title }}</a>
          {% endfor %}
        </div>
      </div>
    </aside>
  </div>

  {% from "_cluster_nav.html.j2" import cluster_nav %}
  {{ cluster_nav(cluster_ctx) }}

  {% from "_recent_briefings.html.j2" import recent_briefings_rail %}
  {{ recent_briefings_rail(
       recent_briefings,
       heading="Latest analysis",
       intro="Recent investor briefings on OFAC Venezuela-program actions, license activity, and enforcement signals.",
  ) }}
</section>
{% endblock %}
