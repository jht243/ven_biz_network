{% extends "_base.html.j2" %}

{% block head_extra %}
<style>
  .checker-form { display: flex; gap: 8px; margin: 20px 0; }
  .checker-form input { flex: 1; padding: 14px 18px; border: 2px solid var(--sr-blue); border-radius: 3px; font-size: 16px; }
  .checker-form button { background: var(--sr-blue); color: var(--white); border: none; padding: 14px 24px; font-size: 15px; font-weight: 600; cursor: pointer; border-radius: 3px; }
  .checker-form button:hover { background: var(--sr-blue-dark); }
  .result-banner { padding: 16px 20px; margin: 20px 0; border-radius: 3px; }
  .result-banner.match { background: #fdecea; border-left: 4px solid var(--sr-red); color: #7a1f1a; }
  .result-banner.clear { background: #e8f5e9; border-left: 4px solid #2e7d32; color: #1b4d1f; }
  .result-banner.partial { background: #fff3e0; border-left: 4px solid #f5b041; color: #7c4a03; }
  .result-banner h3 { font-family: var(--font-serif); margin-bottom: 4px; }
  .match-card { border: 1px solid var(--sr-gray-light); border-left: 4px solid var(--sr-red); padding: 14px 18px; margin-bottom: 10px; background: #fff8f7; border-radius: 3px; }
  .match-card .name { font-weight: 700; color: #7a1f1a; font-family: var(--font-serif); font-size: 16px; }
  .match-card .meta { font-size: 13px; color: var(--sr-gray-text); margin-top: 4px; }
  .match-card .remarks { font-size: 13px; margin-top: 6px; }
  .match-card .score { float: right; background: var(--sr-red); color: var(--white); padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 600; }
  .examples { font-size: 13px; color: var(--sr-gray-text); margin-top: 6px; }
  .examples a { margin-right: 12px; }
  .disclaimer { background: #fff3e0; border-left: 4px solid #f5b041; padding: 14px 18px; font-size: 13px; color: #7c4a03; margin: 24px 0; border-radius: 3px; }
</style>
{% endblock %}

{% block content %}
<section class="container">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <a href="/invest-in-venezuela">Invest in Venezuela</a><span>/</span>
    <span>OFAC Sanctions Exposure Checker</span>
  </nav>

  <header style="margin: 16px 0 20px;">
    <div style="font-size:12px; text-transform:uppercase; letter-spacing:1.4px; color:#cc0000; font-weight:700;">
      Compliance tool · Real-time check against {{ total_sdn }} SDN designations
    </div>
    <h1 style="font-family:var(--font-serif); font-size:32px; color:var(--sr-blue-dark); margin:8px 0 10px;">
      OFAC Venezuela Sanctions Exposure Checker
    </h1>
    <p style="font-family:var(--font-serif); font-style:italic; color:var(--sr-gray-text); font-size:17px;">
      Type the name of an individual, company, vessel, IMO number, aircraft tail
      number, or Venezuelan cédula. We search every Venezuela-related entry on
      the OFAC Specially Designated Nationals (SDN) list and surface fuzzy
      matches you should investigate before transacting.
    </p>
  </header>

  <form class="checker-form" method="get" action="/tools/ofac-venezuela-sanctions-checker">
    <input type="text" name="q" value="{{ query or '' }}" placeholder="e.g. PDVSA, Maduro, IMO 9432660, YV2954, V-1234567" autofocus required>
    <button type="submit">Check exposure</button>
  </form>

  <div class="examples">
    Try:
    <a href="?q=pdvsa">PDVSA</a>
    <a href="?q=cardon">Cardon</a>
    <a href="?q=YV2954">YV2954 (aircraft)</a>
    <a href="?q=9432660">IMO 9432660</a>
    <a href="?q=maduro">Maduro</a>
  </div>

  {% if query %}
    {% if matches and matches|length > 0 %}
    <div class="result-banner match">
      <h3>{{ matches|length }} potential match{% if matches|length != 1 %}es{% endif %} found</h3>
      <p>Review each match below carefully. Always verify with the underlying OFAC entry before making any compliance decision.</p>
    </div>
    {% for m in matches %}
    <article class="match-card">
      <span class="score">{{ m.score }}% match</span>
      <div class="name">{{ m.name }}</div>
      <div class="meta">
        <strong>Type:</strong> {{ m.type }} ·
        <strong>Program:</strong> {{ m.program or '—' }}
      </div>
      <div class="remarks">{{ m.remarks }}</div>
    </article>
    {% endfor %}
    {% else %}
    <div class="result-banner clear">
      <h3>No matches found</h3>
      <p>No entry on the Venezuela-related OFAC SDN list matched <strong>{{ query }}</strong>. This is not a substitute for a full OFAC compliance check — variant spellings, aliases, and ownership chains may still trigger sanctions exposure. Re-run with alternative spellings or browse the <a href="/sanctions-tracker">full SDN tracker</a>.</p>
    </div>
    {% endif %}
  {% endif %}

  <div class="disclaimer">
    <strong>Important:</strong> This tool searches our cached copy of the OFAC SDN
    list filtered for Venezuela-related programs. It uses a fuzzy match against
    name, alias, IMO, tail number, cédula, and remarks fields, but it does NOT
    perform full ownership-chain analysis (the OFAC 50% Rule), check non-SDN
    sectoral lists, or substitute for a vetted commercial sanctions-screening
    provider. For high-stakes counterparties, retain qualified sanctions
    counsel.
  </div>

  <p style="font-size:12px; color:var(--sr-gray-text); margin-bottom:32px;">
    See related: <a href="/sanctions-tracker">browse the full SDN list</a> ·
    <a href="/tools/ofac-venezuela-general-licenses">general license lookup</a> ·
    <a href="/sectors/sanctions">Venezuela sanctions sector page</a>.
  </p>

  {% from "_cluster_nav.html.j2" import cluster_nav %}
  {{ cluster_nav(cluster_ctx) }}

</section>
{% endblock %}
