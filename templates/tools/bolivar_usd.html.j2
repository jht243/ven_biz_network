{% extends "_base.html.j2" %}

{% block head_extra %}
<style>
  .ex-card { background: var(--white); border: 1px solid var(--sr-gray-light); border-radius: 4px; padding: 24px; margin: 20px 0; }
  .rate-headline { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; align-items: center; }
  .rate-headline .col { padding: 16px; border-radius: 3px; background: var(--sr-gray-bg); text-align: center; }
  .rate-headline .col.bcv { background: var(--sr-blue); color: var(--white); }
  .rate-headline .lbl { font-size: 12px; text-transform: uppercase; letter-spacing: 1px; opacity: 0.85; }
  .rate-headline .val { font-family: var(--font-serif); font-size: 36px; font-weight: 700; margin-top: 4px; }
  .rate-headline .sub { font-size: 12px; opacity: 0.85; margin-top: 4px; }
  .rate-error { background: #fff3e0; border-left: 4px solid #f5b041; padding: 14px 18px; font-size: 14px; color: #7c4a03; border-radius: 3px; }
  .converter { display: grid; grid-template-columns: 1fr auto 1fr; gap: 12px; align-items: end; margin: 24px 0 8px; }
  .converter label { display: block; font-size: 12px; text-transform: uppercase; letter-spacing: 0.7px; color: var(--sr-gray-text); margin-bottom: 4px; }
  .converter input, .converter select { width: 100%; padding: 12px 14px; border: 1px solid var(--sr-gray-light); border-radius: 3px; font-size: 16px; }
  .converter .arrow { font-size: 22px; color: var(--sr-blue); padding: 0 8px 12px; }
  .quick-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 8px; margin-top: 16px; }
  .quick-card { background: var(--sr-gray-bg); padding: 10px 12px; border-radius: 3px; text-align: center; }
  .quick-card .from { font-size: 12px; color: var(--sr-gray-text); }
  .quick-card .to { font-family: var(--font-serif); font-size: 17px; font-weight: 700; color: var(--sr-blue-dark); }
</style>
{% endblock %}

{% block content %}
<section class="container">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <a href="/invest-in-venezuela">Invest in Venezuela</a><span>/</span>
    <span>Bolivar / USD Exchange Rate</span>
  </nav>

  <header style="margin: 16px 0 16px;">
    <div style="font-size:12px; text-transform:uppercase; letter-spacing:1.4px; color:#cc0000; font-weight:700;">
      Live tool · Pulled from BCV homepage
    </div>
    <h1 style="font-family:var(--font-serif); font-size:32px; color:var(--sr-blue-dark); margin:8px 0 10px;">
      Venezuelan Bolívar (VES) to US Dollar Exchange Rate
    </h1>
    <p style="font-family:var(--font-serif); font-style:italic; color:var(--sr-gray-text); font-size:17px;">
      Today's official Banco Central de Venezuela (BCV) USD/VES rate, plus a
      free converter, Euro cross-rate, and the parallel-market context every
      Venezuelan-asset investor needs.
    </p>
  </header>

  <div class="ex-card">
    {% if rate_usd %}
    <div class="rate-headline">
      <div class="col bcv">
        <div class="lbl">Official BCV USD rate</div>
        <div class="val">Bs. {{ '%.4f' % rate_usd }}</div>
        <div class="sub">per US$1 · as of {{ rate_date }}</div>
      </div>
      <div class="col">
        <div class="lbl">Official BCV EUR rate</div>
        <div class="val" style="color:var(--sr-blue-dark);">Bs. {{ '%.4f' % rate_eur if rate_eur else '—' }}</div>
        <div class="sub">per €1 · as of {{ rate_date }}</div>
      </div>
    </div>

    <div class="converter">
      <div>
        <label for="amt">Amount</label>
        <input type="number" id="amt" value="100" min="0" step="any">
      </div>
      <div class="arrow">&rarr;</div>
      <div>
        <label for="dir">Convert</label>
        <select id="dir">
          <option value="usd_to_ves">USD &rarr; VES</option>
          <option value="ves_to_usd">VES &rarr; USD</option>
          <option value="eur_to_ves">EUR &rarr; VES</option>
          <option value="ves_to_eur">VES &rarr; EUR</option>
        </select>
      </div>
    </div>
    <div id="conv-result" style="text-align:center; font-family:var(--font-serif); font-size:24px; font-weight:700; color:var(--sr-blue-dark); margin-top:12px;"></div>

    <div class="quick-grid">
      {% for amt in [10, 100, 1000, 10000] %}
      <div class="quick-card">
        <div class="from">US${{ amt }}</div>
        <div class="to">Bs. {{ '{:,.2f}'.format(rate_usd * amt) }}</div>
      </div>
      {% endfor %}
    </div>

    <p style="font-size:12px; color:var(--sr-gray-text); margin-top:16px;">
      Source: <a href="https://www.bcv.org.ve" rel="nofollow noopener" target="_blank">Banco Central de Venezuela</a>.
      Refreshed each pipeline run; cached value below if the BCV site is unreachable.
    </p>

    <script>
      (function() {
        var rates = { usd: {{ rate_usd }}, eur: {{ rate_eur or 'null' }} };
        var amt = document.getElementById('amt');
        var dir = document.getElementById('dir');
        var out = document.getElementById('conv-result');
        function fmt(n, prefix, suffix) {
          if (!isFinite(n)) return '—';
          return prefix + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 4 }) + suffix;
        }
        function render() {
          var v = parseFloat(amt.value || '0');
          var d = dir.value;
          if (d === 'usd_to_ves') out.textContent = fmt(v * rates.usd, 'Bs. ', '');
          else if (d === 'ves_to_usd') out.textContent = fmt(v / rates.usd, 'US$', '');
          else if (d === 'eur_to_ves') out.textContent = rates.eur ? fmt(v * rates.eur, 'Bs. ', '') : 'EUR rate unavailable';
          else if (d === 'ves_to_eur') out.textContent = rates.eur ? fmt(v / rates.eur, '€', '') : 'EUR rate unavailable';
        }
        amt.addEventListener('input', render);
        dir.addEventListener('change', render);
        render();
      })();
    </script>
    {% else %}
    <div class="rate-error">
      Live BCV rate unavailable right now (the BCV homepage is intermittently
      reachable from outside Venezuela). The rate refreshes every pipeline run;
      try again in a few hours, or browse the most recent published value on
      the <a href="https://www.bcv.org.ve" rel="nofollow noopener" target="_blank">official BCV site</a>.
    </div>
    {% endif %}
  </div>

  <h2 style="font-family:var(--font-serif); color:var(--sr-blue-dark); margin: 32px 0 8px;">Why two exchange rates matter</h2>
  <p>Venezuela operates under a managed-float regime. The Banco Central de Venezuela publishes the <strong>official BCV rate</strong>, used for taxes, customs, public-sector transactions, and compulsory trade settlement. A separate <strong>parallel rate</strong> emerges from informal currency trading and typically diverges from the official rate during periods of currency stress. Investors must understand both to value Venezuelan assets, settle import bills, or repatriate dividends.</p>

  <h2 style="font-family:var(--font-serif); color:var(--sr-blue-dark); margin: 32px 0 8px;">Currency convertibility for foreign investors</h2>
  <p>Capital repatriation in foreign currency requires registration with the BCV and approval against existing exchange-control regulations. New investments since the partial liberalisation of 2019 have benefited from streamlined treatment, but FX availability for repatriation remains the single biggest operational risk for foreign investors. Always include explicit FX-availability language in joint-venture agreements and quote portfolio returns in USD-equivalent terms.</p>

  <p style="font-size:12px; color:var(--sr-gray-text); margin: 32px 0;">
    See related: <a href="/invest-in-venezuela">how to invest in Venezuela</a> ·
    <a href="/sectors/banking">Venezuela banking sector page</a> ·
    <a href="/briefing">latest BCV-related briefings</a>.
  </p>

  {% from "_recent_briefings.html.j2" import recent_briefings_rail %}
  {{ recent_briefings_rail(
       recent_briefings,
       heading="Latest analysis",
       intro="Recent investor briefings on the bolivar, BCV policy, and Venezuelan banking.",
  ) }}

</section>
{% endblock %}
