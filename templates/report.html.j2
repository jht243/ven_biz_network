                    data-share-url="{% if entry.blog_slug %}https://caracasresearch.com/briefing/{{ entry.blog_slug }}{% else %}https://caracasresearch.com/#dev-{{ entry.id }}{% endif %}"
                    data-share-title="{{ (entry.headline_short or entry.headline) | e }}"
                    aria-label="Share this development">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
              </svg>
              <span class="share-btn-label">Share</span>
            </button>
          </div>
          {% if entry.body_text %}
          <button class="detail-toggle" onclick="toggleDetail(this)" style="margin-top:8px;"><span>&#9662;</span> Read Original Source Extract</button>
          <div class="detail-content">{{ entry.body_text }}</div>
          {% endif %}
        </div>
      </div>
