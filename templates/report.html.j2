    </div>
  </div>

  <!-- LATEST DEVELOPMENTS -->
  <div class="panel-box" style="margin-bottom: 8px;">
    <div class="panel-header">
      <h3>Latest Developments</h3>
      <select class="sector-select" id="sectorFilter">
        <option value="all">All Sectors</option>
        {% for sector in all_sectors %}
        <option value="{{ sector.value }}">{{ sector.label }}</option>
        {% endfor %}
      </select>
    </div>
    <div class="entries-container">
      {% for entry in entries %}
      <div class="entry" id="dev-{{ entry.id }}" data-sectors="{{ entry.sectors_str }}">
        <div class="entry-header">
          <div class="pill-row">
            <span class="category-label">{{ entry.category_label }}</span>
            {% if entry.is_new %}<span class="badge-new">New</span>{% endif %}
            <span class="status-pill status-{{ entry.status_class }}"><span class="status-dot"></span> {{ entry.status_label }}</span>
          </div>
          <h3>{{ entry.headline_short or entry.headline }}</h3>
          {% if entry.headline_short and entry.headline_short != entry.headline %}
          <div class="original-headline" lang="es" title="Original source headline">{{ entry.headline }}</div>
          {% endif %}
          <div class="entry-meta">
            <span>{{ entry.date_display }}</span>
            <span>|</span>
            <a href="{{ entry.source_url }}" target="_blank">{{ entry.source_display }} &rarr;</a>
            <span class="source-trust trust-{{ entry.trust_class }}">{{ entry.trust_label }}</span>
          </div>
        </div>
        <div class="entry-body">
          <div class="takeaway-header">
            <span>Investment Impact</span>
            <span class="sentiment-badge sentiment-{{ entry.sentiment }}">
              {% if entry.sentiment == 'positive' %}&#9650; Favorable
              {% elif entry.sentiment == 'negative' %}&#9660; Unfavorable
              {% else %}&#9672; Mixed{% endif %}
            </span>
          </div>
          <div class="takeaway">{{ entry.takeaway }}</div>
          <div class="entry-actions" style="margin-top:10px; display:flex; align-items:center; gap:14px; flex-wrap:wrap;">
            {% if entry.blog_slug %}
