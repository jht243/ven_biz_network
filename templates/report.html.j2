<script>
// Mobile nav toggle. The hamburger button is the only way to reach the
// nav links on screens <=768px, so this script is required, not nice-to-have.
(function initNavToggle() {
  var btn = document.querySelector('.top-nav .nav-toggle');
  var nav = document.querySelector('.top-nav');
  if (!btn || !nav) return;
  function setOpen(open) {
    nav.classList.toggle('is-open', open);
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  }
  btn.addEventListener('click', function() {
    setOpen(!nav.classList.contains('is-open'));
  });
  nav.querySelectorAll('.nav-links a').forEach(function(a) {
    a.addEventListener('click', function() { setOpen(false); });
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') setOpen(false);
  });
})();

// Give "Read full analysis" links instant visual feedback when clicked
// so the reader sees something happen even while the next page loads.
// We don't preventDefault — navigation still proceeds normally.
document.querySelectorAll('.full-analysis-link a').forEach(function(a) {
  a.addEventListener('click', function() {
    a.classList.add('is-loading');
  });
});

// Share buttons on each "Latest Developments" entry. On mobile (or any
// browser exposing navigator.share) we open the native share sheet; on
// desktop we copy to the clipboard and show a toast.
(function initShareButtons() {
  var toastEl = null;
  function showToast(msg) {
    if (!toastEl) {
      toastEl = document.createElement('div');
      toastEl.className = 'share-toast';
      document.body.appendChild(toastEl);
    }
    toastEl.textContent = msg;
    requestAnimationFrame(function() { toastEl.classList.add('is-visible'); });
    clearTimeout(toastEl._hideTimer);
    toastEl._hideTimer = setTimeout(function() {
      toastEl.classList.remove('is-visible');
    }, 1600);
  }
  function flashCopied(btn) {
    var label = btn.querySelector('.share-btn-label');
    var prev = label ? label.textContent : null;
    btn.classList.add('copied');
    if (label) label.textContent = 'Copied';
    setTimeout(function() {
      btn.classList.remove('copied');
      if (label && prev !== null) label.textContent = prev;
    }, 1600);
  }
  function copyToClipboard(text) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      return navigator.clipboard.writeText(text);
    }
    return new Promise(function(resolve, reject) {
      try {
        var ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        resolve();
      } catch (err) { reject(err); }
    });
  }
  document.querySelectorAll('.share-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var url = btn.getAttribute('data-share-url');
      var title = btn.getAttribute('data-share-title') || 'Caracas Research';
      if (!url) return;
      // Prefer the native share sheet on mobile / supported browsers.
      if (navigator.share) {
        navigator.share({ title: title, url: url }).catch(function() {
          // User cancelled or share failed — silently fall back to copy.
          copyToClipboard(url).then(function() {
            flashCopied(btn);
            showToast('Link copied');
          }).catch(function() {});
        });
        return;
      }
      copyToClipboard(url).then(function() {
        flashCopied(btn);
        showToast('Link copied');
      }).catch(function() {
        showToast('Could not copy link');
      });
    });
  });
})();

function toggleDetail(btn) {
  const content = btn.nextElementSibling;
  content.classList.toggle('open');
  const span = btn.querySelector('span');
  if (content.classList.contains('open')) {
    span.innerHTML = '&#9652;';
    btn.innerHTML = btn.innerHTML.replace('Read Original', 'Hide Original');
  } else {
    span.innerHTML = '&#9662;';
    btn.innerHTML = btn.innerHTML.replace('Hide Original', 'Read Original');
  }
}

document.querySelectorAll('.news-link').forEach(link => {
  link.addEventListener('click', function(e) {
    e.preventDefault();
    const targetId = this.getAttribute('href').slice(1);
    const target = document.getElementById(targetId);
    if (!target) return;
    const dropdown = document.getElementById('sectorFilter');
    if (dropdown.value !== 'all') {
      dropdown.value = 'all';
      dropdown.dispatchEvent(new Event('change'));
    }
    target.scrollIntoView({ behavior: 'smooth', block: 'center' });
    target.classList.remove('highlight');
    void target.offsetWidth;
    target.classList.add('highlight');
  });
});

document.getElementById('sectorFilter').addEventListener('change', function() {
  const filter = this.value;
  const isAll = filter === 'all';
  document.querySelectorAll('.entry').forEach(entry => {
    if (isAll) {
      entry.classList.remove('hidden');
    } else {
      const sectors = entry.dataset.sectors || '';
      entry.classList.toggle('hidden', !sectors.includes(filter));
    }
  });
});

function handleSignup(e) {
  e.preventDefault();
  const form = e.target;
  const input = form.querySelector('input');
  const btn = form.querySelector('button');
  const email = input.value.trim();
  if (!email) return;

  btn.disabled = true;
  btn.textContent = 'Subscribing...';

  fetch('/api/subscribe', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email: email })
  })
  .then(r => r.json())
  .then(data => {
    if (data.ok) {
      form.innerHTML = '<div style="color: white; font-size: 1.1rem; padding: 14px 0;">\u2713 You\'re in. Watch your inbox.</div>';
    } else {
      btn.disabled = false;
      btn.textContent = 'Subscribe';
      alert(data.error || 'Something went wrong. Please try again.');
    }
  })
  .catch(() => {
    btn.disabled = false;
    btn.textContent = 'Subscribe';
    alert('Network error. Please try again.');
  });
}

const climateObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      document.querySelectorAll('.bar-fill').forEach(bar => {
        bar.style.width = bar.dataset.width + '%';
      });
      climateObserver.unobserve(entry.target);
    }
  });
}, { threshold: 0.3 });

const climateBox = document.getElementById('climateBox');
if (climateBox) climateObserver.observe(climateBox);
</script>

</body>
</html>
