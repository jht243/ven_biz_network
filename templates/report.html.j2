<!-- INVESTMENT CLIMATE TRACKER -->
<div class="climate-panel">
  <div class="climate-box" id="climateBox">
    <div class="climate-header">
      <h3>Investment Climate Tracker</h3>
      <span class="climate-period">{{ climate.period }}</span>
    </div>
    <div class="climate-bars">
      {% for bar in climate.bars %}
      <div class="bar-item">
        <div class="bar-top">
          <span class="bar-label">{{ bar.label }}</span>
          <div class="bar-right">
            <span class="bar-score">{{ bar.score }}/10</span>
            <span class="bar-trend trend-{{ bar.trend_dir }}">{% if bar.trend_dir == 'up' %}&#9650;{% elif bar.trend_dir == 'down' %}&#9660;{% else %}&mdash;{% endif %} {{ bar.trend_value }}</span>
          </div>
        </div>
        <div class="bar-track"><div class="bar-fill bar-{{ bar.bar_color }}" data-width="{{ bar.score * 10 }}"></div></div>
        <div class="bar-why">{{ bar.why }}</div>
      </div>
      {% endfor %}
    </div>
    <div class="climate-footer">
      <strong>Methodology:</strong> {{ climate.methodology }}
    </div>
  </div>

  <!-- NEWS + CALENDAR -->
