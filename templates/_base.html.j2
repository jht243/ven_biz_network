{#
  Shared base layout for non-report pages (blog posts, blog index,
  pillar / sector / sanctions / tools). Inherits the visual identity of
  the home report — Libre Baskerville + Open Sans + the navy/red palette
  — but slim, server-side rendered, and gzip-friendly (no embedded report
  CSS bloat).
#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {% set _seo = seo|default({}) %}
  <title>{{ _seo.title|default('Caracas Research') }}</title>
  <meta name="description" content="{{ _seo.description|default('') }}">
  {% if _seo.keywords %}<meta name="keywords" content="{{ _seo.keywords }}">{% endif %}
  {% if _seo.news_keywords %}<meta name="news_keywords" content="{{ _seo.news_keywords }}">{% endif %}
  <meta name="author" content="{{ _seo.site_name|default('Caracas Research') }}">
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1">
  <link rel="canonical" href="{{ _seo.canonical|default('') }}">
  <link rel="alternate" hreflang="en" href="{{ _seo.canonical|default('') }}">
  <link rel="alternate" hreflang="x-default" href="{{ _seo.canonical|default('') }}">

  <meta property="og:type" content="{{ _seo.og_type|default('article') }}">
  <meta property="og:site_name" content="{{ _seo.site_name|default('Caracas Research') }}">
  <meta property="og:locale" content="{{ _seo.locale|default('en_US') }}">
  <meta property="og:url" content="{{ _seo.canonical|default('') }}">
  <meta property="og:title" content="{{ _seo.title|default('') }}">
  <meta property="og:description" content="{{ _seo.description|default('') }}">
  <meta property="og:image" content="{{ _seo.og_image|default('') }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  {% if _seo.published_iso %}<meta property="article:published_time" content="{{ _seo.published_iso }}">{% endif %}
  {% if _seo.modified_iso %}<meta property="article:modified_time" content="{{ _seo.modified_iso }}">{% endif %}
  {% if _seo.section %}<meta property="article:section" content="{{ _seo.section }}">{% endif %}
  {% for tag in _seo.article_tags|default([]) %}<meta property="article:tag" content="{{ tag }}">
  {% endfor %}

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ _seo.title|default('') }}">
  <meta name="twitter:description" content="{{ _seo.description|default('') }}">
  <meta name="twitter:image" content="{{ _seo.og_image|default('') }}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">

  {% if jsonld %}
  <script type="application/ld+json">{{ jsonld | safe }}</script>
  {% endif %}

  <style>
    :root {
      --sr-blue: #002b5e;
      --sr-blue-dark: #001f44;
      --sr-red: #cc0000;
      --sr-gray-bg: #f8f9fa;
      --sr-gray-light: #e9ecef;
      --sr-gray-text: #6c757d;
      --sr-dark-text: #212529;
      --white: #ffffff;
      --font-serif: 'Libre Baskerville', 'Times New Roman', Times, serif;
      --font-sans: 'Open Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-sans); background: var(--white); color: var(--sr-dark-text); line-height: 1.65; font-size: 17px; -webkit-font-smoothing: antialiased; }
    a { color: var(--sr-blue); text-decoration: underline; text-decoration-color: var(--sr-gray-light); text-underline-offset: 3px; }
    a:hover { color: var(--sr-red); text-decoration-color: var(--sr-red); }
    /* Top-nav styling — kept identical to templates/report.html.j2 so the
       header looks the same on every page (homepage, tools, briefings…). */
    .top-nav { background-color: var(--sr-blue); color: var(--white); padding: 12px 0; font-family: var(--font-sans); }
    .top-nav-inner { max-width: 1140px; margin: 0 auto; padding: 0 20px; display: flex; justify-content: space-between; align-items: center; }
    .nav-brand { font-family: var(--font-serif); font-size: 1.25rem; font-weight: 700; letter-spacing: 0.5px; color: var(--white); text-decoration: none; display: flex; align-items: center; gap: 12px; line-height: 1; }
    .nav-brand svg.brand-logo { width: 30px; height: 30px; flex-shrink: 0; display: block; }
    .nav-links { display: flex; align-items: center; gap: 24px; font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; line-height: 1; }
    .nav-links a { color: var(--white); text-decoration: none; transition: opacity 0.2s; display: inline-flex; align-items: center; }
    .nav-links a:hover { opacity: 0.8; }
    .nav-login { background: var(--sr-red); padding: 8px 16px; border-radius: 3px; line-height: 1; }
    /* Hamburger button — hidden on desktop, shown on <=768px to expose nav-links. */
    .nav-toggle { display: none; background: transparent; border: 0; padding: 8px; margin: -8px -4px -8px 0; cursor: pointer; -webkit-tap-highlight-color: transparent; }
    .nav-toggle-bar { display: block; width: 24px; height: 2px; background: var(--white); border-radius: 2px; margin: 5px 0; transition: transform 0.2s ease, opacity 0.15s ease; }
    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(2) { opacity: 0; }
    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    @media (max-width: 768px) {
      .top-nav-inner { flex-wrap: wrap; }
      .nav-toggle { display: block; }
      .nav-links { display: none; flex-direction: column; align-items: stretch; width: 100%; gap: 0; margin-top: 12px; padding-top: 6px; border-top: 1px solid rgba(255,255,255,0.18); font-size: 0.95rem; }
      .nav-links a { padding: 14px 4px; border-bottom: 1px solid rgba(255,255,255,0.08); }
      .nav-links a:last-child { border-bottom: 0; }
      .nav-login { display: inline-block; align-self: flex-start; margin-top: 10px; padding: 10px 18px; }
      .top-nav.is-open .nav-links { display: flex; }
    }

    .container { max-width: 760px; margin: 0 auto; padding: 0 24px; }
    .container-wide { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

    /* Breadcrumbs row — turned into a flex container so the auto-injected
       share button sits flush-right on the same line. */
    .breadcrumbs { font-size: 13px; color: var(--sr-gray-text); margin: 24px 0 12px; display: flex; align-items: center; flex-wrap: wrap; gap: 6px; }
    .breadcrumbs a { color: var(--sr-gray-text); }
    .breadcrumbs span { margin: 0 0; }
    .breadcrumbs .breadcrumb-share { margin-left: auto; }

    article header h1 { font-family: var(--font-serif); font-size: 38px; line-height: 1.2; color: var(--sr-blue-dark); margin: 12px 0; font-weight: 700; }
    article header .subtitle { font-family: var(--font-serif); font-style: italic; font-size: 20px; color: var(--sr-gray-text); margin-bottom: 18px; }
    article header .meta { font-size: 13px; color: var(--sr-gray-text); border-top: 1px solid var(--sr-gray-light); border-bottom: 1px solid var(--sr-gray-light); padding: 12px 0; margin-bottom: 28px; display: flex; gap: 18px; flex-wrap: wrap; }
    article header .meta strong { color: var(--sr-dark-text); }

    article .body h2 { font-family: var(--font-serif); font-size: 24px; color: var(--sr-blue-dark); margin: 32px 0 12px; font-weight: 700; }
    article .body h3 { font-family: var(--font-serif); font-size: 19px; color: var(--sr-blue-dark); margin: 24px 0 10px; }
    article .body p { margin: 0 0 16px; }
    article .body ul, article .body ol { margin: 0 0 16px 24px; }
    article .body li { margin-bottom: 8px; }
    article .body blockquote { border-left: 3px solid var(--sr-red); padding: 4px 16px; margin: 20px 0; color: var(--sr-gray-text); font-style: italic; font-family: var(--font-serif); }

    .takeaways { background: var(--sr-gray-bg); border-left: 3px solid var(--sr-blue); padding: 18px 22px; margin: 24px 0 32px; }
    .takeaways h3 { font-family: var(--font-serif); font-size: 16px; color: var(--sr-blue-dark); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; }
    .takeaways ul { margin-left: 20px; }
    .takeaways li { margin-bottom: 6px; font-size: 15px; }

    .source-citation { background: #fff8e1; border-left: 3px solid #f5b041; padding: 14px 18px; margin: 24px 0; font-size: 14px; color: var(--sr-dark-text); }
    .source-citation a { font-weight: 600; }

    .related { margin: 48px 0 24px; padding-top: 24px; border-top: 1px solid var(--sr-gray-light); }
    .related h3 { font-family: var(--font-serif); font-size: 18px; color: var(--sr-blue-dark); margin-bottom: 12px; }
    .related ul { list-style: none; }
    .related li { padding: 8px 0; border-bottom: 1px dotted var(--sr-gray-light); }
    .related li a { font-weight: 600; color: var(--sr-blue); text-decoration: none; }
    .related li small { color: var(--sr-gray-text); margin-left: 8px; }

    .index-grid { display: grid; grid-template-columns: 1fr; gap: 22px; margin: 24px 0 48px; }
    @media (min-width: 720px) { .index-grid { grid-template-columns: 1fr 1fr; } }
    .index-card { position: relative; background: var(--white); border: 1px solid var(--sr-gray-light); border-radius: 4px; padding: 20px 22px; transition: border-color 0.15s, transform 0.15s; cursor: pointer; }
    .index-card:hover { border-color: var(--sr-blue); transform: translateY(-1px); }
    .index-card:hover a.title-link { color: var(--sr-red); }
    .index-card a.card-link { position: absolute; inset: 0; z-index: 1; text-indent: -9999px; overflow: hidden; border-radius: 4px; }
    .index-card a.card-link:focus-visible { outline: 2px solid var(--sr-blue); outline-offset: 2px; }
    .index-card a.title-link { position: relative; z-index: 2; font-family: var(--font-serif); font-weight: 700; font-size: 20px; color: var(--sr-blue-dark); text-decoration: none; line-height: 1.3; display: block; margin-bottom: 8px; pointer-events: none; }
    .index-card .meta { font-size: 12px; color: var(--sr-gray-text); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
    .index-card .summary { font-size: 14px; color: var(--sr-dark-text); line-height: 1.55; }

    .footer-cta { background: var(--sr-gray-bg); border-top: 1px solid var(--sr-gray-light); padding: 32px 24px; text-align: center; margin-top: 64px; }
    .footer-cta h3 { font-family: var(--font-serif); color: var(--sr-blue-dark); margin-bottom: 8px; font-size: 22px; }
    .footer-cta p { color: var(--sr-gray-text); margin-bottom: 16px; }
    .footer-cta a.btn { display: inline-block; background: var(--sr-red); color: var(--white); padding: 10px 24px; border-radius: 3px; text-decoration: none; font-weight: 600; font-size: 14px; letter-spacing: 0.5px; text-transform: uppercase; }

    .site-footer { background: var(--sr-blue-dark); color: rgba(255,255,255,0.7); padding: 24px; text-align: center; font-size: 13px; }
    .site-footer a { color: rgba(255,255,255,0.85); text-decoration: none; margin: 0 8px; }

    /* Share button — same look & behavior as on the homepage report cards.
       Used across every sub-page (blog post, landing, tools, calendar…). */
    .share-btn { background: transparent; border: 1px solid var(--sr-gray-light); border-radius: 999px; padding: 6px 14px; font-family: var(--font-sans); font-size: 12px; font-weight: 600; color: var(--sr-gray-text); cursor: pointer; display: inline-flex; align-items: center; gap: 6px; line-height: 1; transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease; text-decoration: none; }
    .share-btn:hover { color: var(--sr-blue); border-color: var(--sr-blue); }
    .share-btn:active { transform: scale(0.97); }
    .share-btn.copied { color: #166534; border-color: #166534; background: #f0fdf4; }
    .share-btn svg { display: block; }
    /* Page-level share row sits flush-right above the headline, matching
       the visual weight of the "By Caracas Research" meta line. */
    .page-share-row { display: flex; justify-content: flex-end; margin: 4px 0 -4px; }
    /* Toast — bottom-center floating pill, ~1.6s. */
    .share-toast { position: fixed; bottom: 32px; left: 50%; transform: translateX(-50%) translateY(20px); background: var(--sr-blue-dark); color: var(--white); padding: 10px 20px; border-radius: 999px; font-family: var(--font-sans); font-size: 13px; font-weight: 600; letter-spacing: 0.3px; box-shadow: 0 8px 24px rgba(0,0,0,0.18); opacity: 0; pointer-events: none; transition: opacity 0.2s ease, transform 0.2s ease; z-index: 9999; }
    .share-toast.is-visible { opacity: 1; transform: translateX(-50%) translateY(0); }
  </style>
  {% block head_extra %}{% endblock %}
</head>
<body>

<nav class="top-nav">
  <div class="top-nav-inner">
    <a class="nav-brand" href="/">{% include "_brand_logo.svg" %}Caracas Research</a>
    <button type="button" class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="primary-nav">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
    <div class="nav-links" id="primary-nav">
      <a href="/briefing">Analysis</a>
      <a href="/invest-in-venezuela">Invest</a>
      <a href="/sanctions-tracker">Sanctions</a>
      <a href="/tools">Tools</a>
      <a href="/explainers">Explainers</a>
      <a href="/travel">Travel</a>
      <a href="/#signup" class="nav-login">Subscribe Free</a>
    </div>
  </div>
</nav>

{# Reusable share button macro. Pages call {{ share_button(url, title) }}
   anywhere they want to render a Share affordance. The global script
   below wires up navigator.share / clipboard fallback. #}
{% macro share_button(url, title, label='Share') -%}
<button type="button" class="share-btn"
        data-share-url="{{ url }}"
        data-share-title="{{ title|e }}"
        aria-label="Share this page">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
    <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
  </svg>
  <span class="share-btn-label">{{ label }}</span>
</button>
{%- endmacro %}

{% block content %}{% endblock %}

<div class="footer-cta">
  <h3>Get the daily briefing in your inbox</h3>
  <p>Twice-daily Venezuelan business intelligence — sanctions, regulatory, sector analysis.</p>
  <a class="btn" href="/#newsletter">Subscribe free</a>
</div>

<footer class="site-footer">
  &copy; {{ current_year|default(2026) }} Caracas Research ·
  <a href="/sitemap.xml">Sitemap</a>
</footer>

<script>
// Mobile nav toggle. The hamburger button is the only way to reach the
// nav links on screens <=768px, so this script is required, not nice-to-have.
(function initNavToggle() {
  var btn = document.querySelector('.top-nav .nav-toggle');
  var nav = document.querySelector('.top-nav');
  if (!btn || !nav) return;
  function setOpen(open) {
    nav.classList.toggle('is-open', open);
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  }
  btn.addEventListener('click', function() {
    setOpen(!nav.classList.contains('is-open'));
  });
  nav.querySelectorAll('.nav-links a').forEach(function(a) {
    a.addEventListener('click', function() { setOpen(false); });
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') setOpen(false);
  });
})();

// Auto-inject a Share button into every breadcrumbs row. This means tools,
// calendar, sanctions tracker, blog index, etc. all get a consistent share
// affordance without per-template edits. Pages can still place additional
// .share-btn elements anywhere they want.
(function autoInjectBreadcrumbShare() {
  var canonicalEl = document.querySelector('link[rel="canonical"]');
  var canonical = (canonicalEl && canonicalEl.getAttribute('href')) || window.location.href;
  var title = document.title || 'Caracas Research';
  document.querySelectorAll('nav.breadcrumbs').forEach(function(crumbs) {
    if (crumbs.querySelector('.share-btn')) return;
    var btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'share-btn breadcrumb-share';
    btn.setAttribute('data-share-url', canonical);
    btn.setAttribute('data-share-title', title);
    btn.setAttribute('aria-label', 'Share this page');
    btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' +
      '<circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>' +
      '<line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>' +
      '</svg><span class="share-btn-label">Share</span>';
    crumbs.appendChild(btn);
  });
})();

// Share button handler — used by any .share-btn on this page (page header,
// inline buttons, breadcrumbs auto-injected, etc.). On mobile / browsers
// exposing navigator.share we open the native share sheet; on desktop we
// copy the canonical URL and show a "Link copied" toast. Falls back to
// window.location.href when no data-share-url is provided.
(function initShareButtons() {
  var toastEl = null;
  function showToast(msg) {
    if (!toastEl) {
      toastEl = document.createElement('div');
      toastEl.className = 'share-toast';
      document.body.appendChild(toastEl);
    }
    toastEl.textContent = msg;
    requestAnimationFrame(function() { toastEl.classList.add('is-visible'); });
    clearTimeout(toastEl._hideTimer);
    toastEl._hideTimer = setTimeout(function() {
      toastEl.classList.remove('is-visible');
    }, 1600);
  }
  function flashCopied(btn) {
    var label = btn.querySelector('.share-btn-label');
    var prev = label ? label.textContent : null;
    btn.classList.add('copied');
    if (label) label.textContent = 'Copied';
    setTimeout(function() {
      btn.classList.remove('copied');
      if (label && prev !== null) label.textContent = prev;
    }, 1600);
  }
  function copyToClipboard(text) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      return navigator.clipboard.writeText(text);
    }
    return new Promise(function(resolve, reject) {
      try {
        var ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        resolve();
      } catch (err) { reject(err); }
    });
  }
  document.querySelectorAll('.share-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var url = btn.getAttribute('data-share-url') || window.location.href;
      var title = btn.getAttribute('data-share-title') || document.title;
      if (navigator.share) {
        navigator.share({ title: title, url: url }).catch(function() {
          copyToClipboard(url).then(function() {
            flashCopied(btn);
            showToast('Link copied');
          }).catch(function() {});
        });
        return;
      }
      copyToClipboard(url).then(function() {
        flashCopied(btn);
        showToast('Link copied');
      }).catch(function() {
        showToast('Could not copy link');
      });
    });
  });
})();
</script>
</body>
</html>
