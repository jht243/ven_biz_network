  .disclaimer { background: #fff8e1; border-left: 4px solid #f5b041; padding: 14px 18px; border-radius: 3px; margin: 20px 0; font-size: 13.5px; line-height: 1.65; color: var(--sr-dark-text); }

  .callout { background: #f4f8fb; border: 1px solid #cfdce8; border-left: 5px solid var(--sr-blue); padding: 18px 22px; border-radius: 4px; margin: 20px 0 24px; }
  .callout h4 { font-family: var(--font-serif); font-size: 16px; color: var(--sr-blue-dark); margin: 0 0 8px; }
  .callout p { font-size: 14px; color: var(--sr-dark-text); margin: 0; line-height: 1.6; }

