{% block head_extra %}
<style>
  .oil-hero { background: linear-gradient(180deg, #f4f8fc 0%, var(--white) 100%); padding: 28px 0 16px; margin-bottom: 16px; }
  .oil-hero .kicker { font-size: 12px; text-transform: uppercase; letter-spacing: 1.4px; color: var(--sr-blue); font-weight: 700; }
  .oil-hero h1 { font-family: var(--font-serif); font-size: 32px; color: var(--sr-blue-dark); margin: 8px 0 8px; line-height: 1.2; }
  .oil-hero p.lead { font-family: var(--font-serif); font-style: italic; color: var(--sr-gray-text); font-size: 16px; max-width: 720px; margin: 0; }

  .stat-banner { display: grid; grid-template-columns: 1fr; gap: 0; margin: 20px 0 28px; border: 1px solid #d0dae8; border-radius: 6px; overflow: hidden; }
  @media (min-width: 640px) { .stat-banner { grid-template-columns: 1fr 1fr 1fr; } }
  .stat-banner .stat { padding: 18px 22px; text-align: center; border-bottom: 1px solid #d0dae8; }
  @media (min-width: 640px) { .stat-banner .stat { border-bottom: 0; border-right: 1px solid #d0dae8; } .stat-banner .stat:last-child { border-right: 0; } }
  .stat-banner .stat-num { font-family: var(--font-serif); font-size: 28px; font-weight: 700; color: var(--sr-blue-dark); line-height: 1.1; }
  .stat-banner .stat-label { font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: var(--sr-gray-text); margin-top: 4px; font-weight: 600; }
