{% extends "_base.html.j2" %}
{% from "_card_grid.html.j2" import card_grid_section %}

{% block head_extra %}
<style>
  .re-hero { padding: 28px 0 18px; border-bottom: 1px solid var(--sr-gray-light); }
  .re-kicker { font-size: 12px; text-transform: uppercase; letter-spacing: 1.4px; color: var(--sr-red); font-weight: 700; }
  .re-hero h1 { font-family: var(--font-serif); color: var(--sr-blue-dark); font-size: 40px; line-height: 1.15; margin: 8px 0 12px; }
  .re-subtitle { font-family: var(--font-serif); font-style: italic; color: var(--sr-gray-text); font-size: 19px; max-width: 820px; }
  .re-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 18px; }
  .re-btn { display: inline-flex; align-items: center; justify-content: center; min-height: 42px; padding: 10px 16px; border-radius: 3px; border: 1px solid var(--sr-blue); text-decoration: none; font-weight: 700; font-size: 13px; text-transform: uppercase; letter-spacing: .4px; }
  .re-btn-primary { background: var(--sr-red); border-color: var(--sr-red); color: #fff; }
  .re-btn-secondary { background: #fff; color: var(--sr-blue); }
  .re-band { margin: 30px 0; }
  .re-band h2 { font-family: var(--font-serif); color: var(--sr-blue-dark); font-size: 25px; margin: 0 0 12px; }
  .re-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; }
  .re-stat { border-left: 3px solid var(--sr-blue); background: var(--sr-gray-bg); padding: 14px 16px; }
  .re-stat strong { display:block; font-family: var(--font-serif); color: var(--sr-blue-dark); font-size: 24px; line-height: 1.2; }
  .re-stat span { font-size: 12px; color: var(--sr-gray-text); text-transform: uppercase; letter-spacing: .6px; }
  .re-table { width: 100%; border-collapse: collapse; font-size: 14px; }
  .re-table th { background: var(--sr-blue); color: #fff; text-align: left; padding: 9px 10px; font-size: 12px; text-transform: uppercase; letter-spacing: .4px; }
  .re-table td { border-bottom: 1px solid var(--sr-gray-light); padding: 10px; vertical-align: top; }
  .re-table tr:nth-child(even) td { background: var(--sr-gray-bg); }
  .re-checklist { margin-left: 20px; }
  .re-form { background: #f4f8fc; border: 1px solid #cfddee; border-left: 4px solid var(--sr-blue); padding: 18px; border-radius: 3px; }
  .re-form-grid { display:grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 10px; }
  .re-form label { display:block; font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:.6px; color:var(--sr-blue-dark); margin-bottom:4px; }
  .re-form input, .re-form select, .re-form textarea { width:100%; padding:11px 12px; border:1px solid #b9c7d8; border-radius:3px; font-family:var(--font-sans); font-size:14px; background:#fff; }
  .re-form button { margin-top: 12px; padding: 12px 18px; border:0; border-radius:3px; background:var(--sr-red); color:#fff; font-weight:700; text-transform:uppercase; letter-spacing:.5px; cursor:pointer; }
  .re-note { font-size: 13px; color: var(--sr-gray-text); }
  @media (max-width: 640px) { .re-hero h1 { font-size: 32px; } }
</style>
{% endblock %}

{% block content %}
<article class="container-wide">
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    {% if page_kind != 'landing' %}<a href="/real-estate/">Real Estate</a><span>/</span>{% endif %}
    <span>{{ h1 }}</span>
  </nav>

  <header class="re-hero">
    <div class="re-kicker">Caracas Research Real Estate</div>
    <h1>{{ h1 }}</h1>
    <p class="re-subtitle">{{ subtitle }}</p>
    <div class="re-actions">
      <a class="re-btn re-btn-primary" href="/real-estate/buyers-guide/">Get the Free Buyer Brief</a>
      <a class="re-btn re-btn-secondary" href="/real-estate/properties/">Browse Sample Listings</a>
    </div>
  </header>

  {% if direct_answer %}
  <section class="re-band">
    <h2>{{ answer_heading|default('Overview') }}</h2>
    <p>{{ direct_answer }}</p>
  </section>
  {% endif %}

  {% if stats %}
  <section class="re-band">
    <h2>Current market price snapshot</h2>
    <div class="re-grid">
      <div class="re-stat"><strong>{{ stats.count }}</strong><span>Listings sampled</span></div>
      <div class="re-stat"><strong>${{ "{:,.0f}".format(stats.median_price) }}</strong><span>Median asking price</span></div>
      <div class="re-stat"><strong>${{ "{:,.0f}".format(stats.median_ppm2) }}</strong><span>Median price per m²</span></div>
      <div class="re-stat"><strong>${{ "{:,.0f}".format(stats.low_price) }}–${{ "{:,.0f}".format(stats.high_price) }}</strong><span>Asking range</span></div>
    </div>
    <p class="re-note" style="margin-top:10px;">{{ methodology }}</p>
  </section>
  {% endif %}

  {% if city_price_rows %}
  <section class="re-band">
    <h2>Price ranges by city</h2>
    <div style="overflow-x:auto;">
      <table class="re-table">
        <thead><tr><th>City</th><th>Sample</th><th>Median asking</th><th>Median $/m²</th><th>Range</th><th>Neighborhoods</th></tr></thead>
        <tbody>
          {% for row in city_price_rows %}
          <tr>
            <td><a href="/real-estate/{{ row.slug }}/">{{ row.city }}</a></td>
            <td>{{ row.stats.count }}</td>
            <td>${{ "{:,.0f}".format(row.stats.median_price) }}</td>
            <td>${{ "{:,.0f}".format(row.stats.median_ppm2) }}</td>
            <td>${{ "{:,.0f}".format(row.stats.low_price) }}–${{ "{:,.0f}".format(row.stats.high_price) }}</td>
            <td>{{ row.stats.neighborhoods|join(", ") }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
  {% endif %}

  {% if content_sections %}
  {% for section in content_sections %}
  <section class="re-band">
    <h2>{{ section[0] }}</h2>
    <p>{{ section[1] }}</p>
  </section>
  {% endfor %}
  {% endif %}

  {% if source_notes %}
  <section class="re-band">
    <h2>Research notes and sources</h2>
    <div class="re-grid">
      {% for source in source_notes %}
      <div class="re-stat">
        <strong style="font-size:17px;"><a href="{{ source.url }}" rel="nofollow noopener" target="_blank">{{ source.label }}</a></strong>
        <p style="font-size:13px; color:var(--sr-gray-text); margin:6px 0 0;">{{ source.note }}</p>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {% if city_page %}
  <section class="re-band">
    <h2>Popular neighborhoods</h2>
    <ul class="re-checklist">
      {% for n in city_page.neighborhoods %}<li>{{ n }}</li>{% endfor %}
    </ul>
  </section>
  {% endif %}

  <section class="re-band">
    <h2>Buyer risk checklist</h2>
    <ul class="re-checklist">
      <li>Verify ownership, title chain, liens, and registry documentation.</li>
      <li>Confirm seller identity and authority to sell before paying any deposit.</li>
      <li>Screen counterparties and payment intermediaries for sanctions exposure.</li>
      <li>Inspect building condition, utilities, parking, water, and condominium debt.</li>
      <li>Compare price per m² against similar sampled listings before negotiating.</li>
    </ul>
  </section>

  {% if featured_listings %}
  {% set cards = [] %}
  {% for p in featured_listings %}
    {% set _ = cards.append({
      'href': '/real-estate/property/' ~ p.slug ~ '/',
      'eyebrow': p.city ~ ' · ' ~ p.property_type,
      'title': p.title,
      'tagline': p.english_summary,
      'meta_rows': ['$' ~ "{:,.0f}".format(p.price_usd), p.square_meters ~ ' m²', '$' ~ "{:,.0f}".format(p.price_per_m2) ~ '/m²'],
      'cta': 'View property'
    }) %}
  {% endfor %}
  {{ card_grid_section(
       heading='Featured property listings',
       meta=(featured_listings|length|string) ~ ' sampled listings',
       intro='Translated sample listings organized for foreign-buyer research. Each listing still requires independent verification.',
       cards=cards,
       aria_label='Featured real estate listings',
       footer_link={'href': '/real-estate/properties/', 'label': 'Browse all sample listings'},
       footer_mode='always'
  ) }}
  {% endif %}

  {% if guide_cards %}
  {{ card_grid_section(
       heading='Popular real estate guides',
       cards=guide_cards,
       aria_label='Popular Venezuela real estate guides',
       footer_link={'href': '/real-estate/venezuela-homes-for-sale/', 'label': 'See more real estate guides'},
       footer_mode='always',
       max_cards=3
  ) }}
  {% endif %}

  {% if faq %}
  <section class="re-band">
    <h2>Frequently asked questions</h2>
    {% for q, a in faq %}
    <details {% if loop.first %}open{% endif %} style="border:1px solid #d8dde6; border-left:3px solid var(--sr-blue); border-radius:3px; padding:12px 16px; margin-bottom:8px;">
      <summary style="font-family:var(--font-serif); color:var(--sr-blue-dark); font-weight:700; cursor:pointer;">{{ q }}</summary>
      <p style="margin-top:10px;">{{ a }}</p>
    </details>
    {% endfor %}
  </section>
  {% endif %}

  <section class="re-band re-form" id="buyer-brief">
    <h2>Get the Free Buyer Brief</h2>
    <p>Receive the Venezuela Property Buyer Brief for Americans & Canadians.</p>
    <form method="post" action="/real-estate/thanks">
      <div class="re-form-grid">
        <div><label for="email">Email</label><input id="email" name="email" type="email" required></div>
        <div><label for="first-name">First name</label><input id="first-name" name="first_name" type="text"></div>
        <div><label for="buyer-type">Buyer type</label><select id="buyer-type" name="buyer_type"><option>Investor</option><option>Diaspora buyer</option><option>Relocation buyer</option><option>Just researching</option></select></div>
        <div><label for="budget">Budget range</label><select id="budget" name="budget"><option>Under $50k</option><option>$50k-$100k</option><option>$100k-$250k</option><option>$250k+</option><option>Not sure</option></select></div>
      </div>
      <button type="submit">Get the Free Buyer Brief</button>
    </form>
  </section>

  <section class="related">
    <h3>Related Caracas Research resources</h3>
    <ul>
      <li><a href="/sanctions-tracker">Venezuela sanctions tracker</a></li>
      <li><a href="/invest-in-venezuela">Broader Venezuela investment guide</a></li>
      <li><a href="/sectors/real-estate">Venezuela real estate sector overview</a></li>
      <li><a href="/tools">Investor tools</a></li>
    </ul>
  </section>
</article>
{% endblock %}
