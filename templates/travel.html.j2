{% extends "_base.html.j2" %}
{% from "_base.html.j2" import share_button %}

{% block head_extra %}
<style>
  .travel-hero { background: linear-gradient(180deg, #f6f8fa 0%, var(--white) 100%); padding: 28px 0 16px; margin-bottom: 16px; }
  .travel-hero .kicker { font-size: 12px; text-transform: uppercase; letter-spacing: 1.4px; color: #cc0000; font-weight: 700; }
  .travel-hero h1 { font-family: var(--font-serif); font-size: 32px; color: var(--sr-blue-dark); margin: 8px 0 8px; line-height: 1.2; }
  .travel-hero p.lead { font-family: var(--font-serif); font-style: italic; color: var(--sr-gray-text); font-size: 16px; max-width: 720px; margin: 0; }

  /* Visual "do these three things in order before you fly" panel.
     This is the primary entry point for the page; everything else
     below is reference material. */
  .steps-grid { display: grid; grid-template-columns: 1fr; gap: 16px; margin: 24px 0 32px; }
  @media (min-width: 720px) { .steps-grid { grid-template-columns: 1fr 1fr 1fr; gap: 18px; } }
  .step-card { position: relative; background: var(--white); border: 1px solid var(--sr-gray-light); border-radius: 6px; padding: 22px 22px 20px; display: flex; flex-direction: column; min-height: 280px; transition: border-color 0.15s, transform 0.15s, box-shadow 0.2s; text-decoration: none; color: inherit; overflow: hidden; }
  .step-card::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: var(--sr-blue); }
  .step-card.s1::before { background: #1f6fb2; }
  .step-card.s2::before { background: #cc0000; }
  .step-card.s3::before { background: #1b7a3f; }
  .step-card:hover { border-color: var(--sr-blue); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(13, 36, 64, 0.08); }
  .step-card .step-meta { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
  .step-card .step-num { display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 50%; background: var(--sr-blue-dark); color: #fff; font-family: var(--font-sans); font-weight: 700; font-size: 16px; line-height: 1; }
  .step-card.s2 .step-num { background: #cc0000; }
  .step-card.s3 .step-num { background: #1b7a3f; }
  .step-card .step-tag { font-size: 11px; text-transform: uppercase; letter-spacing: 1.2px; color: var(--sr-gray-text); font-weight: 700; }
  .step-card .step-icon { width: 44px; height: 44px; margin-bottom: 14px; color: var(--sr-blue-dark); }
  .step-card.s2 .step-icon { color: #cc0000; }
  .step-card.s3 .step-icon { color: #1b7a3f; }
  .step-card h2 { font-family: var(--font-serif); font-size: 20px; color: var(--sr-blue-dark); margin: 0 0 8px; line-height: 1.25; }
  .step-card p { font-size: 14px; color: var(--sr-gray-text); margin: 0 0 16px; line-height: 1.55; flex-grow: 1; }
  .step-card .step-cta { display: inline-flex; align-items: center; gap: 6px; font-size: 13.5px; font-weight: 700; color: var(--sr-blue); align-self: flex-start; }
  .step-card .step-cta::after { content: "→"; transition: transform 0.15s; }
  .step-card:hover .step-cta::after { transform: translateX(3px); }
  .step-card.s2 .step-cta { color: #cc0000; }
  .step-card.s3 .step-cta { color: #1b7a3f; }

  .advisory { padding: 14px 18px; border-radius: 4px; margin: 16px 0 28px; }
  .advisory.l4 { background: #fdecea; border-left: 4px solid var(--sr-red); }
  .advisory.l3 { background: #fff3e0; border-left: 4px solid #f5b041; }
  .advisory.l2 { background: #fff8e1; border-left: 4px solid #fbc02d; }
  .advisory.l1 { background: #e8f5e9; border-left: 4px solid #2e7d32; }
  .advisory .lvl { font-weight: 700; }

  .toc { background: var(--sr-gray-bg); border-left: 3px solid var(--sr-blue); padding: 18px 22px; margin: 0 0 32px; font-size: 14px; }
  .toc h3 { font-family: var(--font-serif); font-size: 14px; text-transform: uppercase; letter-spacing: 1px; color: var(--sr-blue-dark); margin-bottom: 10px; }
  .toc ol { margin-left: 20px; columns: 2; column-gap: 24px; }
  .toc li { margin-bottom: 6px; }
  @media (max-width: 640px) { .toc ol { columns: 1; } }

  .sec { margin: 40px 0 24px; padding-top: 8px; }
  .sec h2 { font-family: var(--font-serif); font-size: 26px; color: var(--sr-blue-dark); margin-bottom: 8px; }
  .sec .sec-lead { color: var(--sr-gray-text); margin-bottom: 18px; font-size: 15px; }

  .card-grid { display: grid; grid-template-columns: 1fr; gap: 14px; margin-bottom: 18px; }
  @media (min-width: 720px) { .card-grid.cols-2 { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 980px) { .card-grid.cols-3 { grid-template-columns: 1fr 1fr 1fr; } }

  .card { background: var(--white); border: 1px solid var(--sr-gray-light); border-radius: 4px; padding: 18px 20px; transition: border-color 0.15s, transform 0.15s; }
  .card:hover { border-color: var(--sr-blue); transform: translateY(-1px); }
  .card h3 { font-family: var(--font-serif); font-size: 17px; color: var(--sr-blue-dark); margin-bottom: 6px; }
  .card .meta { font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--sr-gray-text); margin-bottom: 8px; }
  .card .row { font-size: 14px; margin: 4px 0; }
  .card .row strong { color: var(--sr-dark-text); display: inline-block; min-width: 96px; font-weight: 600; }
  .card a.tel { font-weight: 600; color: var(--sr-blue); text-decoration: none; }
  .card a.tel:hover { text-decoration: underline; }
  .card .note { font-size: 13px; color: var(--sr-gray-text); margin-top: 10px; line-height: 1.55; padding-top: 10px; border-top: 1px dotted var(--sr-gray-light); }
  .card a.cta { font-size: 13px; color: var(--sr-blue); font-weight: 600; text-decoration: none; }
  .card a.cta:hover { text-decoration: underline; }

  .checklist { list-style: none; margin: 0 0 8px; padding: 0; }
  .checklist li { display: flex; gap: 14px; padding: 14px 0; border-bottom: 1px dotted var(--sr-gray-light); align-items: flex-start; }
  .checklist li:last-child { border-bottom: 0; }
  .checklist .marker { flex-shrink: 0; width: 22px; height: 22px; border: 2px solid var(--sr-blue); border-radius: 4px; margin-top: 2px; display: inline-block; }
  .checklist .marker.warn { border-color: #cc0000; }
  .checklist .body h4 { font-family: var(--font-sans); font-size: 15px; color: var(--sr-dark-text); margin-bottom: 4px; font-weight: 700; }
  .checklist .body p { font-size: 14px; color: var(--sr-gray-text); margin: 0; line-height: 1.6; }
  .checklist .body a { color: var(--sr-blue); }

  .em-table { width: 100%; border-collapse: collapse; margin: 8px 0 18px; font-size: 14px; }
  .em-table th, .em-table td { text-align: left; padding: 10px 12px; border-bottom: 1px solid var(--sr-gray-light); }
  .em-table th { background: var(--sr-gray-bg); font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--sr-gray-text); font-weight: 600; }
  .em-table td.num { font-family: var(--font-sans); font-weight: 600; color: var(--sr-blue); white-space: nowrap; }

  .disclaimer { background: #fff8e1; border-left: 4px solid #f5b041; padding: 14px 18px; border-radius: 3px; margin: 20px 0; font-size: 13.5px; line-height: 1.65; color: var(--sr-dark-text); }

  .pillbar { display: flex; flex-wrap: wrap; gap: 8px; margin: 8px 0 24px; }
  .pillbar a { display: inline-block; padding: 6px 14px; background: var(--white); border: 1px solid var(--sr-gray-light); border-radius: 999px; font-size: 13px; font-weight: 600; color: var(--sr-blue-dark); text-decoration: none; }
  .pillbar a:hover { border-color: var(--sr-blue); color: var(--sr-blue); }

  /* "Register your trip" callout — visually distinct and impossible to miss. */
  .register-callout { background: #f4f8fb; border: 1px solid #cfdce8; border-left: 5px solid var(--sr-blue); padding: 22px 24px; border-radius: 4px; margin: 28px 0 32px; }
  .register-callout .kicker { font-size: 12px; text-transform: uppercase; letter-spacing: 1.4px; color: var(--sr-red); font-weight: 700; margin-bottom: 6px; }
  .register-callout h2 { font-family: var(--font-serif); font-size: 24px; color: var(--sr-blue-dark); margin: 0 0 10px; }
  .register-callout p { font-size: 15px; color: var(--sr-dark-text); margin: 0 0 16px; line-height: 1.65; max-width: 760px; }
  .register-callout p.fine { font-size: 13px; color: var(--sr-gray-text); margin-top: 14px; margin-bottom: 0; }
  .register-grid { display: grid; grid-template-columns: 1fr; gap: 10px; }
  @media (min-width: 720px) { .register-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1080px) { .register-grid { grid-template-columns: 1fr 1fr 1fr; } }
  .register-grid a { display: block; padding: 12px 14px; background: var(--white); border: 1px solid var(--sr-gray-light); border-radius: 4px; text-decoration: none; color: var(--sr-dark-text); transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s; }
  .register-grid a:hover { border-color: var(--sr-blue); transform: translateY(-1px); box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05); }
  .register-grid .country { display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.7px; color: var(--sr-gray-text); margin-bottom: 2px; }
  .register-grid .program { display: block; font-family: var(--font-serif); font-weight: 700; font-size: 15px; color: var(--sr-blue-dark); margin-bottom: 4px; }
  .register-grid .blurb { display: block; font-size: 12.5px; color: var(--sr-gray-text); line-height: 1.5; }

  .visa-service-callout { background: #fff8e1; border: 1px solid #f1d28a; border-left: 5px solid #f5b041; padding: 20px 22px; border-radius: 4px; margin: 10px 0 28px; display: grid; grid-template-columns: 1fr; gap: 12px; align-items: center; }
  @media (min-width: 760px) { .visa-service-callout { grid-template-columns: 1.6fr 1fr; } }
  .visa-service-callout .kicker { font-size: 12px; text-transform: uppercase; letter-spacing: 1.2px; color: var(--sr-red); font-weight: 700; margin-bottom: 5px; }
  .visa-service-callout h2 { font-family: var(--font-serif); color: var(--sr-blue-dark); font-size: 22px; line-height: 1.25; margin: 0 0 8px; }
  .visa-service-callout p { font-size: 14.5px; color: var(--sr-dark-text); line-height: 1.6; margin: 0; }
  .visa-service-callout .price { background: #fff; border: 1px solid #efd48d; border-radius: 4px; padding: 13px 15px; }
  .visa-service-callout .price strong { display: block; font-family: var(--font-serif); color: var(--sr-red); font-size: 30px; line-height: 1.1; }
  .visa-service-callout .price span { display: block; color: var(--sr-gray-text); font-size: 12.5px; line-height: 1.45; margin-top: 5px; }
  .visa-service-callout .cta { display: inline-block; margin-top: 12px; padding: 9px 15px; border-radius: 3px; background: var(--sr-red); color: #fff; text-decoration: none; font-size: 13px; font-weight: 700; }
  .visa-service-callout .cta:hover { background: #a01d18; color: #fff; }

  /* "Show top N" collapsible sections — items beyond data-limit are hidden
     until the user clicks "See all". Limits supported: 2, 3, 4. */
  .section-collapsed[data-limit="2"] > :nth-child(n+3),
  .section-collapsed[data-limit="3"] > :nth-child(n+4),
  .section-collapsed[data-limit="4"] > :nth-child(n+5) { display: none; }
  .see-more-row { margin: 4px 0 8px; }
  .see-more-btn { display: inline-flex; align-items: center; gap: 8px; padding: 9px 18px; background: var(--white); border: 1px solid var(--sr-blue); border-radius: 999px; color: var(--sr-blue); font-size: 13px; font-weight: 600; cursor: pointer; font-family: var(--font-sans); transition: background 0.15s, color 0.15s, transform 0.1s; }
  .see-more-btn:hover { background: var(--sr-blue); color: var(--white); }
  .see-more-btn:active { transform: scale(0.98); }
  .see-more-btn[hidden] { display: none; }
  .see-more-btn .chev { transition: transform 0.2s ease; }
</style>
{% endblock %}

{% block content %}
<section class="container-wide">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <a href="/invest-in-venezuela">Invest in Venezuela</a><span>/</span>
    <span>Travel to Venezuela</span>
    <span style="margin-left:auto;">{{ share_button(seo.canonical, seo.title) }}</span>
  </nav>

  <header class="travel-hero">
    <div class="kicker">Travel briefing · Updated {{ updated_label }}</div>
    <h1>Travel to Venezuela</h1>
    <p class="lead">
      Caracas operational briefing for business travellers, journalists
      and NGO staff. Start with the three steps below, then use the
      reference sections for hotels, transport, medical and security.
    </p>
  </header>

  {% if advisory %}
  <div class="advisory l{{ advisory.level }}">
    <div><span class="lvl">US State Department: Level {{ advisory.level }} — {{ advisory.label }}</span> (issued {{ advisory.issued }})</div>
    <div style="font-size: 13px; margin-top: 6px;">
      <a href="{{ advisory.primary_url }}" rel="nofollow noopener" target="_blank" style="color: inherit;">Read the full advisory &rarr;</a>
    </div>
  </div>
  {% endif %}

  {# ============ Visual "do this in order" three-step entry point ============ #}
  <div class="steps-grid" aria-label="Three steps to take before you fly">

    <a class="step-card s1" href="/tools/venezuela-visa-requirements" target="_blank" rel="noopener">
      <div class="step-meta">
        <span class="step-num">1</span>
        <span class="step-tag">Do this first</span>
      </div>
      <svg class="step-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="5" y="3" width="14" height="18" rx="1.5"/>
        <circle cx="12" cy="11" r="3"/>
        <path d="M9 16h6M10 19h4"/>
      </svg>
      <h2>Check if you need a visa</h2>
      <p>Pick your passport country to confirm whether you need a visa and how to apply. US citizens use the official Cancillería Digital e-visa portal &mdash; not a US-based consulate.</p>
      <span class="step-cta">Open the visa checker</span>
    </a>

    <a class="step-card s2" href="/travel#register" target="_blank" rel="noopener">
      <div class="step-meta">
        <span class="step-num">2</span>
        <span class="step-tag">Free · 5 minutes</span>
      </div>
      <svg class="step-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 11l18-7-3 16-6-5-9 4z"/>
        <path d="M12 15l-3 4"/>
      </svg>
      <h2>Enrol in STEP or your country's equivalent</h2>
      <p>Free traveller-registration with your foreign ministry. Lets your government locate you in a crisis and pushes real-time security alerts to your phone throughout the trip.</p>
      <span class="step-cta">Pick your country's program</span>
    </a>

    <a class="step-card s3" href="/travel/emergency-card" target="_blank" rel="noopener">
      <div class="step-meta">
        <span class="step-num">3</span>
        <span class="step-tag">Print one A4 page</span>
      </div>
      <svg class="step-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M7 3h7l4 4v14a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"/>
        <path d="M14 3v5h5"/>
        <path d="M9 13l2 2 4-4"/>
      </svg>
      <h2>Print the Caracas Emergency Card</h2>
      <p>Bilingual one-page card to fold into your passport &mdash; hospital and embassy addresses a taxi driver can read, plus your blood type and home contact. Saved locally; reprint anytime.</p>
      <span class="step-cta">Personalize &amp; print</span>
    </a>

  </div>

  {# Cross-link to the dedicated visa-application pillar. Sits between the
     3-step hero and the in-page reference pillbar so the deeper guide is
     one click away for users who already know they need a visa. #}
  <p style="text-align:center; margin: -8px 0 18px; font-size: 14.5px; color: var(--sr-gray-text); line-height: 1.6;">
    Already know you need a visa? &nbsp;
    <a href="/apply-for-venezuelan-visa" style="color: var(--sr-blue); font-weight: 600;">Open the full Venezuela visa application guide &rarr;</a>
    <br>
    <span style="display:inline-block; margin-top: 6px;">Applying on the e-visa portal? &nbsp;
    <a href="{{ us_embassy_eguide_url }}" target="_blank" rel="noopener" style="color: var(--sr-blue); font-weight: 600;">Embassy Application Instructions &rarr;</a></span>
  </p>

  <div class="visa-service-callout">
    <div>
      <div class="kicker">New service · Same-day application filing</div>
      <h2>Need help filing the Venezuela e-visa application?</h2>
      <p>
        We review your documents, prepare the Cancillería Digital filing,
        submit complete packages the same business day, and monitor ministry
        follow-up. Approval is never guaranteed by any private service.
      </p>
      <a class="cta" href="/get-venezuela-visa">Get Venezuela visa help &rarr;</a>
    </div>
    <div class="price">
      <strong>$49.99</strong>
      <span>Launch special this month. Regular service fee $79.99; government fees are separate.</span>
    </div>
  </div>

  <div class="pillbar" aria-label="Jump to a reference section">
    <a href="#embassies">Embassies</a>
    <a href="#hotels">Hotels</a>
    <a href="#transport">Airport transfer</a>
    <a href="#medical">Hospitals</a>
    <a href="#security">Corporate security</a>
    <a href="#money">Money &amp; banking</a>
    <a href="#emergency">Emergency numbers</a>
    <a href="/tools/caracas-safety-by-neighborhood">Caracas safety map &rarr;</a>
    <a href="/tools/bolivar-usd-exchange-rate">Live FX rate &rarr;</a>
  </div>

  {# Step 2 detail block — anchored from the hero card #}
  <div id="register" class="register-callout">
    <div class="kicker">Step 2 detail · Pick your country</div>
    <h2>Traveller-registration programs</h2>
    <p>
      Pick the program for your nationality and enrol before you fly.
      Other countries: ask your foreign ministry's consular section
      whether they operate a registration system &mdash; most G20 countries
      do, and enrolment is always free.
    </p>
    <div class="register-grid section-collapsed" data-limit="3" id="reg-grid">
      {% for r in registration_programs %}
      <a href="{{ r.url }}" rel="nofollow noopener" target="_blank">
        <span class="country">{{ r.country }}</span>
        <span class="program">{{ r.program }}</span>
        <span class="blurb">{{ r.blurb }}</span>
      </a>
      {% endfor %}
    </div>
    {% if registration_programs|length > 3 %}
    <div class="see-more-row">
      <button type="button" class="see-more-btn" data-target="reg-grid">
        See all {{ registration_programs|length }} country programs <span class="chev">&darr;</span>
      </button>
    </div>
    {% endif %}
  </div>

  {# ======================================================================= #}
  <section id="embassies" class="sec">
    <h2>1. Embassies &amp; consulates in Caracas</h2>
    <p class="sec-lead">
      Register with your embassy <em>before</em> you fly via your foreign
      ministry's traveller-registration system (US: STEP; UK: FCDO; Canada:
      ROCA). All numbers below are in international dialling format.
    </p>
    <div class="card-grid cols-2 section-collapsed" data-limit="2" id="embassies-grid">
      {% for e in embassies %}
      <div class="card">
        <div class="meta">{{ e.country }}</div>
        <h3>Embassy in {{ e.city }}</h3>
        {% if e.address %}<div class="row"><strong>Address</strong>{{ e.address }}</div>{% endif %}
        {% if e.phone %}<div class="row"><strong>Phone</strong><a class="tel" href="tel:{{ e.phone | replace(' ', '') | replace('(', '') | replace(')', '') | replace('-', '') }}">{{ e.phone }}</a></div>{% endif %}
        {% if e.after_hours %}<div class="row"><strong>After-hours</strong>{{ e.after_hours }}</div>{% endif %}
        {% if e.email %}<div class="row"><strong>Email</strong><a href="mailto:{{ e.email }}">{{ e.email }}</a></div>{% endif %}
        {% if e.website %}<div class="row"><strong>Website</strong><a href="{{ e.website }}" rel="nofollow noopener" target="_blank">Official site &rarr;</a></div>{% endif %}
        {% if e.notes %}<div class="note">{{ e.notes }}</div>{% endif %}
      </div>
      {% endfor %}
    </div>
    {% if embassies|length > 2 %}
    <div class="see-more-row">
      <button type="button" class="see-more-btn" data-target="embassies-grid">
        See all {{ embassies|length }} embassies <span class="chev">&darr;</span>
      </button>
    </div>
    {% endif %}
  </section>

  {# ======================================================================= #}
  <section id="hotels" class="sec">
    <h2>2. Where to stay</h2>
    <p class="sec-lead">
      The hotels below are international or long-established Venezuelan
      properties in safer neighbourhoods (Las Mercedes, La Castellana,
      Altamira, El Rosal, Chuao). Their concierges arrange airport transfers,
      which is the single most important logistics call you make on this trip.
    </p>
    <div class="card-grid cols-2 section-collapsed" data-limit="4" id="hotels-grid">
      {% for h in hotels %}
      <div class="card">
        <div class="meta">{{ h.tier }} · {{ h.neighborhood }}</div>
        <h3>{{ h.name }}</h3>
        {% if h.address %}<div class="row"><strong>Address</strong>{{ h.address }}</div>{% endif %}
        {% if h.phone %}<div class="row"><strong>Phone</strong><a class="tel" href="tel:{{ h.phone | replace(' ', '') | replace('(', '') | replace(')', '') | replace('-', '') }}">{{ h.phone }}</a></div>{% endif %}
        {% if h.url %}<div class="row"><strong>Booking</strong><a href="{{ h.url }}" rel="nofollow noopener" target="_blank">Official site &rarr;</a></div>{% endif %}
        {% if h.why_listed %}<div class="note">{{ h.why_listed }}</div>{% endif %}
      </div>
      {% endfor %}
    </div>
    {% if hotels|length > 4 %}
    <div class="see-more-row">
      <button type="button" class="see-more-btn" data-target="hotels-grid">
        See all {{ hotels|length }} hotels <span class="chev">&darr;</span>
      </button>
    </div>
    {% endif %}
  </section>

  {# ======================================================================= #}
  <section id="restaurants" class="sec">
    <h2>3. Where to eat</h2>
    <p class="sec-lead">
      All entries are well-established restaurants in safer central-east
      neighbourhoods. Reservations are advised for dinner; valet parking
      is the norm. We deliberately do not list late-night venues outside
      these zones.
    </p>
    <div class="card-grid cols-2 section-collapsed" data-limit="4" id="restaurants-grid">
      {% for r in restaurants %}
      <div class="card">
        <div class="meta">{{ r.cuisine }} · {{ r.neighborhood }}</div>
        <h3>{{ r.name }}</h3>
        {% if r.phone %}<div class="row"><strong>Phone</strong><a class="tel" href="tel:{{ r.phone | replace(' ', '') | replace('(', '') | replace(')', '') | replace('-', '') }}">{{ r.phone }}</a></div>{% endif %}
        {% if r.url %}<div class="row"><strong>Listing</strong><a href="{{ r.url }}" rel="nofollow noopener" target="_blank">Open &rarr;</a></div>{% endif %}
        {% if r.notes %}<div class="note">{{ r.notes }}</div>{% endif %}
      </div>
      {% endfor %}
    </div>
    {% if restaurants|length > 4 %}
    <div class="see-more-row">
      <button type="button" class="see-more-btn" data-target="restaurants-grid">
        See all {{ restaurants|length }} restaurants <span class="chev">&darr;</span>
      </button>
    </div>
    {% endif %}
  </section>

  {# ======================================================================= #}
  <section id="medical" class="sec">
    <h2>4. Hospitals &amp; medical providers</h2>
    <p class="sec-lead">
      Public hospitals are heavily under-resourced and visitors should plan
      around the private clinics below. Confirm direct billing with your
      travel-medical insurer (e.g. International SOS) before you fly.
    </p>
    <div class="card-grid cols-2 section-collapsed" data-limit="2" id="medical-grid">
      {% for m in medical %}
      <div class="card">
        <div class="meta">{{ m.type }} · {{ m.neighborhood }}</div>
        <h3>{{ m.name }}</h3>
        {% if m.phone %}<div class="row"><strong>Phone</strong><a class="tel" href="tel:{{ m.phone | replace(' ', '') | replace('(', '') | replace(')', '') | replace('-', '') }}">{{ m.phone }}</a></div>{% endif %}
        {% if m.url %}<div class="row"><strong>Website</strong><a href="{{ m.url }}" rel="nofollow noopener" target="_blank">Official site &rarr;</a></div>{% endif %}
        {% if m.notes %}<div class="note">{{ m.notes }}</div>{% endif %}
      </div>
      {% endfor %}
    </div>
    {% if medical|length > 2 %}
    <div class="see-more-row">
      <button type="button" class="see-more-btn" data-target="medical-grid">
        See all {{ medical|length }} hospitals &amp; medical providers <span class="chev">&darr;</span>
      </button>
    </div>
    {% endif %}
  </section>

  {# ======================================================================= #}
  <section id="transport" class="sec">
    <h2>5. Ground transport &amp; drivers</h2>
    <p class="sec-lead">
      <strong>The single most important rule:</strong> never take a street
      taxi, especially not at SVMI airport. Always pre-arrange transport.
      The default option for almost every business traveller is to book the
      airport transfer through the hotel's reservation desk before flying.
    </p>
    <div class="card-grid cols-2 section-collapsed" data-limit="2" id="transport-grid">
      {% for t in transport %}
      <div class="card">
        <div class="meta">{{ t.type }}</div>
        <h3>{{ t.name }}</h3>
        {% if t.phone %}<div class="row"><strong>Contact</strong>{{ t.phone }}</div>{% endif %}
        {% if t.url %}<div class="row"><strong>Link</strong><a href="{{ t.url }}" rel="nofollow noopener" target="_blank">Open &rarr;</a></div>{% endif %}
        {% if t.notes %}<div class="note">{{ t.notes }}</div>{% endif %}
      </div>
      {% endfor %}
    </div>
    {% if transport|length > 2 %}
    <div class="see-more-row">
      <button type="button" class="see-more-btn" data-target="transport-grid">
        See all {{ transport|length }} transport options <span class="chev">&darr;</span>
      </button>
    </div>
    {% endif %}
  </section>

  {# ======================================================================= #}
  <section id="security" class="sec">
    <h2>6. Corporate security advisory</h2>
    <p class="sec-lead">
      For protective services in Caracas (executive transport with vetted
      drivers, residential security, journey management, evacuation), engage
      one of the established international security firms below rather than
      contracting a local protective-services vendor cold. They maintain the
      vetted local relationships you need.
    </p>
    <div class="card-grid cols-2 section-collapsed" data-limit="2" id="security-grid">
      {% for s in security %}
      <div class="card">
        <div class="meta">{{ s.type }}</div>
        <h3>{{ s.name }}</h3>
        {% if s.phone %}<div class="row"><strong>Phone</strong>{{ s.phone }}</div>{% endif %}
        {% if s.url %}<div class="row"><strong>Website</strong><a href="{{ s.url }}" rel="nofollow noopener" target="_blank">Open &rarr;</a></div>{% endif %}
        {% if s.notes %}<div class="note">{{ s.notes }}</div>{% endif %}
      </div>
      {% endfor %}
    </div>
    {% if security|length > 2 %}
    <div class="see-more-row">
      <button type="button" class="see-more-btn" data-target="security-grid">
        See all {{ security|length }} security firms <span class="chev">&darr;</span>
      </button>
    </div>
    {% endif %}
  </section>

  {# ======================================================================= #}
  <section id="comms" class="sec">
    <h2>7. Communications &amp; SIM cards</h2>
    <p class="sec-lead">
      Cellular roaming on US carriers is unreliable; plan around an eSIM
      activated before you board, plus a VPN configured in advance.
    </p>
    <ul class="checklist section-collapsed" data-limit="2" id="comms-list">
      {% for c in communications %}
      <li>
        <span class="marker"></span>
        <div class="body">
          <h4>{{ c.topic }}</h4>
          <p>{{ c.detail }}</p>
        </div>
      </li>
      {% endfor %}
    </ul>
    {% if communications|length > 2 %}
    <div class="see-more-row">
      <button type="button" class="see-more-btn" data-target="comms-list">
        See all {{ communications|length }} communications tips <span class="chev">&darr;</span>
      </button>
    </div>
    {% endif %}
  </section>

  {# ======================================================================= #}
  <section id="money" class="sec">
    <h2>8. Money &amp; banking</h2>
    <p class="sec-lead">
      Caracas runs on US dollar cash and informal Zelle transfers. Bring
      small denominations and don't rely on ATMs.
    </p>
    <ul class="checklist section-collapsed" data-limit="2" id="money-list">
      {% for m in money %}
      <li>
        <span class="marker"></span>
        <div class="body">
          <h4>{{ m.topic }}</h4>
          <p>{{ m.detail }}
            {% if m.url %}<a href="{{ m.url }}">See live rates &rarr;</a>{% endif %}
          </p>
        </div>
      </li>
      {% endfor %}
    </ul>
    {% if money|length > 2 %}
    <div class="see-more-row">
      <button type="button" class="see-more-btn" data-target="money-list">
        See all {{ money|length }} money &amp; banking tips <span class="chev">&darr;</span>
      </button>
    </div>
    {% endif %}
  </section>

  {# ======================================================================= #}
  <section id="pretrip" class="sec">
    <h2>9. Pre-departure checklist</h2>
    <p class="sec-lead">
      Work this list end-to-end at least two weeks before departure.
    </p>
    <ul class="checklist section-collapsed" data-limit="2" id="pretrip-list">
      {% for item in pre_trip %}
      <li>
        <span class="marker"></span>
        <div class="body">
          <h4>{{ item.label }}</h4>
          <p>{{ item.detail }}
            {% if item.url %}
              {% if item.url.startswith('#') %}
                <a href="{{ item.url }}">Jump to the registration section &darr;</a>
              {% elif item.url.startswith('/') %}
                <a href="{{ item.url }}">Open the tool &rarr;</a>
              {% else %}
                <a href="{{ item.url }}" rel="nofollow noopener" target="_blank">Open &rarr;</a>
              {% endif %}
            {% endif %}
          </p>
        </div>
      </li>
      {% endfor %}
    </ul>
    {% if pre_trip|length > 2 %}
    <div class="see-more-row">
      <button type="button" class="see-more-btn" data-target="pretrip-list">
        See all {{ pre_trip|length }} pre-departure items <span class="chev">&darr;</span>
      </button>
    </div>
    {% endif %}
  </section>

  {# ======================================================================= #}
  <section id="safety" class="sec">
    <h2>10. Personal safety checklist</h2>
    <p class="sec-lead">
      These are the on-the-ground rules that experienced visitors,
      diplomats and journalists treat as non-negotiable.
    </p>
    <ul class="checklist section-collapsed" data-limit="2" id="safety-list">
      {% for r in safety %}
      <li>
        <span class="marker warn"></span>
        <div class="body">
          <h4>{{ r.rule }}</h4>
          <p>{{ r.detail }}</p>
        </div>
      </li>
      {% endfor %}
    </ul>
    {% if safety|length > 2 %}
    <div class="see-more-row">
      <button type="button" class="see-more-btn" data-target="safety-list">
        See all {{ safety|length }} safety rules <span class="chev">&darr;</span>
      </button>
    </div>
    {% endif %}
  </section>

  {# ======================================================================= #}
  <section id="emergency" class="sec">
    <h2>11. Emergency numbers</h2>
    <p class="sec-lead">
      Save these to your phone before you fly. In a serious incident, call
      your embassy first, then your security/medical assistance provider,
      then local emergency services.
    </p>
    <table class="em-table">
      <thead>
        <tr><th style="width:65%;">Service</th><th>Number</th></tr>
      </thead>
      <tbody class="section-collapsed" data-limit="2" id="emergency-tbody">
        {% for e in emergency %}
        <tr>
          <td>{{ e.label }}</td>
          <td class="num">{{ e.number }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% if emergency|length > 2 %}
    <div class="see-more-row">
      <button type="button" class="see-more-btn" data-target="emergency-tbody">
        See all {{ emergency|length }} emergency numbers <span class="chev">&darr;</span>
      </button>
    </div>
    {% endif %}
  </section>

  <div style="margin-top: 40px; padding: 18px; background: var(--sr-gray-bg); border-radius: 4px;">
    <p style="font-size: 14px; color: var(--sr-dark-text); margin: 0;">
      <strong>Heading to Venezuela?</strong>
      Subscribe to the Caracas Research daily briefing for sanctions, FX,
      legal and political updates that affect your trip and your business
      in Venezuela. <a href="/#signup" style="font-weight: 600;">Get the daily briefing &rarr;</a>
    </p>
  </div>

  <p style="font-size: 12px; color: var(--sr-gray-text); margin: 24px 0;">
    Sources: US State Department Travel Advisory and OSAC Caracas Crime &amp;
    Safety Report; UK FCDO Foreign Travel Advice; MPPRE consular directory;
    embassy and hotel websites cited above. Information is for planning
    purposes only and does not constitute travel, legal or security advice.
  </p>

</section>

<script>
// "See more" expanders. Clicking a .see-more-btn removes the
// .section-collapsed class from its target container, revealing all
// hidden items, and hides the button itself.
(function initSeeMore() {
  document.querySelectorAll('.see-more-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var target = document.getElementById(btn.getAttribute('data-target'));
      if (!target) return;
      target.classList.remove('section-collapsed');
      btn.setAttribute('hidden', '');
    });
  });
  // Auto-expand a section if the user lands via an anchor link inside it,
  // so e.g. /travel#safety doesn't strand them on a 2-item view.
  function expandFromHash() {
    var hash = (window.location.hash || '').replace(/^#/, '');
    if (!hash) return;
    var target = document.getElementById(hash);
    if (!target) return;
    target.querySelectorAll('.section-collapsed').forEach(function(el) {
      el.classList.remove('section-collapsed');
    });
    target.querySelectorAll('.see-more-btn').forEach(function(btn) {
      btn.setAttribute('hidden', '');
    });
  }
  expandFromHash();
  window.addEventListener('hashchange', expandFromHash);
})();
</script>

