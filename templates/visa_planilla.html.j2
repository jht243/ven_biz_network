<!DOCTYPE html>
<html lang="en">
<head>
  {% include "_google_tag.html.j2" %}

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ seo.title }}</title>
  <meta name="description" content="{{ seo.description }}">
  <link rel="canonical" href="{{ seo.canonical }}">
  <meta name="robots" content="noindex,follow">
  <meta name="application-name" content="Caracas Research">
  <meta name="apple-mobile-web-app-title" content="Caracas Research">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" type="image/svg+xml" href="/static/cr-favicon.svg">
  <link rel="icon" type="image/png" sizes="48x48" href="/static/cr-favicon-48.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/static/cr-favicon-192.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/static/apple-touch-icon.png">
  <link rel="manifest" href="/static/site.webmanifest">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Noto+Sans:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    :root { --navy: #002b5e; --ink: #111; --muted: #555; --edit: #fff7c2; }
    * { box-sizing: border-box; }
    body { font-family: 'Noto Sans', -apple-system, sans-serif; font-size: 14px; color: var(--ink); margin: 0; padding: 24px 0 40px; background: #c8c8c2; -webkit-font-smoothing: antialiased; }
    .toolbar { max-width: 210mm; margin: 0 auto 16px; background: #fff; border: 1px solid #b0b0a8; border-top: 4px solid var(--navy); border-radius: 4px; padding: 14px 18px; }
    .toolbar h1 { font-size: 16px; color: var(--navy); margin: 0 0 6px; }
    .toolbar p { font-size: 13px; color: var(--muted); line-height: 1.5; margin: 0 0 10px; }
    .toolbar .actions { display: flex; flex-wrap: wrap; gap: 8px; }
    .toolbar button { font-family: inherit; font-size: 13px; font-weight: 600; padding: 8px 16px; border-radius: 3px; cursor: pointer; }
    .toolbar .pri { background: #cc0000; color: #fff; border: 0; }
    .toolbar .sec { background: #fff; color: var(--navy); border: 1px solid var(--navy); }
    .toolbar a.back { color: var(--navy); font-size: 13px; font-weight: 600; }
    .sheet { max-width: 210mm; margin: 0 auto; background: #fff; padding: 10mm 12mm; box-shadow: 0 1px 6px rgba(0,0,0,.12); }
    .sheet > h1 { font-size: 14px; text-align: center; margin: 0 0 12px; letter-spacing: 0.5px; }
    .sheet-sub { font-size: 11px; color: var(--muted); text-align: center; margin: -6px 0 14px; line-height: 1.4; }
    .sec { margin-bottom: 10px; page-break-inside: avoid; }
    .sec h2 { font-size: 11px; margin: 0 0 6px; text-transform: uppercase; letter-spacing: 0.3px; border-bottom: 1px solid #333; padding-bottom: 2px; }
    .row { display: flex; flex-wrap: wrap; gap: 6px 12px; margin-bottom: 4px; font-size: 10pt; }
    .row label { min-width: 140px; color: #333; }
    .row input, .row select, .row textarea { flex: 1; min-width: 120px; font-family: inherit; font-size: 10pt; padding: 2px 5px; border: 0; border-bottom: 1px solid #999; background: var(--edit); }
    @media (max-width: 700px) { .row { flex-direction: column; } .row input { min-width: 100%; } }
    .lbl-en { display: inline; }
    .lbl-es { display: none; }
    .field-hint { font-size: 9pt; color: var(--muted); margin: 0 0 4px; line-height: 1.35; }
    .sig-block { margin-top: 4px; }
    .sig-block label { display: block; font-size: 9pt; margin-bottom: 2px; }
    .sig-input { width: 100%; max-width: 360px; font-size: 11pt !important; }
    .sig-cursive { font-family: 'Great Vibes', cursive; font-size: 32px; min-height: 40px; color: #000; line-height: 1.1; }
    @page { size: A4; margin: 8mm; }
    @media print {
      body { background: #fff; padding: 0; }
      .toolbar, .sheet-sub, .field-hint { display: none !important; }
      .sheet { box-shadow: none; max-width: none; padding: 0; }
      input, select, textarea { background: transparent !important; border-bottom: 1px solid #666 !important; }
      .no-print-elm { display: none !important; }
      #pl-sig { display: none !important; }
      #pl-sig-out { display: block !important; }
      .sig-cursive { font-size: 28pt; }
      .lbl-en { display: none !important; }
      .lbl-es { display: inline !important; }
    }
  </style>
</head>
<body>
  <div class="toolbar">
    <h1>{{ planilla_hero_line }} — type in English, print a Spanish form</h1>
    <p>
      Labels are in <strong>English</strong> while you work. When you use <strong>Print</strong> → <strong>Save as PDF</strong>,
      section titles and field labels switch to <strong>Spanish</strong> for upload to Cancillería Digital (your answers stay as you typed them).
      Confirm wording against the current official planilla if the ministry updates it.
    </p>
    <div class="actions">
      <button type="button" class="pri" onclick="trackVisaFormEvent('visa_form_print_click'); window.print()">Print / Save as PDF</button>
      <button type="button" class="sec" onclick="trackVisaFormEvent('visa_form_clear'); document.getElementById('pform').reset(); syncSig('pl-sig','pl-sig-out');">Clear form</button>
      <a class="back" href="/planilla-de-solicitud-de-visa" onclick="trackVisaFormEvent('visa_form_back_to_guide')">{{ planilla_hero_line }}</a>
      <a class="back" href="/apply-for-venezuelan-visa" onclick="trackVisaFormEvent('visa_form_back_to_guide')">← Full visa guide (2026)</a>
    </div>
  </div>

  <form class="sheet" id="pform" autocomplete="off" lang="es">
    <h1>PLANILLA DE SOLICITUD DE VISA</h1>
    <p class="sheet-sub no-print-elm">Official heading above is Spanish on your PDF. Fill the fields in any language the portal accepts; most travelers use English.</p>

    <div class="sec">
      <h2><span class="lbl-en">1. Visa type</span><span class="lbl-es" lang="es">1. Tipo de visa</span></h2>
      <div class="row"><label for="p1tipo"><span class="lbl-en">Type</span><span class="lbl-es" lang="es">Tipo</span></label><input id="p1tipo" name="p1tipo" type="text" placeholder="e.g. Tourist / Business" value=""></div>
      <div class="row"><label for="p1fecha"><span class="lbl-en">Application date</span><span class="lbl-es" lang="es">Fecha de solicitud</span></label><input id="p1fecha" name="p1fecha" type="text" placeholder="DD/MM/YYYY"></div>
    </div>

    <div class="sec">
      <h2><span class="lbl-en">2. Personal details</span><span class="lbl-es" lang="es">2. Datos personales</span></h2>
      <div class="row"><label for="p2a"><span class="lbl-en">Surname(s)</span><span class="lbl-es" lang="es">Apellidos</span></label><input id="p2a" type="text" placeholder="As in passport"></div>
      <div class="row"><label for="p2n"><span class="lbl-en">Given name(s)</span><span class="lbl-es" lang="es">Nombres</span></label><input id="p2n" type="text"></div>
      <div class="row"><label for="p2nac"><span class="lbl-en">Nationality</span><span class="lbl-es" lang="es">Nacionalidad</span></label><input id="p2nac" type="text" placeholder="e.g. United States"></div>
      <div class="row"><label for="p2ln"><span class="lbl-en">Place of birth</span><span class="lbl-es" lang="es">Lugar de nacimiento</span></label><input id="p2ln" type="text"></div>
      <div class="row"><label for="p2fn"><span class="lbl-en">Date of birth</span><span class="lbl-es" lang="es">Fecha de nacimiento</span></label><input id="p2fn" type="text" placeholder="DD/MM/YYYY"></div>
      <p class="field-hint no-print-elm">Gender: options below appear in Spanish on your PDF (Masculino / Femenino / Otro).</p>
      <div class="row"><label for="p2s"><span class="lbl-en">Gender</span><span class="lbl-es" lang="es">Sexo</span></label>
        <select id="p2s"><option value="">—</option><option>Masculino</option><option>Femenino</option><option>Otro</option></select></div>
      <div class="row"><label for="p2e"><span class="lbl-en">Marital status</span><span class="lbl-es" lang="es">Estado civil</span></label><input id="p2e" type="text" placeholder="e.g. Single / Married"></div>
    </div>

    <div class="sec">
      <h2><span class="lbl-en">3. Passport details</span><span class="lbl-es" lang="es">3. Datos del pasaporte</span></h2>
      <div class="row"><label for="p3t"><span class="lbl-en">Type</span><span class="lbl-es" lang="es">Tipo</span></label><input id="p3t" type="text" placeholder="e.g. Ordinary (ordinario)" value="Ordinario"></div>
      <div class="row"><label for="p3n"><span class="lbl-en">Number</span><span class="lbl-es" lang="es">Número</span></label><input id="p3n" type="text"></div>
      <div class="row"><label for="p3pe"><span class="lbl-en">Country of issue</span><span class="lbl-es" lang="es">País de emisión</span></label><input id="p3pe" type="text"></div>
      <div class="row"><label for="p3e"><span class="lbl-en">Issue date</span><span class="lbl-es" lang="es">Fecha de emisión</span></label><input id="p3e" type="text" placeholder="DD/MM/YYYY"></div>
      <div class="row"><label for="p3v"><span class="lbl-en">Expiry date</span><span class="lbl-es" lang="es">Fecha de vencimiento</span></label><input id="p3v" type="text" placeholder="DD/MM/YYYY"></div>
    </div>

    <div class="sec">
      <h2><span class="lbl-en">4. Home address</span><span class="lbl-es" lang="es">4. Dirección de residencia</span></h2>
      <div class="row"><label for="p4d"><span class="lbl-en">Street address</span><span class="lbl-es" lang="es">Dirección</span></label><input id="p4d" type="text" style="flex:1 1 100%;"></div>
      <div class="row"><label for="p4t"><span class="lbl-en">Phone</span><span class="lbl-es" lang="es">Teléfono</span></label><input id="p4t" type="text"></div>
      <div class="row"><label for="p4c"><span class="lbl-en">Email</span><span class="lbl-es" lang="es">Correo electrónico</span></label><input id="p4c" type="email"></div>
    </div>

    <div class="sec">
      <h2><span class="lbl-en">5. Trip information</span><span class="lbl-es" lang="es">5. Información del viaje</span></h2>
      <div class="row"><label for="p5m"><span class="lbl-en">Purpose of trip</span><span class="lbl-es" lang="es">Motivo del viaje</span></label><input id="p5m" type="text" placeholder="e.g. Tourism"></div>
      <div class="row"><label for="p5e"><span class="lbl-en">Arrival date</span><span class="lbl-es" lang="es">Fecha de entrada</span></label><input id="p5e" type="text" placeholder="DD/MM/YYYY"></div>
      <div class="row"><label for="p5s"><span class="lbl-en">Departure date</span><span class="lbl-es" lang="es">Fecha de salida</span></label><input id="p5s" type="text" placeholder="DD/MM/YYYY"></div>
      <div class="row"><label for="p5a"><span class="lbl-en">Airline</span><span class="lbl-es" lang="es">Aerolínea</span></label><input id="p5a" type="text"></div>
      <div class="row"><label for="p5i"><span class="lbl-en">Outbound flight</span><span class="lbl-es" lang="es">Vuelo (ida)</span></label><input id="p5i" type="text"></div>
      <div class="row"><label for="p5r"><span class="lbl-en">Return flight</span><span class="lbl-es" lang="es">Vuelo (regreso)</span></label><input id="p5r" type="text"></div>
    </div>

    <div class="sec">
      <h2><span class="lbl-en">6. Lodging in Venezuela</span><span class="lbl-es" lang="es">6. Lugar de alojamiento en Venezuela</span></h2>
      <div class="row"><label for="p6h"><span class="lbl-en">Hotel / lodging</span><span class="lbl-es" lang="es">Hotel / alojamiento</span></label><input id="p6h" type="text"></div>
      <div class="row"><label for="p6d"><span class="lbl-en">Address</span><span class="lbl-es" lang="es">Dirección</span></label><input id="p6d" type="text"></div>
      <div class="row"><label for="p6t"><span class="lbl-en">Phone</span><span class="lbl-es" lang="es">Teléfono</span></label><input id="p6t" type="text"></div>
    </div>

    <div class="sec">
      <h2><span class="lbl-en">7. Financial guarantor</span><span class="lbl-es" lang="es">7. Responsable económico</span></h2>
      <div class="row"><label for="p7n"><span class="lbl-en">Name</span><span class="lbl-es" lang="es">Nombre</span></label><input id="p7n" type="text"></div>
      <div class="row"><label for="p7r"><span class="lbl-en">Relationship to you</span><span class="lbl-es" lang="es">Relación</span></label><input id="p7r" type="text" placeholder="Self / employer / …"></div>
    </div>

    <div class="sec">
      <h2><span class="lbl-en">8. Contact in Venezuela</span><span class="lbl-es" lang="es">8. Contacto en Venezuela</span></h2>
      <div class="row"><label for="p8n"><span class="lbl-en">Name</span><span class="lbl-es" lang="es">Nombre</span></label><input id="p8n" type="text"></div>
      <div class="row"><label for="p8r"><span class="lbl-en">Relationship</span><span class="lbl-es" lang="es">Relación</span></label><input id="p8r" type="text" placeholder="Hotel / host / …"></div>
      <div class="row"><label for="p8t"><span class="lbl-en">Phone</span><span class="lbl-es" lang="es">Teléfono</span></label><input id="p8t" type="text"></div>
    </div>

    <div class="sec">
      <h2><span class="lbl-en">9. Additional information</span><span class="lbl-es" lang="es">9. Información adicional</span></h2>
      <p class="field-hint no-print-elm">Have you visited Venezuela before? Options print as Sí / No in Spanish.</p>
      <div class="row"><label for="p9v"><span class="lbl-en">Prior visits to Venezuela?</span><span class="lbl-es" lang="es">¿Ha visitado Venezuela antes?</span></label>
        <select id="p9v"><option value="">—</option><option>Sí</option><option>No</option></select></div>
    </div>

    <div class="sec">
      <h2><span class="lbl-en">10. Signature</span><span class="lbl-es" lang="es">10. Firma</span></h2>
      <p class="no-print-elm" style="font-size:10pt;color:var(--muted);margin:0 0 6px;">Type your full legal name — the cursive preview is what prints as your signature line.</p>
      <div class="sig-block">
        <input type="text" id="pl-sig" class="sig-input" placeholder="Full name (signature)">
        <div id="pl-sig-out" class="sig-cursive" aria-hidden="true"></div>
      </div>
      <div class="row" style="margin-top:8px;"><label for="p10d"><span class="lbl-en">Date</span><span class="lbl-es" lang="es">Fecha</span></label><input id="p10d" name="p10d" type="text" placeholder="DD/MM/YYYY"></div>
    </div>
  </form>

  <script>
  function syncSig(a, b) {
    var i = document.getElementById(a), o = document.getElementById(b);
    if (i && o) { o.textContent = i.value || ''; }
  }
  function trackVisaFormEvent(name) {
    if (typeof window.gtag === 'function') {
      window.gtag('event', name, {
        document_type: 'planilla',
        source_page: window.location.pathname
      });
    }
  }
  trackVisaFormEvent('visa_form_tool_open');
  document.getElementById('pl-sig').addEventListener('input', function() { syncSig('pl-sig', 'pl-sig-out'); });
  syncSig('pl-sig', 'pl-sig-out');
  (function() {
    var t = new Date();
    var d = String(t.getDate()).padStart(2,'0');
    var m = String(t.getMonth()+1).padStart(2,'0');
    var y = t.getFullYear();
    var el = document.getElementById('p1fecha');
    if (el && !el.value) el.placeholder = d + '/' + m + '/' + y;
  })();
  </script>
</body>
</html>
