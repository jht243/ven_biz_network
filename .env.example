# ── Database (Supabase Postgres — session pooler, IPv4-friendly) ────
# IMPORTANT: must be the *session pooler* (port 5432, host
# aws-1-us-east-1.pooler.supabase.com) — the transaction pooler does
# not work with SQLAlchemy connection pooling.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# ── Storage / logs ─────────────────────────────────────────────────
STORAGE_DIR=./storage
LOG_LEVEL=INFO

# ── Scraper settings ───────────────────────────────────────────────
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_DELAY_SECONDS=60
SCRAPER_LOOKBACK_DAYS=30

# How many days back the report includes. 120 covers Jan 1 → mid-April
# of the same year. Bump for a longer rolling window.
REPORT_LOOKBACK_DAYS=120

# ── Tesseract (OCR for gazette PDFs) ──────────────────────────────
TESSERACT_CMD=/usr/local/bin/tesseract
TESSERACT_LANG=spa

# ── OpenAI (REQUIRED — powers the LLM investor analysis) ─────────
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
ANALYSIS_MIN_RELEVANCE=5

# ── Buttondown (subscriber signup from the website) ──
# Get a key at https://buttondown.com/settings/programming
BUTTONDOWN_API_KEY=

# ── Newsletter (optional — set to "buttondown" or "sendgrid") ────
# While set to "console", emails are printed to logs only.
NEWSLETTER_PROVIDER=buttondown
NEWSLETTER_FROM_EMAIL=briefing@venezuelanbusiness.net
NEWSLETTER_API_KEY=
SUBSCRIBER_LIST_PATH=subscribers.json

# ── Supabase Storage ─────────────────────────────────────────────
# The cron uploads report.html here; the web service reads it.
# Bucket must be public and allow text/html MIME types.
SUPABASE_URL=https://<project-ref>.supabase.co
# service_role key — REQUIRED for the cron (uploads). Web does NOT need it.
SUPABASE_SERVICE_KEY=
SUPABASE_REPORT_BUCKET=reports

# ── Server ────────────────────────────────────────────────────────
SERVER_PORT=8080
